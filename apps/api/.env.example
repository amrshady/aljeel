DATABASE_URL="postgresql://aljeel:aljeel@localhost:5432/aljeel?schema=public"
PORT=3002
NODE_ENV=development
API_VERSION=0.0.1
CORS_ORIGIN=http://localhost:3000

# Local document storage fallback (when KB/Spaces vars below are unset)
STORAGE_DIR=./storage

# KB upload — same tenant + bucket layout as workers/files-portal (FILES_PORTAL.md).
# When set, documents upload direct to Spaces/MinIO via presigned URLs.
# Omit all SPACES_* vars to use local multipart upload instead.
KB_TENANT=aljeel-ap
SPACES_ACCESS_KEY_ID=aljeel
SPACES_SECRET_ACCESS_KEY=aljeelsecret
SPACES_REGION=us-east-1
SPACES_ENDPOINT=localhost:9000
SPACES_BUCKET=accord-aljeel-ap-kb
SPACES_PREFIX=current/
SPACES_USE_SSL=false
SPACES_FORCE_PATH_STYLE=true
