DATABASE_URL="postgresql://aljeel:aljeel@localhost:5432/aljeel?schema=public"
PORT=3002
NODE_ENV=development
API_VERSION=0.0.1
CORS_ORIGIN=http://localhost:3000

# Cloudflare Access authentication.
# CF_ACCESS_TEAM_DOMAIN is the Access team domain that serves /cdn-cgi/access/certs,
# for example: your-team.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=
# CF_ACCESS_AUD is the Cloudflare Access application audience tag.
CF_ACCESS_AUD=
# Local-only escape hatch. When explicitly true, the API skips CF Access headers and
# authenticates every request as AUTH_DEV_EMAIL. Never enable in production.
AUTH_DEV_MODE=false
AUTH_DEV_EMAIL=amr+apadmin@accordpartners.ai
# Optional fallback for authenticated Aljeel staff without an AppUser row.
# Leave either value blank to deny unknown emails.
AUTH_STAFF_DOMAIN=aljeel.com
AUTH_STAFF_DEFAULT_ROLE=AP_CLERK

# Local document storage fallback (when KB/Spaces vars below are unset)
STORAGE_DIR=./storage

# Asateel reconciliation trigger API. Keep the key server-side only.
# ASATEEL_API_BASE defaults to http://127.0.0.1:5000 when omitted.
# ASATEEL_BATCHES_ROOT defaults to /home/clawdbot/.openclaw/workspace/aljeel/batches.
ASATEEL_TRIGGER_KEY=
ASATEEL_API_BASE=http://127.0.0.1:5000
ASATEEL_BATCHES_ROOT=/home/clawdbot/.openclaw/workspace/aljeel/batches

# KB upload — same tenant + bucket layout as workers/files-portal (FILES_PORTAL.md).
# When set, documents upload direct to Spaces/MinIO via presigned URLs.
# Omit all SPACES_* vars to use local multipart upload instead.
KB_TENANT=aljeel-ap
SPACES_ACCESS_KEY_ID=aljeel
SPACES_SECRET_ACCESS_KEY=aljeelsecret
SPACES_REGION=us-east-1
SPACES_ENDPOINT=localhost:9000
SPACES_BUCKET=accord-aljeel-ap-kb
SPACES_PREFIX=current/
SPACES_USE_SSL=false
SPACES_FORCE_PATH_STYLE=true
