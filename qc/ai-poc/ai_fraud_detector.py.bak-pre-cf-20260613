    # POC summary
    summary_path = AI_POC_DIR / "fraud-poc-summary.md"
    _write_poc_summary(summary_path, results)
    print(f"  POC summary: {summary_path}")

    # Final output
    print("\n" + "=" * 70)
    print(f"DELIVERABLES [{VERSION_TAG}]")
    print("=" * 70)
    for batch_id, tel in results.items():
        cost_display = 'CACHED' if tel['cache_hit'] else f"${tel['cost_usd']:.4f}"
        print(f"\n{batch_id}:")
        print(f"  Output: {tel['output_file']}")
        print(f"  AI: {tel['ai_red']} RED, {tel['ai_yellow']} YELLOW, {tel['rows_processed'] - tel['ai_flagged']} CLEAN")
