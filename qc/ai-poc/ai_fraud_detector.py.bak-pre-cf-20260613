def _build_evidence_schema() -> dict:
    return {
        "type": "OBJECT",
        "properties": {
            "source": {"type": "STRING", "enum": EVIDENCE_SOURCE_VALUES},
            "pointer": {"type": "STRING"},
            "quote": {"type": "STRING"},
        },
        "required": ["source", "pointer", "quote"],
    }


def _build_response_schema() -> dict:
    ev = _build_evidence_schema()
    row_verdict = {
        "type": "OBJECT",
        "properties": {
            "sl_no": {"type": "INTEGER"},
            "verdict": {"type": "STRING", "enum": ["RED", "YELLOW", "CLEAN"]},
            "primary_category": {"type": "STRING", "enum": CATEGORY_VALUES},
            "secondary_categories": {
                "type": "ARRAY",
                "items": {"type": "STRING", "enum": CATEGORY_VALUES},
            },
            "other_label": {"type": "STRING", "nullable": True},
            "value_at_risk_sar": {"type": "NUMBER"},
            "evidence": {"type": "ARRAY", "items": ev},
            "reasoning": {"type": "STRING"},
            "confidence": {"type": "STRING", "enum": ["high", "medium", "low"]},
        },
        "required": [
            "sl_no", "verdict", "primary_category", "secondary_categories",
            "value_at_risk_sar", "evidence", "reasoning", "confidence",
        ],
    }
    top_case = {
        "type": "OBJECT",
        "properties": {
            "rank": {"type": "INTEGER"},
            "sl_nos": {"type": "ARRAY", "items": {"type": "INTEGER"}},
            "headline": {"type": "STRING"},
            "primary_category": {"type": "STRING", "enum": CATEGORY_VALUES},
            "total_value_at_risk_sar": {"type": "NUMBER"},
            "full_reasoning": {"type": "STRING"},
            "evidence": {"type": "ARRAY", "items": ev},
            "recommended_action": {"type": "STRING", "enum": RECOMMENDED_ACTION_VALUES},
        },
        "required": [
            "rank", "sl_nos", "headline", "primary_category",
            "total_value_at_risk_sar", "full_reasoning", "evidence", "recommended_action",
        ],
    }
    batch_summary = {
        "type": "OBJECT",
        "properties": {
            "red_count": {"type": "INTEGER"},
            "yellow_count": {"type": "INTEGER"},
            "clean_count": {"type": "INTEGER"},
            "total_rows": {"type": "INTEGER"},
            "total_value_at_risk_sar": {"type": "NUMBER"},
            "catches_by_category": {"type": "STRING"},
            "key_themes": {"type": "ARRAY", "items": {"type": "STRING"}},
        },
        "required": [
            "red_count", "yellow_count", "clean_count", "total_rows",
            "total_value_at_risk_sar", "catches_by_category", "key_themes",
        ],
    }
    return {
        "type": "OBJECT",
        "properties": {
            "per_row_verdicts": {"type": "ARRAY", "items": row_verdict},
            "top_5_cases": {"type": "ARRAY", "items": top_case},
            "batch_summary": batch_summary,
        },
        "required": ["per_row_verdicts", "top_5_cases", "batch_summary"],
    }


