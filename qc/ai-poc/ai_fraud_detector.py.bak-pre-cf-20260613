def load_v30_resolved(batch_id: str) -> dict[int, dict]:
    import openpyxl
    batch_dir = ROOT / "batches" / f"jawal-{batch_id}"
    
    # Robust search for the latest resolved output file
    xlsx = batch_dir / "output" / f"Spreadsheet-{batch_id}-FILLED-v30.xlsx"
    if not xlsx.exists():
        xlsx = batch_dir / "output" / f"Spreadsheet-{batch_id}-FILLED-v15.11.2.xlsx"
    if not xlsx.exists():
        xlsx = batch_dir / "output" / f"Spreadsheet-{batch_id}-FILLED-v15.11.xlsx"
    if not xlsx.exists():
        # Fallback to look for any FILLED spreadsheet in output folder
        candidates = sorted(batch_dir.glob("output/Spreadsheet-*-FILLED-v*.xlsx"), reverse=True)
        if candidates:
            xlsx = candidates[0]
            
    if not xlsx or not xlsx.exists():
        print(f"  [data] WARNING: v30, v15.11, or other FILLED XLSX not found")
        return {}
        
    print(f"  [data] Loading resolved data from: {xlsx.name}")
    wb = openpyxl.load_workbook(xlsx, read_only=True, data_only=True)
    # Do NOT use wb.active — it can point at the wrong sheet. Prefer "Sheet1",
    # else fall back to the first sheet by index.
    ws = wb["Sheet1"] if "Sheet1" in wb.sheetnames else wb.worksheets[0]
    all_rows = list(ws.iter_rows(values_only=True))
    wb.close()
    if len(all_rows) < 4:
        print("  [data] WARNING: resolved XLSX has too few rows")
        return {}
    headers = [str(h).strip() if h is not None else f"col_{i}" for i, h in enumerate(all_rows[2])]
    resolved = {}
    # Column 0 is "*Invoice Header Identifier" (same value for every row of an
    # invoice), so it cannot key rows. Data rows are in Phase 1 parser order,
    # so key them positionally: sl_no = 1..N over non-empty rows.
    sl_no = 0
    for row in all_rows[3:]:
        if not row or all(c is None for c in row):
            continue
        sl_no += 1
