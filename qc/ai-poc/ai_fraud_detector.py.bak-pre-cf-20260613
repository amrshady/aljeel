def load_approval_emails(batch_id: str) -> list[dict]:
    try:
        import extract_msg
    except ImportError:
        print("  [data] WARNING: extract_msg not available, skipping email load")
        return []
    batch_raw = ROOT / "batches" / f"jawal-{batch_id}" / "raw"
    if not batch_raw.exists():
        print(f"  [data] WARNING: raw dir not found: {batch_raw}")
        return []
    emails = []
    errors = 0
    for root_dir, dirs, files in os.walk(batch_raw):
        for fname in files:
            if not fname.endswith('.msg'):
                continue
            fpath = Path(root_dir) / fname
            rel_path = str(fpath.relative_to(batch_raw))
            try:
                msg = extract_msg.openMsg(str(fpath))
                body = msg.body or ""
                subject = msg.subject or ""
                sender = str(msg.sender) if msg.sender else ""
                received_at = None
                try:
                    if msg.date:
                        received_at = str(msg.date)
                except Exception:
                    pass
                att_names = []
                try:
                    for att in msg.attachments:
                        n = getattr(att, 'longFilename', None) or getattr(att, 'shortFilename', None)
                        if n:
                            att_names.append(str(n))
                except Exception:
                    pass
                folder = Path(root_dir).name
                ticket_hint = folder if folder.startswith('690') else None
                emails.append({
                    "filename": fname,
                    "rel_path": rel_path,
                    "ticket_hint": ticket_hint,
                    "subject": subject,
                    "sender": sender,
                    "received_at": received_at,
                    "body_text_full": body,
                    "body_chars": len(body),
                    "attachment_names": att_names,
                })
            except Exception as e:
                errors += 1
                if errors <= 3:
                    print(f"  [data] WARNING: Failed to read {fname}: {e}")
    total_chars = sum(e["body_chars"] for e in emails)
    print(f"  [data] Loaded {len(emails)} emails ({total_chars:,} total body chars)")
    if errors:
        print(f"  [data] WARNING: {errors} emails failed to parse")
    return emails


def load_manpower() -> list[dict]:
    import openpyxl
    wb = openpyxl.load_workbook(MANPOWER_XLSX, read_only=True, data_only=True)
    ws = wb['Manpower']
    header_row_idx = None
    headers = []
    for row_idx, row in enumerate(ws.iter_rows(values_only=True), 1):
        if any(str(v).lower() == 'emp no' for v in row if v):
            header_row_idx = row_idx
            headers = [str(v).strip() if v else f"col_{i}" for i, v in enumerate(row)]
            break
    if not header_row_idx:
        print("  [data] WARNING: manpower header not found")
        return []
    employees = []
    for row in ws.iter_rows(min_row=header_row_idx + 1, values_only=True):
        if row[0] is None:
            continue
        row_dict = dict(zip(headers, row))
        emp = {
            "emp_no": row_dict.get("Emp No"),
            "name": row_dict.get("Name"),
            "location": row_dict.get("Location"),
            "manager_no": row_dict.get("Manager No"),
            "line_manager": row_dict.get("Line Manager"),
