def build_payload(batch_id: str) -> tuple[dict, str]:
    print(f"\n[{batch_id}] Building payload...")
    invoice_rows = load_invoice_rows(batch_id)
    v30_resolved = load_v30_resolved(batch_id)
    approval_emails = load_approval_emails(batch_id)
    manpower = load_manpower()
    lm_overrides, pax_overrides = load_overrides()
    cross_batch = load_cross_batch_history()
    merged_rows = []
    for row in invoice_rows:
        sl = row.get("sl_no")
        resolved = v30_resolved.get(sl, {})
        merged = {**row}
        if resolved:
            merged["account_resolved_v30"] = resolved.get("account_code")
            merged["employee_resolved_v30"] = resolved.get("employee_no")
            merged["location_resolved_v30"] = resolved.get("location_code")
            merged["cost_center_v30"] = resolved.get("cost_center")
            merged["div_code_v30"] = resolved.get("div_code")
            merged["row_status_v30"] = resolved.get("row_status")
            merged["agent_flags_v30"] = resolved.get("agent_flags")
            merged["qc_catches_v30"] = resolved.get("qc_catches")
            merged["trip_purpose_v30"] = resolved.get("trip_purpose")
        merged_rows.append(merged)
    payload = {
        "batch_id": batch_id,
        "invoice_rows": merged_rows,
        "approval_emails": approval_emails,
        "manpower": manpower,
        "line_manager_overrides": lm_overrides,
        "pax_overrides": pax_overrides,
        "cross_batch_history": {
            "passenger_trips": cross_batch.get("passenger_trips", {}),
            "tickets": cross_batch.get("tickets", {}),
            "batches_processed": cross_batch.get("batches_processed", []),
        },
    }
    # Cache key includes version + model + config
    config_tag = (
        f"schema={VERSION_TAG}|{GEMINI_PRIMARY_MODEL}"
        f"|maxOut={GEMINI_MAX_OUTPUT_TOKENS}|thinkBudget={GEMINI_THINKING_BUDGET}"
    )
    payload_json = json.dumps(payload, ensure_ascii=False, sort_keys=True)
    sha256 = hashlib.sha256((config_tag + payload_json).encode("utf-8")).hexdigest()
    print(f"  [payload] {batch_id}: {len(merged_rows)} rows, {len(approval_emails)} emails, {len(manpower)} employees")
    print(f"  [payload] JSON size: {len(payload_json):,} chars (~{len(payload_json) // 4:,} tokens est.)")
    print(f"  [payload] SHA256 ({VERSION_TAG}): {sha256[:16]}...")
    return payload, sha256


