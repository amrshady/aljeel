# ---------------------------------------------------------------------------
# entity_key computation (post-Gemini, not by model)
# ---------------------------------------------------------------------------

_HONORIFICS = re.compile(
    r"\b(mr|mrs|ms|miss|dr|prof|eng|engr|sir|سيد|د|م|أ|ا|المهندس|الدكتور)\.?\b",
    flags=re.IGNORECASE | re.UNICODE,
)

_AMOUNT_BANDS = [500, 1000, 2000, 5000, 10000, 20000, 50000]


def _normalize_passenger(name: str) -> str:
    if not name:
        return "UNKNOWN"
    # Unicode normalize
    name = unicodedata.normalize("NFKC", name)
    # Remove honorifics
    name = _HONORIFICS.sub("", name)
    # Strip stray punctuation (e.g. "." left by "Dr."), normalize spaces
    name = re.sub(r"[^\w\s]", " ", name)
    name = re.sub(r"\s+", " ", name).strip().upper()
    return name or "UNKNOWN"


def _amount_band(amount: float) -> str:
    for band in _AMOUNT_BANDS:
        if amount <= band:
            return f"lte{band}"
    return "gt50000"


def _route_corridor(route: str) -> str:
    if not route:
        return "UNKNOWN"
    # Extract 3-letter codes, sort for normalization (JED-RUH == RUH-JED)
    codes = re.findall(r"\b[A-Z]{3}\b", route.upper())
    if len(codes) >= 2:
        return "-".join(sorted(set(codes[:2])))
    return route.upper()[:20]


def compute_entity_key(row: dict) -> str:
    """
    Stable hash for cross-batch tracking.
    Format: {passenger_normalized}|{route_corridor}|{amount_band}|{yyyy-mm}
    """
    passenger = _normalize_passenger(
        row.get("passenger") or row.get("description") or ""
    )
    # Try various route fields
    route = row.get("route") or row.get("sector") or ""
    corridor = _route_corridor(route)

    amount = 0.0
    for fld in ("value_at_risk_sar", "total_amount", "taxable_amount", "amount"):
        try:
            v = row.get(fld)
            if v is not None:
                amount = float(v)
                break
        except (TypeError, ValueError):
            pass
    band = _amount_band(amount)

    # Service date → yyyy-mm
    date_str = row.get("service_date") or row.get("issue_date") or ""
    ym = "0000-00"
    m = re.search(r"(\d{4})-(\d{2})", str(date_str))
    if m:
        ym = f"{m.group(1)}-{m.group(2)}"

    return f"{passenger}|{corridor}|{band}|{ym}"


