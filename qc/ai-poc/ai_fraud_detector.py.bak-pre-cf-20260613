        merged = {
            **inv_row,
            "value_at_risk_sar": verdict.get("value_at_risk_sar", 0.0),
        }
        verdict_copy = dict(verdict)
        verdict_copy["entity_key"] = compute_entity_key(merged)
        enriched.append(verdict_copy)
    return enriched


