def main():
    parser = argparse.ArgumentParser(description="AlJeel AI Fraud Detector")
    parser.add_argument("--no-cache", action="store_true", default=False,
                        help="Skip SHA256 payload cache and force a fresh LLM call")
    parser.add_argument("--batches", nargs="*", default=None,
                        help="Batch IDs to process (default: all configured batches)")
    args = parser.parse_args()
    no_cache = args.no_cache

    print("=" * 70)
    print(f"AlJeel AP — AI Fraud Detector POC {VERSION_TAG}")
    print(f"Run: {datetime.utcnow().strftime('%Y-%m-%d %H:%M:%S UTC')}")
    print("=" * 70)
    print()
    print("Model: gemini-3.1-pro-preview via direct Gemini API")
    print("Schema: hardened Pydantic v2 + Gemini responseSchema")
    print("Output: *-fraud-ai-v162.json (v16 + v161 originals preserved)")
    print()

    if args.batches is not None:
        batches_to_run = args.batches
    else:
        batches_to_run = os.environ.get("AI_POC_BATCHES", "J26-640,J26-788").split(",")
    batches_to_run = [b.strip() for b in batches_to_run if b.strip()]
    print(f"Batches: {batches_to_run}")
    print()

    results = {}
    for batch_id in batches_to_run:
        try:
            results[batch_id] = process_batch(batch_id, no_cache=no_cache)
        except Exception as e:
            print(f"\n❌ {batch_id} FAILED: {e}", file=sys.stderr)
            import traceback
            traceback.print_exc()
            sys.exit(1)

    # Combined report
    print("\n\nBuilding combined comparison report...")
    report_path = AI_POC_DIR / "fraud-comparison-report.md"

    report_lines = [
        f"# AlJeel AP — AI Fraud Detector vs v15.11 Deterministic Rules ({VERSION_TAG})",
        "",
        f"**Generated:** {datetime.utcnow().strftime('%Y-%m-%d %H:%M UTC')}",
        f"**Schema:** {VERSION_TAG} — hardened Pydantic v2 + Gemini responseSchema",
        "**Model:** gemini-3.1-pro-preview (direct API, 2M context)",
        "",
        "## Telemetry Summary",
        "",
        "| Batch | Model | Rows | RED | YELLOW | SAR at Risk | v15.11 Flagged | Cost | Latency | Pydantic |",
        "|-------|-------|------|-----|--------|-------------|----------------|------|---------|----------|",
    ]
    for batch_id, tel in results.items():
        cost_str = 'CACHED' if tel['cache_hit'] else f"${tel['cost_usd']:.4f}"
        valid_str = "✅" if tel['pydantic_valid'] else f"⚠️ {len(tel['validation_errors'])} err"
        report_lines.append(
            f"| {batch_id} | {tel['model_used']} | {tel['rows_processed']} "
            f"| {tel['ai_red']} | {tel['ai_yellow']} "
            f"| SAR {tel['total_sar_at_risk']:,.0f} "
            f"| {tel['v1511_flagged']} | {cost_str} | {tel['total_latency_sec']}s | {valid_str} |"
        )

    # Combined catches_by_category across both batches
    all_cats: dict[str, int] = {}
    for tel in results.values():
        for cat, cnt in tel.get("catches_by_category", {}).items():
            all_cats[cat] = all_cats.get(cat, 0) + cnt

    report_lines += [
        "",
        "## Combined Catches by Category (Both Batches)",
        "",
        "| Category | Count |",
        "|----------|-------|",
    ]
    for cat, cnt in sorted(all_cats.items(), key=lambda x: -x[1]):
        report_lines.append(f"| {cat} | {cnt} |")

    report_lines += ["", "---", ""]
    for batch_id, tel in results.items():
        report_lines.append(tel.get("comparison_md", f"(comparison for {batch_id} missing)"))
        report_lines.append("\n---\n")

    report_text = "\n".join(report_lines)
    report_path.write_text(report_text, encoding="utf-8")
