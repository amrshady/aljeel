        lines.append("| SL# | v15.11 Category | AI Verdict | AI Reasoning |")
        lines.append("|-----|----------------|-----------|-------------|")
        for sl in v1511_only:
            pv = pv_map.get(sl, {})
            v_cat = _get_v1511_category(sl, v1511_catches)
            reasoning = (pv.get("reasoning") or "")[:150]
            lines.append(f"| {sl} | {v_cat} | {pv.get('verdict','CLEAN')} | {reasoning} |")
    else:
        lines.append("_No rules-only catches._")

    lines += [
        "",
        f"### Q4: Neither ({len(neither)} rows)",
        "_Both agree: clean_",
        f"_All {len(neither)} remaining rows consensus-clean._",
        "",
        "## Top 5 AI Cases",
        "",
    ]
    for case in top5:
        sl_nos = case.get("sl_nos", [case.get("sl_no")])
        if not isinstance(sl_nos, list):
            sl_nos = [sl_nos]
        in_v1511 = "✅ Also in v15.11" if any(s in v1511_flagged for s in sl_nos) else "🆕 AI-only find"
        ev_lines = []
        for ev in case.get("evidence", []):
            ev_lines.append(
                f"  - [{ev.get('source')}] {ev.get('pointer')}: `{(ev.get('quote') or '')[:120]}`"
            )
        lines += [
            f"### Rank {case.get('rank')}: {case.get('headline')} ({in_v1511})",
            f"**SL#s:** {', '.join(str(s) for s in sl_nos)}",
            f"**Category:** {case.get('primary_category')}",
            f"**SAR at Risk:** {case.get('total_value_at_risk_sar', 0):,.2f}",
            f"**Recommended Action:** {case.get('recommended_action')}",
            f"**Reasoning:** {case.get('full_reasoning', '')}",
            "**Evidence:**",
        ] + ev_lines + [""]

    lines += [
        "## AI Key Themes",
        "",
        *[f"- {t}" for t in summary.get("key_themes", [])],
        "",
        "## v15.11 Catches Detail",
        "",
        f"Categories: {json.dumps(v1511_catches.get('summary_catches_by_category', {}), ensure_ascii=False)}",
        "",
    ]
    fw = v1511_catches.get("fraud_watch", {})
    if fw.get("high_signal_catches"):
        lines.append("### v15.11 High Signal Catches")
        lines.append("")
        for c in fw.get("high_signal_catches", []):
            lines.append(
                f"- SL#{c.get('sl_nos')} | {c.get('passenger')} | "
                f"{c.get('category')} | SAR {c.get('value_at_risk_sar')} | {(c.get('detail') or '')[:100]}"
            )
    lines += [
        "",
        f"### v15.11 Medium NO_APPROVAL",
        f"Count: {fw.get('medium_no_approval_count', 0)}, Total: SAR {fw.get('medium_no_approval_total_sar', 0):,.2f}",
        "",
    ]
    return "\n".join(lines)


def _get_v1511_category(sl: int, v1511_catches: dict) -> str:
    for c in v1511_catches.get("within_batch", []):
        if sl in c.get("sl_nos", [c.get("sl_no")]):
            return c.get("category", "?")
    for c in v1511_catches.get("cross_batch", []):
        if sl in c.get("sl_nos", [c.get("sl_no")]):
            return c.get("category", "?") + " (XB)"
    return "?"


# ---------------------------------------------------------------------------
# Main: Process One Batch
# ---------------------------------------------------------------------------
def process_batch(batch_id: str, no_cache: bool = False) -> dict:
    print(f"\n{'=' * 60}")
    print(f"PROCESSING BATCH: {batch_id} [{VERSION_TAG}]")
    print(f"{'=' * 60}")
    t_start = time.time()

    # Output file uses v162 suffix (preserve v16 + v161 originals)
    raw_output = AI_POC_DIR / f"{batch_id.lower()}-fraud-ai-v162.json"

    payload, sha256 = build_payload(batch_id)

    cache_file = CACHE_DIR / f"{sha256}.fraud.json"
    llm_resp = None
    model_used = None
    usage = {}
    cached = False

    def call_llm_and_cache():
        print(f"\n[{batch_id}] Building prompt...")
        prompt = build_prompt(batch_id, payload)
        prompt_tokens_est = len(prompt) // 4
        print(f"  [prompt] Estimated tokens: ~{prompt_tokens_est:,}")
        MAX_TOKENS = 900_000
        if prompt_tokens_est > MAX_TOKENS:
            raise RuntimeError(
                f"[ABORT] Payload too large: ~{prompt_tokens_est:,} tokens > {MAX_TOKENS:,} limit."
            )
        print(f"\n[{batch_id}] Calling LLM...")
        t_llm_start = time.time()
        llm_raw_resp, called_model, called_usage = call_llm(prompt)
        llm_latency = time.time() - t_llm_start
        cache_data = {
            "batch_id": batch_id,
            "schema_version": VERSION_TAG,
            "sha256": sha256,
            "model_used": called_model,
            "usage": called_usage,
            "llm_latency_sec": llm_latency,
            "raw_response": llm_raw_resp,
        }
        with cache_file.open("w", encoding="utf-8") as f:
            json.dump(cache_data, f, ensure_ascii=False, indent=2)
        print(f"  [cache] Saved to {cache_file.name}")
        return llm_raw_resp, called_model, called_usage

    if cache_file.exists() and not no_cache:
        print(f"  [cache] HIT: {sha256[:16]}...")
        try:
            with cache_file.open(encoding="utf-8") as f:
                cached_data = json.load(f)
            llm_resp = cached_data.get("raw_response")
            model_used = cached_data.get("model_used")
            usage = cached_data.get("usage", {})
            cached = True
        except json.JSONDecodeError as ex:
            print(f"  [cache] CORRUPT: {cache_file.name} ({ex}); deleting and retrying LLM")
            cache_file.unlink(missing_ok=True)
            llm_resp, model_used, usage = call_llm_and_cache()
    elif cache_file.exists() and no_cache:
        print(f"  [cache] BYPASS (--no-cache): {sha256[:16]}...")
        llm_resp, model_used, usage = call_llm_and_cache()
    else:
        llm_resp, model_used, usage = call_llm_and_cache()

    # Parse
    print(f"\n[{batch_id}] Parsing response...")
    try:
        parsed_result = parse_llm_response(llm_resp)
    except (MalformedLLMResponse, json.JSONDecodeError) as ex:
        if not cached:
            raise
        print(f"  [cache] CORRUPT: {cache_file.name} cached raw_response is malformed ({ex})")
        print(f"  [cache] Deleting corrupt cache entry and retrying LLM once")
        cache_file.unlink(missing_ok=True)
        cached = False
        llm_resp, model_used, usage = call_llm_and_cache()
        print(f"\n[{batch_id}] Parsing response...")
        parsed_result = parse_llm_response(llm_resp)

    # Normalize catches_by_category: Gemini returns it as string (JSON), parse to dict
    bs = parsed_result.get("batch_summary", {})
    if isinstance(bs.get("catches_by_category"), str):
        try:
            bs["catches_by_category"] = json.loads(bs["catches_by_category"])
            parsed_result["batch_summary"] = bs
            print(f"  [parse] Parsed catches_by_category from JSON string OK")
        except Exception as ex:
            print(f"  [parse] WARNING: catches_by_category JSON parse failed: {ex}; using empty dict")
            bs["catches_by_category"] = {}
            parsed_result["batch_summary"] = bs

    # Pydantic validation
    print(f"\n[{batch_id}] Running Pydantic validation ({VERSION_TAG})...")
    valid, validation_errors, parsed_model = validate_fraud_response(parsed_result, batch_id)
    if not valid:
        print(f"  [validation] PARTIAL — {len(validation_errors)} issue(s):")
        for e in validation_errors[:10]:
            print(f"    {e}")
    else:
        print(f"  [validation] OK — all rows pass Pydantic schema")

    # Row count check
    expected_rows = len(payload["invoice_rows"])
    got_rows = len(parsed_result.get("per_row_verdicts", []))
    if got_rows != expected_rows:
        print(f"  [validation] WARNING: Expected {expected_rows} rows, got {got_rows}")
    else:
        print(f"  [validation] Row count OK: {got_rows}/{expected_rows}")

    # Enrich with entity_key (post-call computation)
    print(f"\n[{batch_id}] Computing entity_keys...")
    parsed_result["per_row_verdicts"] = enrich_entity_keys(
        parsed_result["per_row_verdicts"], payload["invoice_rows"]
    )
    print(f"  [entity_key] Added entity_key to {len(parsed_result['per_row_verdicts'])} rows")

    # Load v15.11 catches
    v1511_catches = load_v1511_catches(batch_id)

    # Save output (v162 file, preserve v16 + v161)
    output_data = {
        "batch_id": batch_id,
        "schema_version": VERSION_TAG,
        "model_used": model_used,
        "cache_hit": cached,
        "sha256": sha256,
        "usage": usage,
        "validation_errors": validation_errors,
        "pydantic_valid": valid,
        "ai_result": parsed_result,
        "v1511_summary_catches": v1511_catches.get("summary_catches_by_category"),
        "generated_at": datetime.utcnow().isoformat() + "Z",
    }
    json.dump(output_data, open(raw_output, "w"), ensure_ascii=False, indent=2)
    print(f"  [output] Saved to {raw_output.name}")

    # Build comparison
    comparison_md = build_comparison(
        batch_id, parsed_result, v1511_catches, payload["invoice_rows"]
    )

    # Cost estimate
    in_tokens = usage.get("prompt_tokens", 0)
    out_tokens = usage.get("completion_tokens", 0)
    if "gemini-3.1-pro" in (model_used or "") or "3.1-pro" in (model_used or ""):
        cost_usd = (in_tokens * 2.0 / 1_000_000) + (out_tokens * 12.0 / 1_000_000)
    elif "gemini-2.5-flash" in (model_used or ""):
        cost_usd = (in_tokens * 0.075 / 1_000_000) + (out_tokens * 0.30 / 1_000_000)
    elif "sonnet" in (model_used or ""):
        cost_usd = (in_tokens * 3.0 / 1_000_000) + (out_tokens * 15.0 / 1_000_000)
    else:
        cost_usd = 0.0

    total_latency = time.time() - t_start
    summary = parsed_result.get("batch_summary", {})
    ai_flagged_count = len([v for v in parsed_result.get("per_row_verdicts", []) if v["verdict"] != "CLEAN"])
    ai_red_count = len([v for v in parsed_result.get("per_row_verdicts", []) if v["verdict"] == "RED"])

    telemetry = {
        "batch_id": batch_id,
        "schema_version": VERSION_TAG,
        "model_used": model_used,
        "cache_hit": cached,
        "input_tokens": in_tokens,
        "output_tokens": out_tokens,
        "cost_usd": round(cost_usd, 4),
        "total_latency_sec": round(total_latency, 1),
        "rows_processed": len(payload["invoice_rows"]),
        "ai_flagged": ai_flagged_count,
        "ai_red": ai_red_count,
        "ai_yellow": ai_flagged_count - ai_red_count,
        "total_sar_at_risk": summary.get("total_value_at_risk_sar", 0.0),
        "catches_by_category": summary.get("catches_by_category", {}),
        "v1511_flagged": len(v1511_catches.get("flagged_sl_nos", [])),
        "validation_errors": validation_errors,
        "pydantic_valid": valid,
        "batch_summary": summary,
        "output_file": str(raw_output),
        "comparison_md": comparison_md,
    }

    print(f"\n[{batch_id}] Done!")
    print(f"  Model: {model_used} | {'CACHED' if cached else f'${cost_usd:.4f}'} | {total_latency:.1f}s")
    print(f"  AI: {ai_red_count} RED + {ai_flagged_count - ai_red_count} YELLOW | v15.11: {telemetry['v1511_flagged']} flagged")
    print(f"  Total SAR at risk: {summary.get('total_value_at_risk_sar', 0):,.2f}")
    print(f"  Pydantic valid: {valid} | Validation errors: {len(validation_errors)}")
    return telemetry


