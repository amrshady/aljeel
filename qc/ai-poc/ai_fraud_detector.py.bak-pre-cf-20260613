            print(f"  Validation errors: {len(tel['validation_errors'])}")
        print(f"  Catches by category: {json.dumps(tel['catches_by_category'], ensure_ascii=False)}")
    print(f"\nComparison report: {report_path}")
    print(f"POC summary: {summary_path}")
    return results


def _write_poc_summary(path: Path, results: dict):
    j640 = results.get("J26-640", {})
    j788 = results.get("J26-788", {})

    def _q(batch_id: str, ai_result_file: Path, v1511_catches: dict):
        if not ai_result_file.exists():
            return {}
        data = json.load(open(ai_result_file))
        ai_r = data.get("ai_result", {})
        pvs = ai_r.get("per_row_verdicts", [])
        v15 = load_v1511_catches(batch_id)
        v_set = set(v15.get("flagged_sl_nos", []))
        a_set = {v["sl_no"] for v in pvs if v["verdict"] != "CLEAN"}
        return {
            "both": len(v_set & a_set),
            "ai_only": len(a_set - v_set),
            "v1511_only": len(v_set - a_set),
            "neither": len(set(v["sl_no"] for v in pvs) - v_set - a_set),
        }

    q640 = _q("J26-640", AI_POC_DIR / "j26-640-fraud-ai-v162.json", j640)
    q788 = _q("J26-788", AI_POC_DIR / "j26-788-fraud-ai-v162.json", j788)

    def _fmt_cat(cats: dict) -> str:
        if not cats:
            return "_(none)_"
        return ", ".join(f"{k}={v}" for k, v in sorted(cats.items(), key=lambda x: -x[1]))

    lines = [
        f"# AlJeel AP — AI Fraud Detector POC: Final Summary ({VERSION_TAG})",
        "",
        f"**Generated:** {datetime.utcnow().strftime('%Y-%m-%d %H:%M UTC')}",
        f"**Schema:** {VERSION_TAG} — Pydantic v2 + Gemini responseSchema locked categories",
        "**Model:** gemini-3.1-pro-preview (direct Gemini API, 2M context)",
        "",
        "## Headline Findings",
        "",
        "### J26-640",
        f"- AI: **{j640.get('ai_red',0)} RED + {j640.get('ai_yellow',0)} YELLOW** / {j640.get('rows_processed','?')} rows",
        f"- **Total SAR at risk: {j640.get('total_sar_at_risk',0):,.2f}**",
        f"- v15.11 flagged: **{j640.get('v1511_flagged',0)} rows**",
        f"- Agreement: **{q640.get('both','?')}** | AI-only: **{q640.get('ai_only','?')}** | Rules-only: **{q640.get('v1511_only','?')}**",
        f"- Pydantic valid: {j640.get('pydantic_valid', '?')} | Errors: {len(j640.get('validation_errors', []))}",
        f"- Categories: {_fmt_cat(j640.get('catches_by_category', {}))}",
        f"- Cost: ${j640.get('cost_usd','?')} | Latency: {j640.get('total_latency_sec','?')}s",
        "",
        "### J26-788",
        f"- AI: **{j788.get('ai_red',0)} RED + {j788.get('ai_yellow',0)} YELLOW** / {j788.get('rows_processed','?')} rows",
        f"- **Total SAR at risk: {j788.get('total_sar_at_risk',0):,.2f}**",
        f"- v15.11 flagged: **{j788.get('v1511_flagged',0)} rows**",
        f"- Agreement: **{q788.get('both','?')}** | AI-only: **{q788.get('ai_only','?')}** | Rules-only: **{q788.get('v1511_only','?')}**",
        f"- Pydantic valid: {j788.get('pydantic_valid', '?')} | Errors: {len(j788.get('validation_errors', []))}",
        f"- Categories: {_fmt_cat(j788.get('catches_by_category', {}))}",
        f"- Cost: ${j788.get('cost_usd','?')} | Latency: {j788.get('total_latency_sec','?')}s",
        "",
        "## Schema Judgment",
        "",
        "The v16.1 hardened schema enforces:",
        "- 12 named primary_category values (no free-form invention)",
        "- Structured Evidence (source enum + pointer + quote)",
        "- value_at_risk_sar per row (enables SAR aggregation)",
        "- entity_key for cross-batch tracking (computed post-call)",
