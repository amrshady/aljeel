class MalformedLLMResponse(ValueError):
    """Raised when the LLM response contains extractable but invalid JSON."""


def parse_llm_response(resp: dict) -> dict:
    choices = resp.get("choices", [])
    if not choices:
        raise ValueError(f"No choices in response: {json.dumps(resp)[:300]}")
    text = choices[0].get("message", {}).get("content", "").strip()
    if not text:
        raise ValueError("Empty response content")
    text = re.sub(r'^```(?:json)?\s*', '', text, flags=re.MULTILINE)
    text = re.sub(r'\s*```\s*$', '', text, flags=re.MULTILINE)
    text = text.strip()
    first_error = None
    if text.startswith("{"):
        try:
            return json.loads(text)
        except json.JSONDecodeError as exc:
            first_error = exc
    match = re.search(r'\{.*\}', text, re.DOTALL)
    if match:
        try:
            return json.loads(match.group())
        except json.JSONDecodeError as exc:
            raise MalformedLLMResponse(
                f"Malformed JSON in LLM response: {exc}. First 500 chars: {text[:500]}"
            ) from exc
    if first_error:
        raise MalformedLLMResponse(
            f"Malformed JSON in LLM response: {first_error}. First 500 chars: {text[:500]}"
        ) from first_error
    raise ValueError(f"Cannot extract JSON from response. First 500 chars: {text[:500]}")


