                    val = line.split("=", 1)[1].strip().strip('"').strip("'")
                    break
    return val


# ---------------------------------------------------------------------------
# LLM — Gemini 3.1 Pro direct API (no fallback per operator instruction)
# ---------------------------------------------------------------------------
GEMINI_PRIMARY_MODEL = "gemini-3.1-pro-preview"
GEMINI_CTX_LIMIT = 2_000_000
GEMINI_MAX_OUTPUT_TOKENS = 65536
GEMINI_THINKING_BUDGET = 8192
GEMINI_REQUEST_TIMEOUT_SECONDS = 360   # 6 minutes — handles up to ~500K token payloads
GEMINI_MAX_ATTEMPTS = 2   # 2 × 360s = 12 min max; 3 × 120s was only wasting time
GEMINI_RETRY_DELAY_SECONDS = 10  # give Gemini more breathing room between retries
GEMINI_RETRYABLE_HTTP_CODES = {500, 503}


def _is_timeout_urlerror(exc: urllib.error.URLError) -> bool:
    reason = getattr(exc, "reason", None)
    return (
        isinstance(reason, socket.timeout)
        or isinstance(reason, TimeoutError)
        or "timed out" in str(reason).lower()
        or "timeout" in str(reason).lower()
    )


def _call_gemini_direct(
    prompt_text: str,
    api_key: str,
    model: str,
    max_output_tokens: int = GEMINI_MAX_OUTPUT_TOKENS,
    response_schema: Optional[dict] = None,
) -> dict:
    """Call Gemini API directly with optional responseSchema for structured output."""
    url = (
        f"https://generativelanguage.googleapis.com/v1beta/"
        f"models/{model}:generateContent?key={api_key}"
    )
    generation_config: dict = {
        "temperature": 0.1,
        "maxOutputTokens": max_output_tokens,
        "thinkingConfig": {
            "thinkingBudget": GEMINI_THINKING_BUDGET,
        },
    }
    if response_schema is not None:
        generation_config["responseSchema"] = response_schema
        generation_config["responseMimeType"] = "application/json"

    encoded_data = json.dumps({
        "contents": [{"parts": [{"text": prompt_text}]}],
        "generationConfig": generation_config,
    }).encode("utf-8")
    req = urllib.request.Request(
        url, data=encoded_data,
        headers={"Content-Type": "application/json"},
    )
    for attempt in range(1, GEMINI_MAX_ATTEMPTS + 1):
        try:
            print(
                f"  [llm] Sending {len(encoded_data):,} bytes to Gemini "
                f"(timeout={GEMINI_REQUEST_TIMEOUT_SECONDS}s)...",
                flush=True,
            )
            t_start = time.time()
            with urllib.request.urlopen(req, timeout=GEMINI_REQUEST_TIMEOUT_SECONDS) as resp:
                if resp.status in GEMINI_RETRYABLE_HTTP_CODES:
                    body = resp.read()
                    raise urllib.error.HTTPError(
                        url, resp.status, "Retryable Gemini response",
                        resp.headers, io.BytesIO(body)
                    )
                response_data = resp.read()
                resp_size = len(response_data)
                elapsed = time.time() - t_start
                print(
                    f"  [llm] Response received ({resp_size:,} bytes) in {elapsed:.1f}s",
                    flush=True,
                )
                return json.loads(response_data)
        except socket.timeout:
            if attempt == GEMINI_MAX_ATTEMPTS:
                raise
            print(
                f"  [llm] WARNING: Gemini request timed out after "
                f"{GEMINI_REQUEST_TIMEOUT_SECONDS}s "
                f"(attempt {attempt}/{GEMINI_MAX_ATTEMPTS}); retrying in "
                f"{GEMINI_RETRY_DELAY_SECONDS}s...",
                flush=True,
            )
            time.sleep(GEMINI_RETRY_DELAY_SECONDS)
        except urllib.error.HTTPError as e:
            if e.code not in GEMINI_RETRYABLE_HTTP_CODES or attempt == GEMINI_MAX_ATTEMPTS:
                raise
            print(
                f"  [llm] WARNING: Gemini returned HTTP {e.code} "
                f"(attempt {attempt}/{GEMINI_MAX_ATTEMPTS}); retrying in "
                f"{GEMINI_RETRY_DELAY_SECONDS}s...",
                flush=True,
            )
            time.sleep(GEMINI_RETRY_DELAY_SECONDS)
        except urllib.error.URLError as e:
            if not _is_timeout_urlerror(e) or attempt == GEMINI_MAX_ATTEMPTS:
                raise
            print(
                f"  [llm] WARNING: Gemini request timed out after "
                f"{GEMINI_REQUEST_TIMEOUT_SECONDS}s "
                f"(attempt {attempt}/{GEMINI_MAX_ATTEMPTS}); retrying in "
                f"{GEMINI_RETRY_DELAY_SECONDS}s...",
                flush=True,
            )
            time.sleep(GEMINI_RETRY_DELAY_SECONDS)

    raise RuntimeError("Gemini request retry loop exited unexpectedly")


def _gemini_to_openai_shape(gemini_resp: dict, model: str) -> dict:
    candidates = gemini_resp.get("candidates", [])
    content = ""
    finish_reason = "stop"
    if candidates:
        cand = candidates[0]
        finish_reason = cand.get("finishReason", "stop")
        parts = cand.get("content", {}).get("parts", [])
        content = " ".join(p.get("text", "") for p in parts if "text" in p).strip()
    usage_meta = gemini_resp.get("usageMetadata", {})
    usage = {
        "prompt_tokens":     usage_meta.get("promptTokenCount", 0),
        "completion_tokens": usage_meta.get("candidatesTokenCount",
                                usage_meta.get("outputTokenCount", 0)),
        "total_tokens":      usage_meta.get("totalTokenCount", 0),
    }
    return {
        "choices": [{"message": {"role": "assistant", "content": content},
                     "finish_reason": finish_reason}],
        "usage": usage,
        "model": gemini_resp.get("modelVersion", model),
        "_raw_gemini": gemini_resp,
    }


def call_llm(prompt_text: str, max_output_tokens: int = 65536) -> tuple[dict, str, dict]:
    """
    Call gemini-3.1-pro-preview with responseSchema for structured output.
    NO Flash fallback — if this fails, raises with full error body.
    """
    gemini_key = _load_env_key("GEMINI_API_KEY")
    if not gemini_key:
        raise RuntimeError("GEMINI_API_KEY not found in ~/.openclaw/.env")

    input_estimate = len(prompt_text) // 4
    print(f"  [llm] Input estimate: ~{input_estimate:,} tokens ({len(prompt_text):,} chars)")

    if input_estimate > GEMINI_CTX_LIMIT * 0.9:
        raise RuntimeError(
            f"[ABORT] Prompt too large: ~{input_estimate:,} tokens > "
            f"{GEMINI_CTX_LIMIT * 0.9:.0f} limit for {GEMINI_PRIMARY_MODEL}"
        )

    print(
        f"  [llm] Calling {GEMINI_PRIMARY_MODEL} "
        f"(maxOutputTokens={GEMINI_MAX_OUTPUT_TOKENS:,}, thinkingBudget={GEMINI_THINKING_BUDGET:,}, "
        f"responseSchema=ENABLED, responseMimeType=application/json)...",
        flush=True,
    )
    t0 = time.time()
    try:
        raw = _call_gemini_direct(
            prompt_text, gemini_key, GEMINI_PRIMARY_MODEL,
            GEMINI_MAX_OUTPUT_TOKENS,
            response_schema=GEMINI_RESPONSE_SCHEMA,
        )
        latency = time.time() - t0
        shaped = _gemini_to_openai_shape(raw, GEMINI_PRIMARY_MODEL)
        usage = shaped["usage"]
        finish = shaped["choices"][0].get("finish_reason", "?")
        print(
            f"  [llm] {GEMINI_PRIMARY_MODEL} OK in {latency:.1f}s | "
            f"in={usage.get('prompt_tokens', '?')} out={usage.get('completion_tokens', '?')} "
            f"finish={finish}"
        )
        return shaped, GEMINI_PRIMARY_MODEL, usage
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        raise RuntimeError(
            f"{GEMINI_PRIMARY_MODEL} HTTP {e.code} — stopping as instructed. "
            f"Full error body: {body[:2000]}"
        ) from e
    except Exception as e:
        raise RuntimeError(
            f"{GEMINI_PRIMARY_MODEL} failed: {type(e).__name__}: {e} — stopping as instructed."
        ) from e


# ---------------------------------------------------------------------------
# Schema validation — Pydantic v2
# ---------------------------------------------------------------------------
MAX_VALIDATION_FAILURE_PCT = 5.0  # fail loud if >5% of rows fail


def validate_fraud_response(data: dict, batch_id: str, version: str = VERSION_TAG) -> tuple[bool, list[str], Optional[GeminiFraudResponse]]:
    """
    Validate with Pydantic v2.
    Returns (ok, errors, parsed_model).
    If >5% of per_row_verdicts fail, writes failure dump and raises.
    """
    errors: list[str] = []

    # Top-level structure
    if not isinstance(data, dict):
        return False, ["Response is not a dict"], None

    pvs_raw = data.get("per_row_verdicts", [])
    if not isinstance(pvs_raw, list):
        errors.append("per_row_verdicts must be a list")
        return False, errors, None

    # Per-row Pydantic validation
    row_errors: list[tuple[int, list]] = []
    for i, row in enumerate(pvs_raw):
        try:
            GeminiRowVerdict.model_validate(row)
        except ValidationError as ve:
            row_errors.append((i, ve.errors()))

    if pvs_raw and row_errors:
        pct = len(row_errors) / len(pvs_raw) * 100
        if pct > MAX_VALIDATION_FAILURE_PCT:
            dump_path = Path(f"/tmp/v16.1-validation-failure-{batch_id}.json")
            dump_path.write_text(
                json.dumps(
                    {"batch_id": batch_id, "row_errors": [
                        {"index": i, "errors": errs} for i, errs in row_errors
                    ], "raw_response": data},
                    ensure_ascii=False, indent=2,
                ),
                encoding="utf-8",
            )
            raise RuntimeError(
                f"[SCHEMA VALIDATION FAILED] {len(row_errors)}/{len(pvs_raw)} rows "
                f"({pct:.1f}%) failed Pydantic validation — exceeds {MAX_VALIDATION_FAILURE_PCT}% threshold. "
                f"Raw response dumped to {dump_path}. NOT retrying without fix."
            )
        else:
            for i, errs in row_errors:
                sl = pvs_raw[i].get("sl_no", f"idx_{i}")
                errors.append(f"Row sl_no={sl}: {errs}")

    # top_5_cases
    top5_raw = data.get("top_5_cases", [])
    if not isinstance(top5_raw, list):
        errors.append("top_5_cases must be a list")
    else:
        for i, case in enumerate(top5_raw):
            try:
                TopCase.model_validate(case)
            except ValidationError as ve:
                errors.append(f"top_5_cases[{i}]: {ve.errors()}")

    # batch_summary
    bs_raw = data.get("batch_summary")
    if not isinstance(bs_raw, dict):
        errors.append("batch_summary must be a dict")
    else:
        try:
            BatchSummary.model_validate(bs_raw)
        except ValidationError as ve:
            errors.append(f"batch_summary: {ve.errors()}")

    # Try full model parse
    parsed = None
    if not errors:
        try:
            parsed = GeminiFraudResponse.model_validate(data)
        except ValidationError as ve:
            errors += [str(e) for e in ve.errors()]

    return len(errors) == 0, errors, parsed


