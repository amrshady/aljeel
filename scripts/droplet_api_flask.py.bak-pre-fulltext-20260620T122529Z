    log_path = _find_run_log_path(run_id)
    if log_path is None:
        return jsonify({"error": "run_id not found"}), 404
    return Response(_stream_run_log(run_id, log_path), mimetype='text/event-stream', headers=_sse_headers())

@app.route('/evidence/tree', methods=['GET'])
def evidence_tree():
    batch_id = request.args.get('batch_id', '').strip()
    batch_dir = _evidence_raw_dir(batch_id)
    if not batch_dir.exists():
        return jsonify({"error": "batch not found"}), 404

    folders = []
    for dirpath, dirnames, filenames in os.walk(batch_dir):
        path = Path(dirpath)
        rel_folder = "" if path == batch_dir else path.relative_to(batch_dir).as_posix()
        files = []
        for filename in sorted(filenames, key=str.lower):
            file_path = path / filename
            rel_file = file_path.relative_to(batch_dir).as_posix()
            files.append({
                "name": filename,
                "ext": file_path.suffix.lower().lstrip("."),
                "size": file_path.stat().st_size,
                "rel": rel_file,
            })
        if not files and dirnames:
            continue
        folders.append({"folder": rel_folder, "files": files})

    folders.sort(key=lambda item: item["folder"].lower())
    return jsonify({"batch_id": batch_id, "raw_dir": str(batch_dir), "folders": folders})

@app.route('/evidence/file', methods=['GET'])
def evidence_file():
    batch_id = request.args.get('batch_id', '').strip()
    rel = request.args.get('rel', '').strip()
    _raw_dir, file_path = _resolve_evidence_path(batch_id, rel)
    if file_path is None:
        return jsonify({"error": "invalid path"}), 400
    if not file_path.exists() or not file_path.is_file():
        return jsonify({"error": "file not found"}), 404

    ext = file_path.suffix.lower()
    if ext == ".msg":
        return jsonify(_parse_msg_payload(file_path))
    if ext == ".eml":
        return jsonify(_parse_eml_payload(file_path))

    mimetype = mimetypes.guess_type(str(file_path))[0] or "application/octet-stream"
    return send_file(file_path, mimetype=mimetype, as_attachment=False)

@app.route('/evidence/msg-attachment', methods=['GET'])
def evidence_msg_attachment():
    batch_id = request.args.get('batch_id', '').strip()
    rel = request.args.get('rel', '').strip()
    try:
        attachment_index = int(request.args.get('attachment', '0'))
    except ValueError:
        return jsonify({"error": "invalid attachment index"}), 400

    _raw_dir, file_path = _resolve_evidence_path(batch_id, rel)
    if file_path is None:
        return jsonify({"error": "invalid path"}), 400
    if not file_path.exists() or not file_path.is_file():
        return jsonify({"error": "file not found"}), 404
    if file_path.suffix.lower() != ".msg":
        return jsonify({"error": "not a msg file"}), 400

    attachment = _msg_attachment(file_path, attachment_index)
    if attachment is None:
        return jsonify({"error": "attachment not found"}), 404

    name, data = attachment
    mimetype = mimetypes.guess_type(name)[0] or "application/octet-stream"
    return send_file(
        BytesIO(data),
        mimetype=mimetype,
        as_attachment=False,
        download_name=name,
    )

@app.route('/upload', methods=['POST'])
def upload_file():
    """Receive an uploaded file from the portal and save it to a temp upload dir.
    Returns {"path": "<absolute path on droplet>"} for portal display/comparison use.
    Files are scoped to a per-upload UUID so concurrent uploads never collide.
    """
    if 'file' not in request.files:
        return jsonify({"error": "No file part in request"}), 400
    f = request.files['file']
    if not f.filename:
        return jsonify({"error": "Empty filename"}), 400
    safe_name = secure_filename(f.filename)
    if not safe_name:
        return jsonify({"error": "Invalid filename"}), 400
    if Path(safe_name).suffix.lower() not in (".xlsx", ".xls"):
        return jsonify({"error": "Only Excel files accepted"}), 400
    upload_id = uuid.uuid4().hex[:12]
    dest_dir = UPLOADS_DIR / upload_id
    dest_dir.mkdir(parents=True, exist_ok=True)
    dest_path = dest_dir / safe_name
    f.save(str(dest_path))
    print(f"[upload] Saved {safe_name} -> {dest_path}", flush=True)
    return jsonify({"path": str(dest_path), "filename": safe_name})

@app.route('/process', methods=['GET'])
def process_batch():
    batch_id = request.args.get('batch_id', 'J26-550')
    no_cache = request.args.get('no_cache', 'false').lower() in ('1', 'true', 'yes', 'on')
    invoice_path = request.args.get('invoice_path')

    _maybe_clear_stale_lock()

    run_id = uuid.uuid4().hex[:8]
    try:
        lock_fd = os.open(RUN_LOCK, os.O_CREAT | os.O_EXCL | os.O_WRONLY)
    except FileExistsError:
        return Response(
            iter([
                "data: [API] ERROR: A pipeline run is already in progress. Please wait for it to finish.\n\n",
                "data: [END]\n\n",
            ]),
            mimetype='text/event-stream',
            headers=_sse_headers(),
        )

    started_at = datetime.now(timezone.utc).isoformat()
    try:
        os.write(lock_fd, f"{run_id}\n".encode("utf-8"))
        RUN_LOCK_TS.write_text(json.dumps({"since": started_at, "run_id": run_id}), encoding="utf-8")

        PIPELINE_LOGS_DIR.mkdir(parents=True, exist_ok=True)
        log_path = PIPELINE_LOGS_DIR / f"{started_at.replace(':', '').replace('+', 'Z')}-{run_id}.log"
        log_path.touch()

        worker = threading.Thread(
            target=_run_pipeline_worker,
            args=(batch_id, no_cache, invoice_path, log_path, lock_fd),
            daemon=True,
        )
        worker.start()
    except Exception:
        _release_run_lock(lock_fd)
        raise

    return Response(_stream_run_log(run_id, log_path), mimetype='text/event-stream', headers=_sse_headers())

@app.route('/qa-run', methods=['POST'])
def qa_run():
    body = request.get_json(silent=True) or {}
    batch_id = request.args.get('batch_id') or body.get('batch_id', '')
    if not batch_id:
        return jsonify({"error": "batch_id required"}), 400

    run_id = uuid.uuid4().hex[:8]
    started_at = datetime.now(timezone.utc).isoformat()
    PIPELINE_LOGS_DIR.mkdir(parents=True, exist_ok=True)
    log_path = PIPELINE_LOGS_DIR / f"qa-{started_at.replace(':', '').replace('+', 'Z')}-{run_id}.log"
    log_path.touch()

    def _stream():
        ended = False
        with log_path.open('a', encoding='utf-8', buffering=1) as log_handle:
            if RUN_LOCK.exists():
                warning = "[API] WARNING: A pipeline run appears active; QA is read-only and will continue."
                _write_pipeline_log(log_handle, warning)
                yield f"data: {warning}\n\n"

            proc = subprocess.Popen(
                [sys.executable, str(ROOT / 'scripts' / 'qa_agent.py'), '--batch-id', batch_id],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                cwd=str(ROOT),
                bufsize=1,
            )
            for line in iter(proc.stdout.readline, ''):
                stripped = line.strip()
                if not stripped:
                    continue
                _write_pipeline_log(log_handle, stripped)
                yield f"data: {stripped}\n\n"
                if stripped.startswith("Saved raw JSON: "):
                    report_path = stripped.split("Saved raw JSON: ", 1)[1].strip()
                    yield f"data: [QA_REPORT_PATH] {report_path}\n\n"
                if stripped == "[END]":
                    ended = True
            proc.wait()
            if not ended:
                _write_pipeline_log(log_handle, "[END]")
                yield "data: [END]\n\n"

    return Response(_stream(), mimetype='text/event-stream', headers=_sse_headers())

def _json_report_to_md(report: dict, report_path: Path) -> str:
    stem = report_path.stem
    if stem.startswith("qa-report-"):
        stem_stripped = stem[len("qa-report-"):]
    else:
        stem_stripped = stem
    parts = stem_stripped.rsplit("-", 1)
    batch_label = parts[0] if len(parts) == 2 else stem_stripped
    timestamp_raw = parts[1] if len(parts) == 2 else ""

    lines = []
    lines.append(f"# QA Report — {batch_label}")
    lines.append(f"**Generated:** {timestamp_raw}  ")
    lines.append(f"**Model:** {report.get('model_used', 'gemini-3.1-pro-preview')}  ")
    lines.append("")
    lines.append("---")
    lines.append("")
    lines.append("## Summary")
    lines.append("")
    lines.append(report.get("summary", ""))
    lines.append("")
    lines.append(f"**Total issues found:** {report.get('total_issues_found', len(report.get('issues', [])))}")
    lines.append("")
    lines.append("---")
    lines.append("")
    lines.append("## Issues")
    lines.append("")

    severity_icons = {"HIGH": "🔴", "MEDIUM": "🟡", "LOW": "🟢", "INFO": "ℹ️"}

    for i, issue in enumerate(report.get("issues", []), 1):
        sev = issue.get("severity", "INFO")
        icon = severity_icons.get(sev, "•")
        lines.append(f"### {icon} Issue {i} — {issue.get('title', '')} ({sev})")
        lines.append(f"**Category:** {issue.get('category', '')}  ")
        rows = issue.get("rows_affected", [])
        if rows:
            lines.append(f"**Rows affected:** {rows}  ")
        lines.append("")
        lines.append(issue.get("detail", ""))
        lines.append("")
        action = issue.get("recommended_action", "")
        if action:
            lines.append(f"**Recommended action:** {action}")
        lines.append("")
        lines.append("---")
        lines.append("")

    cross = report.get("cross_row_patterns", [])
    if cross:
        lines.append("## Cross-Row Patterns")
        lines.append("")
        for p in cross:
            if isinstance(p, dict):
                desc = p.get("description", str(p))
                rows = p.get("rows_affected", [])
                lines.append(f"- **{p.get('pattern_type','')}**: {desc}" + (f" (rows: {rows})" if rows else ""))
            else:
                lines.append(f"- {p}")
        lines.append("")
        lines.append("---")
        lines.append("")

    clean = report.get("clean_notes", []) or report.get("clean_signal", "")
    if clean:
        lines.append("## ✅ Clean / Confirmed OK")
        lines.append("")
        if isinstance(clean, list):
            for n in clean:
                lines.append(f"- {n}")
        else:
            lines.append(f"- {clean}")
        lines.append("")

    return "\n".join(lines)

@app.route('/qa-report-download', methods=['GET'])
def qa_report_download():
    raw_path = request.args.get('path', '')
    if not raw_path:
        return jsonify({"error": "path required"}), 400

    requested_path = Path(raw_path)
    if requested_path.suffix != '.json':
        return jsonify({"error": "must be .json"}), 400

    allowed_prefix = (ROOT / "batches").resolve()
    p = requested_path.resolve(strict=False)
    try:
        p.relative_to(allowed_prefix)
    except ValueError:
        return jsonify({"error": "forbidden path"}), 400

    if not p.is_file():
        return jsonify({"error": "not found"}), 404

    try:
        report = json.loads(p.read_text(encoding='utf-8'))
    except Exception as e:
        return jsonify({"error": str(e)}), 500

    md_content = _json_report_to_md(report, p)
    md_filename = p.stem + ".md"
    return Response(
        md_content,
        mimetype='text/markdown',
        headers={"Content-Disposition": f'attachment; filename="{md_filename}"'}
    )

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, threaded=True)
