    return jsonify(status)

@app.route('/api/last-run', methods=['GET'])
@app.route('/last-run', methods=['GET'])
def last_run():
    result = {"run_id": None, "batch_id": None, "succeeded": False, "failed": False, "ended": False}
    try:
        logs = list(PIPELINE_LOGS_DIR.glob("*-*.log"))
        if not logs:
            return jsonify(result)
        log_path = max(logs, key=lambda path: path.stat().st_mtime)
    except Exception:
        return jsonify(result)

    try:
        match = re.search(r"-([a-f0-9]{8})\.log$", log_path.name)
        if match:
            result["run_id"] = match.group(1)
    except Exception:
        pass

    try:
        content = log_path.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return jsonify(result)

    try:
        lines = content.splitlines()
        search_lines = lines[:5]
        if lines:
            match = re.search(r"for\s+([A-Z0-9-]+)\.\.\.", lines[0])
            if match:
                result["batch_id"] = match.group(1)
        if not result["batch_id"]:
            for line in search_lines:
                match = re.search(r"\bBATCH:\s*([A-Z0-9-]+)\b", line)
                if not match:
                    match = re.search(r"\bfor\s+(J26-[A-Z0-9-]+)", line)
                if match:
                    result["batch_id"] = match.group(1)
                    break
    except Exception:
        pass

    try:
        result["succeeded"] = "[PIPELINE_SUCCESS]" in content
        result["failed"] = "[PIPELINE_FAILED]" in content
        result["ended"] = result["succeeded"] or result["failed"]
    except Exception:
        pass

    return jsonify(result)

@app.route('/clear-lock', methods=['POST'])
@app.route('/api/clear-lock', methods=['POST'])
def clear_lock():
    """Emergency lock clear - safe because pipeline activity is checked first."""
    status = _read_lock_status()
    if not status["locked"]:
        return jsonify({"cleared": False, "reason": "not locked"})

    run_id = status.get("run_id")
    log_age = _run_log_age_seconds(run_id)
    if log_age is not None and log_age < 30:
        return jsonify({"cleared": False, "reason": "pipeline appears active (log modified <30s ago)"})

    _clear_run_lock_files()
    return jsonify({"cleared": True})

