@app.route('/files/<batch_id>', methods=['GET'])
@app.route('/api/files/<batch_id>', methods=['GET'])
def batch_files(batch_id):
    """Report which output spreadsheets exist for a batch (full / split)."""
    batch_id = batch_id.strip().upper()
    if not re.match(r"^J26-\d+$", batch_id):
        return jsonify({"error": "invalid batch id"}), 400
    out_dir = ROOT / "batches" / f"jawal-{batch_id}" / "output"
    pub_dir = ROOT / "dashboard" / "public" / "outputs"
    files = {}
    for key, name in (
        ("full", f"Spreadsheet-{batch_id}-FILLED-v30.xlsx"),
        ("split", f"Spreadsheet-{batch_id}-FILLED-v30-SPLIT.xlsx"),
    ):
        files[key] = {
            "name": name,
            "exists": (out_dir / name).exists() or (pub_dir / name).exists(),
        }
    return jsonify({"batch_id": batch_id, "files": files})

@app.route('/download/<batch_id>/<kind>', methods=['GET'])
@app.route('/api/download/<batch_id>/<kind>', methods=['GET'])
def download_output(batch_id, kind):
    """Serve the pipeline output spreadsheet straight from the batch dir on disk,
    so downloads never depend on a Cloudflare Pages deploy having completed."""
    batch_id = batch_id.strip().upper()
    if not re.match(r"^[A-Z0-9-]+$", batch_id):
        return jsonify({"error": "invalid batch id"}), 400
    if kind == "full":
        name = f"Spreadsheet-{batch_id}-FILLED-v30.xlsx"
    elif kind == "split":
        name = f"Spreadsheet-{batch_id}-FILLED-v30-SPLIT.xlsx"
    else:
        return jsonify({"error": "invalid kind, expected 'full' or 'split'"}), 400
    file_path = ROOT / "batches" / f"jawal-{batch_id}" / "output" / name
    if not file_path.is_file():
        return jsonify({"error": "file not found"}), 404
    return send_file(file_path, as_attachment=True, download_name=name)

@app.route('/batches', methods=['GET'])
@app.route('/api/batches', methods=['GET'])
def batches():
    batches_dir = ROOT / "batches"
    batch_candidates = {}
    deadline = time.monotonic() + 5

    def remember_batch(batch_id, evidence_dir, source):
        if source != "volume" and batch_id in batch_candidates:
            return
        batch_candidates[batch_id] = {
            "evidence_dir": evidence_dir,
            "source": source,
        }

    try:
        volume_entries = list(os.scandir(VOLUME_BASE))
    except FileNotFoundError:
        volume_entries = []

    for entry in volume_entries:
        if not entry.is_dir(follow_symlinks=False):
            continue
        match = re.match(r"^J26-\d+$", entry.name, re.IGNORECASE)
        if not match:
            continue

        batch_id = entry.name.upper()
        evidence_dir = _resolve_volume_evidence_root(batch_id)
        if evidence_dir is None:
            continue
        remember_batch(batch_id, evidence_dir, "volume")

    try:
        batch_entries = list(os.scandir(batches_dir))
    except FileNotFoundError:
        batch_entries = []

    for entry in batch_entries:
        if not entry.is_dir(follow_symlinks=False):
            continue
        match = re.match(r"^jawal-(J26-\d+)$", entry.name, re.IGNORECASE)
        if not match:
            continue

        batch_id = match.group(1).upper()
        if batch_id in batch_candidates:
            continue
        candidates = sorted(_batch_evidence_candidates(batch_id), key=_evidence_candidate_sort_key)
        if candidates:
            remember_batch(batch_id, candidates[0][3], "batches")

    results = []
    for batch_id, candidate in batch_candidates.items():
        evidence_dir = candidate["evidence_dir"]

        size_bytes = 0
        item_count = 0
        if time.monotonic() <= deadline:
            try:
                size_bytes, item_count = _scan_size_and_count(evidence_dir, deadline)
            except TimeoutError:
                size_bytes = 0
                item_count = 0

        try:
            modified_ts = evidence_dir.stat().st_mtime
        except OSError:
            modified_ts = 0

        results.append({
            "id": batch_id,
            "size_bytes": size_bytes,
            "size_label": _format_batch_size(size_bytes),
            "item_count": item_count,
            "modified": datetime.fromtimestamp(modified_ts).strftime("%d %b %Y") if modified_ts else "",
            "evidence_path": _relative_to_root(evidence_dir),
            "source": candidate["source"],
        })

    results.sort(key=lambda item: (_batch_sort_key(item["id"]), item["id"]), reverse=True)
    return jsonify({"batches": results})

@app.route('/preflight-scan', methods=['GET'])
@app.route('/api/preflight-scan', methods=['GET'])
def preflight_scan():
    batch_id = request.args.get('batch_id', '').strip()
    raw_dir = request.args.get('raw_dir', '').strip() or None
    if not batch_id:
        return jsonify({"error": "batch_id required"}), 400

    try:
        from preflight_scan import run_scan
        return jsonify(run_scan(batch_id, raw_dir=raw_dir, emit_lines=False))
    except Exception as exc:
        return jsonify({"error": str(exc), "batch_id": _normalize_batch_id(batch_id)}), 500

