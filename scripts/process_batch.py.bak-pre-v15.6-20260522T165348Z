# ---------------------------------------------------------------------------
# Column indices in the Oracle template (0-based, header at row 2)
# ---------------------------------------------------------------------------
COL_HEADER_ID   = 0   # A
COL_BU          = 1   # B
COL_INV_NO      = 2   # C
COL_CURRENCY    = 3   # D
COL_AMOUNT_HDR  = 4   # E
