def _stamp_21070229_home_segments(row: dict, rec: dict | None) -> None:
    """Stamp account 21070229 rows with the owner's home segments.

    Annual-ticket policy keeps Solution general, but CC/DIV/Agency follow the
    verified owner employee's home allocation.
    """
    if rec:
        cc = rec.get("cost_center", "")
        if cc:
            row["cost_center"] = _norm_master_code(cc, "cc")
        div = rec.get("div_code", "")
        if div:
            row["div"] = _norm_master_code(div, "div")
        agency = rec.get("agency_code", "")
        if agency:
            row["agency"] = _norm_master_code(agency, "agency")
    row["solution"] = ANNUAL_TICKET_SOLUTION

# ─── OPEX serial extraction from folder names (shortcut-row fix) ─────────────
# Sponsorship rows resolved via the v16_sponsorship_master shortcut skip the
# full LLM evidence call, so opex_serial is never extracted for them — yet the
# shared OPEX folder name often contains it directly (e.g. "OPEX Avier
# Combined training CRM-2026-30"). Number order differs by department
# (CRM-2026-30 is YEAR-SEQ, CE-18-2026 is SEQ-YEAR), so the serial is kept
# EXACTLY as written in the source — no reordering.
_SERIAL_PAT = re.compile(
    r"\b(CE|CRM|HF|EP|AATS)-\d+-\d+\b",
    re.IGNORECASE,
)

def _extract_serial_from_text(text: str) -> str:
    """Extract an OPEX serial exactly as it appears in the text. No normalisation."""
    if not text:
        return ""
    m = _SERIAL_PAT.search(text)
    if m:
        return m.group(0).upper()
    return ""

# ─── FIX A-part-2: ticket-first lookup (prevents bad surname match) ──────────

def find_folder_v25(
    ticket_no: str,
    passenger: str,
    notes: str,
    all_folders: list[Path],
    reverse_index: dict[str, Path],
) -> Path | None:
    """
    v25 override of find_folder_with_index.

    KEY CHANGE: check the reverse_index for the exact ticket number BEFORE
    calling find_ticket_folder's surname-based matching.  The reverse index
    now contains adjacent-ticket entries for family/PC folders, so ticket
    6904732430 resolves to '6904732429 family' — not to an unrelated folder
    found by surname ('HUSSEIN' -> 6904687314, 'SALEM' -> train ticket 2).

    Exact/substring/range folder discovery runs first (deterministic, zero false
    positives).  Then reverse_index ticket match.  Surname fallback is last.
    """
    # Step 1: exact / substring / range — identical to fea.find_ticket_folder steps 1-2
    for f in all_folders:
        if f.name.strip() == ticket_no:
            return f
    for f in all_folders:
        fname = f.name.strip()
        m = re.match(r"^(\d{10,})", fname)
        if m and m.group(1).startswith(ticket_no):
            return f
        m2 = re.match(r"^(\d{10})-(\d{1,3})", fname)
        if m2:
            base, end = m2.group(1), m2.group(2)
            if ticket_no == base:
                return f
            if len(end) < 10:
                candidate = base[:10 - len(end)] + end
                if ticket_no == candidate:
                    return f
        if ticket_no in fname:
            return f

    # Step 2: reverse_index exact ticket match (includes adjacent-ticket entries)
    if ticket_no in reverse_index:
        return reverse_index[ticket_no]

    # Step 3: 26-NNN in notes
    for m in re.finditer(r"\b(26-\d{3})\b", notes or ""):
        if m.group(1) in reverse_index:
            return reverse_index[m.group(1)]

    # GLOBAL CACHE FOR FILE TEXT TO PREVENT O(N*M) HANG
    if not hasattr(find_folder_v25, "_file_text_cache"):
        find_folder_v25._file_text_cache = {}
        find_folder_v25._scanned = False

    # Step 4: Strict Scanner with Cache
    if ticket_no:
        if not find_folder_v25._scanned:
            import pypdf
            for f in all_folders:
                if not f.is_dir(): continue
                for child in f.iterdir():
                    cn = child.name.upper()
                    if cn.endswith(".PDF"):
                        try:
                            reader = pypdf.PdfReader(str(child))
                            full_text = []
                            for i in range(min(2, len(reader.pages))):
                                extracted = reader.pages[i].extract_text()
                                if extracted:
                                    full_text.append(extracted)
                            find_folder_v25._file_text_cache[child] = (" ".join(full_text), f)
                        except Exception: pass
                    elif cn.endswith(".MSG"):
                        try:
                            with open(child, "rb") as msg_f:
                                txt = msg_f.read().decode("utf-8", errors="ignore")
                                find_folder_v25._file_text_cache[child] = (txt, f)
                        except Exception: pass
            find_folder_v25._scanned = True
            
        for path, (text, f) in find_folder_v25._file_text_cache.items():
            if ticket_no in text:
                return f

    return None


def _folder_name_owns_ticket(folder: Path | None, ticket_no: str) -> bool:
    """True when a folder name itself is deterministic evidence for this ticket."""
    if not folder or not ticket_no:
        return False
    fname = folder.name.strip()
    if fname == ticket_no or ticket_no in fname:
        return True
    m = re.match(r"^(\d{10})-(\d{1,3})", fname)
    if m:
        base, end = m.group(1), m.group(2)
        if ticket_no == base:
            return True
        if len(end) < 10 and ticket_no == base[:10 - len(end)] + end:
            return True
    return False


def _own_ticket_folder(ticket_no: str, all_folders: list[Path]) -> Path | None:
    """Return only a dedicated/range ticket folder, never a shared content match."""
    if not ticket_no:
        return None
    for folder in all_folders:
        if _folder_name_owns_ticket(folder, ticket_no):
            return folder
    return None


def _parse_own_approved_form(folder: Path | None) -> tuple[dict | None, str, str]:
    if not folder or not folder.exists():
        return None, "", ""
    try:
        from msg_parser import parse_msg
        from oracle_form_parser import parse_form
    except Exception:
        return None, "", ""

    for msg in sorted(folder.glob("*.msg")):
        parsed = parse_msg(msg, use_cache=True)
        if parsed.get("parse_method") == "failed":
            continue
        subject = parsed.get("subject", "") or ""
        body = parsed.get("body_text", "") or ""
        form = parse_form(body)
        if not form:
            continue
        approval_text = f"{subject}\n{body}".lower()
        if "approved" in approval_text or form.get("approver_name") or form.get("approver"):
            return form, subject, body
    return None, "", ""


def _stamp_home_segments_for_account(row: dict, account: str, rec: dict | None) -> None:
    if account == "21070229":
        _stamp_21070229_home_segments(row, rec)
        return
    if not rec:
        return
    row["cost_center"] = _norm_master_code(rec.get("cost_center", ""), "cc")
    row["div"] = _norm_master_code(rec.get("div_code", ""), "div")
    if account in TRAVEL_TICKET_ACCOUNTS:
        row["solution"] = str(row.get("solution", "") or "").strip() or "00000"
    else:
        row["solution"] = _norm_master_code(rec.get("solution", ""), "solution")
    row["agency"] = _norm_master_code(rec.get("agency_code", ""), "agency")


def apply_own_form_trip_purpose_precedence(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    manpower: dict,
    all_folders: list[Path],
) -> int:
    """Rows with their own approved form keep that form's trip-purpose account."""
    try:
        from trip_purpose_classifier import classify_trip
    except Exception:
        return 0

    applied = 0
    for i, c in enumerate(cascade_rows):
        h = hybrid_rows[i]
        if row_missing_evidence(h) or row_family_annual_locked(h):
            continue
        desc = str(c.get("Description", "") or "")
        notes = str(c.get("Notes", "") or "")
        text = f"{desc} {notes}"
        m = re.search(r"\b(\d{10,})\b", text)
        ticket_no = m.group(1) if m else ""
        if not ticket_no:
            continue
        folder = _own_ticket_folder(ticket_no, all_folders)
        form, subject, body = _parse_own_approved_form(folder)
        if not form:
            continue
        passenger = desc.split(" - ", 1)[0].strip() if " - " in desc else desc.strip()
        trip_cls = classify_trip(
            subject=subject,
            body=body,
            form_data=form,
            description=desc,
            passenger_name=passenger,
        )
        override = str(trip_cls.account_override or "").strip()
        form_emp = str(form.get("emp_no") or "").strip()
        rec = manpower.get(form_emp) if form_emp else None
        if not override and trip_cls.trip_purpose == "BUSINESS_TRIP" and rec:
            cc = _norm_master_code(rec.get("cost_center", ""), "cc")
            override = CC_ACCOUNT_OVERRIDE.get(cc, "60301003")
        if not override or trip_cls.confidence < 0.7:
            continue

        old_account = str(h.get("account", "") or "").strip()
        if form_emp and rec:
            h["emp_no"] = form_emp
        h["account"] = override
        _stamp_home_segments_for_account(h, override, rec)
        h["_agent_method"] = "own_form_trip_purpose"
        h["_route_reason"] = "OWN_APPROVED_FORM_TRIP_PURPOSE"
        h["_own_form_trip_purpose"] = {
            "purpose": trip_cls.trip_purpose,
            "confidence": trip_cls.confidence,
            "signals": ", ".join(trip_cls.signals_used),
            "trace": trip_cls.trace,
            "account_override": override,
            "folder": str(folder) if folder else "",
        }
        h["_flags"] = (
            str(h.get("_flags", "") or "") + " OWN_FORM_TRIP_PURPOSE_PRECEDENCE"
        ).strip()

        c["Trip Purpose"] = trip_cls.trip_purpose
        c["Trip Purpose Confidence"] = trip_cls.confidence
        c["Trip Signals"] = ", ".join(trip_cls.signals_used)
        c["Trip Account Override"] = override
        c["Agent Account Rule"] = (
            f"own_form_trip_classifier_{trip_cls.trip_purpose}: "
            f"{trip_cls.trace[:120]}"
        )
        applied += 1
        print(
            f"  [own-form-trip] row {i+1}: account {old_account or '?'} -> {override} "
            f"({trip_cls.trip_purpose}, own folder {folder.name if folder else '?'})",
            flush=True,
        )
    print(f"[own-form-trip] {applied} row(s) reasserted from own approved form", flush=True)
    return applied


def stamp_own_form_trip_columns(out_xlsx: Path, hybrid_rows: list[dict], hdr_row: int) -> int:
    wb = openpyxl.load_workbook(out_xlsx)
    ws = wb.active
    cols = {
        str(ws.cell(hdr_row, ci).value or "").strip(): ci
        for ci in range(1, ws.max_column + 1)
        if str(ws.cell(hdr_row, ci).value or "").strip()
    }
    written = 0
    for row in hybrid_rows:
        trip = row.get("_own_form_trip_purpose")
        if not trip:
            continue
        excel_row = row["_row_idx"]
        values = {
            "Trip Purpose": trip.get("purpose", ""),
            "Trip Purpose Confidence": trip.get("confidence", ""),
            "Trip Signals": trip.get("signals", ""),
            "Trip Account Override": trip.get("account_override", ""),
            "Agent Account Rule": (
                f"own_form_trip_classifier_{trip.get('purpose', '')}: "
                f"{str(trip.get('trace', ''))[:120]}"
            ),
        }
        for hdr, val in values.items():
            if hdr in cols:
                ws.cell(excel_row, cols[hdr]).value = val
        written += 1
    if written:
        wb.save(str(out_xlsx))
    wb.close()
    print(f"[own-form-trip] {written} row(s) stamped Trip Purpose columns", flush=True)
    return written


# ─── FIX A: adjacent-ticket reverse index expansion ──────────────────────────

def build_reverse_folder_index_v25(
    all_folders: list[Path],
    adj_radius: int = 5,
) -> dict[str, Path]:
    """
    Build the standard reverse folder index, then expand it with adjacent-ticket
    entries for:
      (a) Folders named  "<10-digit> family[...]"  (explicit family booking folder)
      (b) Folders that contain a Personal Contribution approval .msg file

    Adjacent tickets ±1..adj_radius are added with setdefault so that dedicated
    single-ticket folders (exact name match, already indexed first) take priority.
    """
    # Build the standard index
    index = build_reverse_folder_index(all_folders)

    # Expand for family/PC folders
    expanded = 0
    for folder in all_folders:
        if not folder.exists():
            continue
        fname = folder.name.strip()
        m_base = _TICKET_10_RE_V25.match(fname)
        if not m_base:
            continue   # folder not named by a ticket number

        base_ticket = int(m_base.group(1))
        # v30 conservative: only expand for folders EXPLICITLY named "family"
        # (e.g. "6904732429 family").  PC-email alone is NOT sufficient — individual
        # employee tickets also have PC emails, and adjacent-ticket expansion based
        # on them causes false-positive folder corrections for unrelated rows.
        is_family_folder = "family" in fname.lower()

        if not is_family_folder:
            continue

        for delta in range(-adj_radius, adj_radius + 1):
            if delta == 0:
                continue
            adj_ticket = str(base_ticket + delta)
            if adj_ticket not in index:           # don't override dedicated folders
                index[adj_ticket] = folder
                expanded += 1

    if expanded:
        print(
            f"[v30-fix-a] {expanded} adjacent-ticket entries added "
            f"(family/PC folder expansion ±{adj_radius})",
            flush=True,
        )
    return index


# ─── FIX B: inject PC-email emp_no hint into classify context ─────────────────

def _build_pc_hint(pc_rec: dict | None) -> str:
    """
    Build a LLM routing context block from a PC index record.
    pc_rec = {"emp_no": "1002466", "name": "Mahmoud Elkilany Hussein", "filename": "..."}
    """
    if not pc_rec:
        return ""
    emp_no = pc_rec.get("emp_no", "").strip()
    name   = pc_rec.get("name", "").strip()
    fname  = pc_rec.get("filename", "").strip()
    if not emp_no:
        return ""
    lines = [
        "\n[ROUTING CONTEXT v30 — PERSONAL CONTRIBUTION EMAIL DETECTED]",
        f"The evidence folder contains a Personal Contribution approval .msg file.",
        f"• Responsible employee (from filename): {name} ({emp_no})",
        f"• Set account=21070229 (Personal Contribution).",
        f"• Use employee {emp_no}'s GL allocation (CC, DIV, Agency) from master data.",
        f"• If the passenger IS {name}, set emp_no={emp_no}.",
        # Labadi RULE 1 (2026-06-09): emp_no is ALWAYS populated. Family
        # members / dependents carry the responsible employee's emp_no — never blank.
        f"• If the passenger is a FAMILY MEMBER / DEPENDENT of {name}, set emp_no={emp_no} (the responsible employee).",
        f"  (Children CHD/INF and spouses traveling on a family PC booking are billed under employee {emp_no}.)",
        f"• Filename for reference: {fname}",
    ]
    return "\n".join(lines) + "\n"



_OPEX_EMP_NO_RE = re.compile(r"Employee No Name Amount\n(\d{5,7})", re.IGNORECASE)
_OPEX_EMP_NO_RE2 = re.compile(r"Employee No:\s*(\d{5,7})", re.IGNORECASE)

def _extract_opex_emp_no(folder_path):
    if not folder_path or not folder_path.exists():
        return ""
    from pypdf import PdfReader
    for pdf_path in folder_path.rglob("*.pdf"):
        try:
            reader = PdfReader(pdf_path)
            text = ""
            for p in reader.pages:
                text += p.extract_text() + "\n"
            m = _OPEX_EMP_NO_RE.search(text)
            if m:
                return m.group(1).strip()
            m2 = _OPEX_EMP_NO_RE2.search(text)
            if m2:
                return m2.group(1).strip()
        except:
            pass
    return ""


def _extract_salesmen_from_opex_pdf(pdf_path, employee_directory=None):
    """Use Gemini to read the SALESMAN / AMOUNT TO ALLOCATE table in an OPEX PDF.

    A bare 1\\d{6} pattern scan false-positives on invoice numbers, amounts and
    page refs, so the table is read by the LLM instead. Returns a list of
    7-digit emp_no strings; [] on failure or when no salesman table is found.
    """
    try:
        import fitz  # pymupdf — primary in this pipeline (see full_evidence_agent)
        doc = fitz.open(str(pdf_path))
        pdf_text = "\n".join(page.get_text() for page in doc)
        doc.close()
    except Exception as e:
        print(f"[salesman-extract] PDF read failed for {pdf_path.name}: {e}", flush=True)
        return []

    if not pdf_text.strip():
        return []

    emp_dir_hint = ""
    if employee_directory:
        emp_dir_hint = f"\n\nKnown AlJeel employees (subset):\n{employee_directory}"

    prompt = f"""You are reading an AlJeel Medical OPEX approval form.
Your task: extract the AlJeel employee number(s) from the SALESMAN / AMOUNT TO ALLOCATE table.

Rules:
- Only return employee numbers from the salesman allocation table (NOT client names, NOT approvers)
- AlJeel employee numbers are 7 digits starting with 1 (e.g. 1000477, 1002037)
- If multiple salesmen share the allocation, return all of them
- Return ONLY a JSON object, no explanation: {{"salesmen": ["1000477", "1002037"]}}
- If no salesman table found or no valid employee numbers, return: {{"salesmen": []}}
{emp_dir_hint}

OPEX FORM TEXT:
{pdf_text[:4000]}
"""

    models = ("gemini-2.5-flash", "gemini-2.5-pro", "gemini-pro-latest")
    for idx, model_name in enumerate(models):
        res = fea.call_gemini(prompt, model_name)
        if res.get("error") or not isinstance(res.get("json"), dict):
            print(f"[salesman-extract] {model_name} failed: {res.get('error', 'bad response')}", flush=True)
            if res.get("unavailable") and idx < len(models) - 1:
                print(f"[salesman-extract] {model_name} returned 503 — waiting 15s before trying next model...", flush=True)
                time.sleep(15)
            continue
        candidates = res["json"].get("salesmen", [])
        if not isinstance(candidates, list):
            candidates = []
        valid = [str(e).strip() for e in candidates if re.match(r"^1\d{6}$", str(e).strip())]
        print(f"[salesman-extract] {pdf_path.name} → {valid} (model={model_name})", flush=True)
        return valid

    return []


def _find_opex_pdfs(folder_path):
    """OPEX-*.pdf files directly inside an evidence folder, sorted by name."""
    try:
        return sorted(
            f for f in folder_path.iterdir()
            if f.is_file() and f.suffix.lower() == ".pdf"
            and re.search(r"opex", f.name, re.IGNORECASE)
        )
    except OSError:
        return []


FORM_VS_MANPOWER_SEGMENT_DIFF = "FORM_VS_MANPOWER_SEGMENT_DIFF"


def _clean_numeric_segment(value, width: int | None = None) -> str:
    text = str(value or "").strip()
    if not text or text.lower() in {"none", "nan", "null", "missing", "n/a"}:
        return ""
    if re.fullmatch(r"\d+\.0", text):
        text = text[:-2]
    text = re.sub(r"\s+", "", text)
    if not text.isdigit():
        return ""
    if width and len(text) <= width:
        return text.zfill(width)
    return text


def _cascade_form_value(cascade_row: dict, header_prefix: str) -> str:
    prefix = header_prefix.lower()
    for key, value in cascade_row.items():
        if str(key or "").strip().lower().startswith(prefix):
            return str(value or "").strip()
    return ""


def _parse_opex_event_segments(folder: Path | None, cascade_row: dict) -> dict:
    """Return OPEX/form-derived sponsorship segment values for a row.

    The Form * audit columns may already be present on regular travel rows from
    process_batch.py. Sponsorship overlay rows often skipped that path, so use
    the OPEX PDF parser as a second source.
    """
    event = {
        "div": _clean_numeric_segment(_cascade_form_value(cascade_row, "Form Division"), 3),
        "agency": _clean_numeric_segment(_cascade_form_value(cascade_row, "Form Agency"), 5),
        "solution": _clean_numeric_segment(_cascade_form_value(cascade_row, "Form Solution"), 5),
        "cost_center_ref": _clean_numeric_segment(
            _cascade_form_value(cascade_row, "Form Cost-Center-Ref")
        ),
        "cost_center": "",
        "source": "cascade_form_columns",
    }

    # A 15-digit Fusion ref belongs in the Form Cost-Center-Ref audit column,
    # not in the 6-digit GL cost-center segment.
    if event["cost_center_ref"] and len(event["cost_center_ref"]) <= 6:
        event["cost_center"] = event["cost_center_ref"].zfill(6)

    if folder and folder.exists():
        for pdf_path in _find_opex_pdfs(folder):
            try:
                from opex_pdf_parser import parse_opex_pdf
                parsed = parse_opex_pdf(pdf_path.read_bytes(), pdf_path.name) or {}
            except Exception as exc:
                print(
                    f"[sponsor-form-segments] OPEX parse failed for {pdf_path}: {exc}",
                    flush=True,
                )
                parsed = {}
            if not parsed:
                text_segments = _extract_opex_pdf_text_segments(pdf_path)
                if not text_segments:
                    continue
                event["source"] = pdf_path.name
                event["div"] = event["div"] or text_segments.get("div", "")
                event["agency"] = event["agency"] or text_segments.get("agency", "")
                event["solution"] = event["solution"] or text_segments.get("solution", "")
                event["cost_center"] = event["cost_center"] or text_segments.get("cost_center", "")
                continue
            event["source"] = str(parsed.get("pdf_source") or pdf_path.name)
            event["div"] = event["div"] or _clean_numeric_segment(parsed.get("form_division"), 3)
            event["agency"] = event["agency"] or _clean_numeric_segment(parsed.get("form_agency"), 5)
            event["solution"] = event["solution"] or _clean_numeric_segment(parsed.get("form_solution"), 5)
            parsed_cc = _clean_numeric_segment(parsed.get("form_cost_center"), 6)
            if parsed_cc and len(parsed_cc) == 6:
                event["cost_center"] = event["cost_center"] or parsed_cc
            if not (event["div"] and event["agency"] and event["solution"] and event["cost_center"]):
                text_segments = _extract_opex_pdf_text_segments(pdf_path)
                event["div"] = event["div"] or text_segments.get("div", "")
                event["agency"] = event["agency"] or text_segments.get("agency", "")
                event["solution"] = event["solution"] or text_segments.get("solution", "")
                event["cost_center"] = event["cost_center"] or text_segments.get("cost_center", "")
            if not event["cost_center_ref"]:
                event["cost_center_ref"] = _clean_numeric_segment(parsed.get("form_cost_center"))
            if event["div"] and event["agency"] and event["solution"] and event["cost_center"]:
                break

    return event


def _feed_sponsorship_agency_from_opex(
    classify: dict,
    cascade_row: dict,
) -> dict:
    """Populate Call-1 sponsorship agency from the already used OPEX form parse."""
    if str(classify.get("sponsorship_agency_from_form", "") or "").strip():
        return {}

    folder_str = (
        classify.get("_folder")
        or classify.get("folder")
        or str((classify.get("_evidence") or {}).get("folder", "") or "")
    )
    folder = Path(folder_str) if folder_str else None
    event = _parse_opex_event_segments(folder, cascade_row)
    form_agency = str(event.get("agency", "") or "").strip()
    if form_agency:
        classify["sponsorship_agency_from_form"] = form_agency
        classify["_sponsorship_agency_from_form_source"] = event.get("source", "")
    return event


def _normalise_label(value: str) -> str:
    return re.sub(r"[^a-z0-9]+", "", str(value or "").lower())


def _lookup_segment_code_by_name(segment: str, label: str) -> str:
    label_norm = _normalise_label(label)
    if not label_norm:
        return ""
    lookup = get_lookup()
    lookup._ensure_loaded()
    maps = {
        "div": lookup._div_to_name,
        "agency": lookup._agency_to_name,
        "solution": lookup._solution_to_name,
    }
    widths = {"div": 3, "agency": 5, "solution": 5}
    mapping = maps.get(segment, {})
    for code, name in mapping.items():
        if _normalise_label(name) == label_norm:
            return _clean_numeric_segment(code, widths[segment])
    for code, name in mapping.items():
        name_norm = _normalise_label(name)
        if label_norm and (label_norm in name_norm or name_norm in label_norm):
            return _clean_numeric_segment(code, widths[segment])
    return ""


def _extract_opex_pdf_text_segments(pdf_path: Path) -> dict:
    """Deterministic fallback for OPEX PDFs that show labels, not numeric codes."""
    try:
        import fitz
        with fitz.open(str(pdf_path)) as doc:
            text = "\n".join(page.get_text() for page in doc)
    except Exception:
        return {}
    if not text.strip():
        text = _ocr_pdf_first_page(pdf_path)
    if not text.strip():
        return {}

    out = {}
    label_map = {
        "agency": r"Agency:\s*([^\n]+)",
        "div": r"Division:\s*([^\n]+)",
        "solution": r"Solution:\s*([^\n]+)",
        "cost_center": r"Cost\s*Center:\s*(\d{1,6})",
    }
    for key, pat in label_map.items():
        m = re.search(pat, text, re.IGNORECASE)
        if not m:
            continue
        raw = m.group(1).strip()
        if key == "cost_center":
            out[key] = _clean_numeric_segment(raw, 6)
        elif raw.isdigit():
            out[key] = _clean_numeric_segment(raw, {"div": 3, "agency": 5, "solution": 5}[key])
        else:
            out[key] = _lookup_segment_code_by_name(key, raw)
    if not out.get("agency"):
        ocr_text = _ocr_pdf_first_page(pdf_path)
        agency = _unique_agency_from_text(f"{text}\n{ocr_text}")
        if agency:
            out["agency"] = agency
    return out


def _ocr_pdf_first_page(pdf_path: Path) -> str:
    if not shutil.which("tesseract"):
        return ""
    try:
        import fitz
        with fitz.open(str(pdf_path)) as doc:
            if not doc:
                return ""
            pix = doc[0].get_pixmap(matrix=fitz.Matrix(2, 2), alpha=False)
            with tempfile.NamedTemporaryFile(suffix=".png", delete=False) as tmp:
                tmp_path = Path(tmp.name)
            try:
                pix.save(str(tmp_path))
                proc = subprocess.run(
                    ["tesseract", str(tmp_path), "stdout", "--psm", "6"],
                    check=False,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.DEVNULL,
                    text=True,
                    timeout=30,
                )
                return proc.stdout or ""
            finally:
                try:
                    tmp_path.unlink()
                except OSError:
                    pass
    except Exception:
        return ""


def _unique_agency_from_text(text: str) -> str:
    lookup = get_lookup()
    lookup._ensure_loaded()
    counts = Counter()
    norm_text = _normalise_label(text)
    text_tokens = re.findall(r"[a-z0-9]+", norm_text)
    for code, name in getattr(lookup, "_agency_to_name", {}).items():
        code = _clean_numeric_segment(code, 5)
        name_norm = _normalise_label(name)
        if (
            not code
            or not name_norm
            or len(name_norm) < 4
            or name_norm in {"general", "spon", "none", "na"}
        ):
            continue
        hit_count = norm_text.count(name_norm)
        if not hit_count and len(name_norm) >= 5:
            for tok in text_tokens:
                if abs(len(tok) - len(name_norm)) > 2:
                    continue
                if SequenceMatcher(None, tok, name_norm).ratio() >= 0.82:
                    hit_count += 1
                    break
        if hit_count:
            counts[code] += hit_count
    if not counts:
        return ""
    ranked = counts.most_common()
    if len(ranked) == 1:
        return ranked[0][0]
    if ranked[0][1] > ranked[1][1]:
        return ranked[0][0]
    return ""


def _first_manpower_emp_no(row: dict) -> str:
    for emp_no in _emp_tokens(row.get("emp_no", "")):
        return emp_no
    return ""


def _manpower_home_segments(row: dict, manpower: dict) -> dict:
    emp_no = _first_manpower_emp_no(row)
    rec = manpower.get(emp_no) if emp_no else None
    if not rec:
        return {"emp_no": emp_no}
    return {
        "emp_no": emp_no,
        "cost_center": _clean_numeric_segment(rec.get("cost_center"), 6),
        "div": _clean_numeric_segment(rec.get("div_code"), 3),
        "agency": _clean_numeric_segment(rec.get("agency_code"), 5),
        "solution": _clean_numeric_segment(rec.get("solution"), 5),
        "location": _clean_numeric_segment(rec.get("location"), 5),
    }


def _append_agent_flag_detail(row: dict, flag: str) -> None:
    details = row.setdefault("_agent_flag_details", [])
    if flag not in details:
        details.append(flag)


def _sponsorship_event_folder_for_row(
    row: dict,
    cascade_row: dict,
    raw_root: Path,
    all_folders: list[Path],
    reverse_index: dict[str, Path],
) -> Path | None:
    existing = str(row.get("_evidence_folder", "") or "").strip()
    if existing:
        p = Path(existing)
        if p.exists():
            return p

    desc = str(cascade_row.get("Description", "") or "")
    notes = str(cascade_row.get("Notes", "") or "")
    ticket = ""
    m = re.search(r"\b(\d{10,})\b", desc + " " + notes)
    if m:
        ticket = m.group(1)
    else:
        m2 = re.search(r"\b(26-\d{3})\b", desc + " " + notes)
        ticket = m2.group(1) if m2 else ""
    passenger = desc.split(" - ", 1)[0].strip() if " - " in desc else desc.strip()

    folder = find_folder_v25(ticket, passenger, notes, all_folders, reverse_index) if ticket else None
    if folder and folder.exists():
        return folder

    # Shared OPEX catch: for rows without a dedicated ticket folder, use the
    # same content-based matcher as the within-batch QC catch when available.
    try:
        from qc_catches_within_batch import _find_shared_opex_folder_in_batch
        _date_dir, shared = _find_shared_opex_folder_in_batch(raw_root, ticket, passenger)
        if shared:
            return shared
    except Exception:
        pass
    return None


def _folder_opex_email_only_serial(folder: Path | None) -> str:
    """Return an OPEX serial when a folder has OPEX email context but no OPEX PDF."""
    if not folder or not folder.exists() or _find_opex_pdfs(folder):
        return ""
    serial = _extract_serial_from_text(folder.name)
    try:
        from msg_parser import parse_msg
    except Exception:
        parse_msg = None
    for msg in sorted(folder.glob("*.msg")):
        subject = body = ""
        if parse_msg:
            parsed = parse_msg(msg, use_cache=True)
            if parsed.get("parse_method") != "failed":
                subject = parsed.get("subject", "") or ""
                body = parsed.get("body_text", "") or ""
        if not subject and not body:
            try:
                raw = msg.read_bytes().decode("utf-8", errors="ignore")
            except Exception:
                raw = ""
            subject = body = raw
        blob = f"{folder.name}\n{subject}\n{body}"
        if "opex" not in blob.lower():
            continue
        serial = serial or _extract_serial_from_text(blob)
        if serial:
            return serial
    return ""


def _email_only_opex_folder_for_ticket(ticket_no: str, all_folders: list[Path]) -> Path | None:
    """Find a direct email-only OPEX/event folder whose PDF itinerary lists ticket_no."""
    if not ticket_no:
        return None
    for folder in sorted(all_folders):
        serial = _folder_opex_email_only_serial(folder)
        if not serial:
            continue
        for pdf in sorted(folder.glob("*.pdf")):
            text = _pdf_text(pdf)
            if ticket_no in text:
                return folder
    return None


def apply_opex_email_only_review_state(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    raw_root: Path,
    all_folders: list[Path],
    reverse_index: dict[str, Path],
) -> int:
    """Flag likely OPEX/event rows where only email evidence exists.

    Without the OPEX PDF, the account signal may be sponsorship but exact
    DIV/agency/solution/cost-center stamping is not evidence-backed.
    """
    applied = 0
    for i, row in enumerate(hybrid_rows):
        if row_missing_evidence(row) or row_verified_emp_locked(row):
            continue
        if row_family_annual_locked(row):
            continue
        account = str(row.get("account", "") or "").strip()
        if account not in {"60301003", "60301004", "60307021"}:
            continue
        cascade_row = cascade_rows[i]
        folder = _email_only_opex_folder_for_ticket(_row_ticket_no(cascade_row), all_folders)
        if folder is None:
            folder = _sponsorship_event_folder_for_row(
                row, cascade_row, raw_root, all_folders, reverse_index
            )
        serial = _folder_opex_email_only_serial(folder)
        if not serial:
            continue
        row["account"] = "60307021"
        for key in ("cost_center", "div", "solution", "agency"):
            row[key] = ""
        row["_opex_serial"] = serial
        if folder:
            row["_evidence_folder"] = str(folder)
        row["_opex_email_only"] = True
        row["_agent_method"] = "v25_opex_email_only"
        row["_route_reason"] = "OPEX_EMAIL_ONLY_REVIEW"
        _append_hybrid_flag(row, OPEX_EMAIL_ONLY_FLAG)
        applied += 1
        print(
            f"[opex-email-only] row {i+1}: {serial} has email evidence but no OPEX PDF; "
            "sponsorship account flagged for review without exact segments",
            flush=True,
        )
    return applied


def apply_sponsorship_event_segments(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    manpower: dict,
    raw_root: Path,
    all_folders: list[Path],
    reverse_index: dict[str, Path],
) -> int:
    """Policy A/B/C: sponsorship rows use event/form segments, not home segments."""
    applied = 0
    for i, row in enumerate(hybrid_rows):
        if row.get("_opex_email_only"):
            continue
        if row_missing_evidence(row) or row_verified_emp_locked(row):
            continue
        if str(row.get("account", "") or "").strip() != "60307021":
            continue

        cascade_row = cascade_rows[i]
        folder = _sponsorship_event_folder_for_row(
            row, cascade_row, raw_root, all_folders, reverse_index
        )
        event = _parse_opex_event_segments(folder, cascade_row)

        # Labadi sponsorship agency rule: when Call 1 or the OPEX form parser
        # provides an agency, ignore form Division/Solution and employee-home/
        # event segments. Apply the single consistent Manpower code set for that
        # agency uniformly to every sponsorship output row, including split rows.
        if (
            not str(row.get("_sponsorship_agency_from_form", "") or "").strip()
            and event.get("agency")
        ):
            row["_sponsorship_agency_from_form"] = event.get("agency", "")
            row["_sponsorship_agency_from_form_source"] = event.get("source", "")
        form_agency = str(row.get("_sponsorship_agency_from_form", "") or "").strip()
        if form_agency:
            agency_codes, agency_status = resolve_sponsorship_codes_from_agency(
                form_agency, manpower
            )
            if agency_codes:
                changes = 0
                for key in ("account", "cost_center", "div", "solution", "agency"):
                    if str(row.get(key, "") or "").strip() != str(agency_codes.get(key, "") or "").strip():
                        row[key] = agency_codes.get(key, "")
                        changes += 1
                row["_sponsorship_agency_status"] = agency_status
                row["_sponsorship_agency_codes_applied"] = True
                if changes and row.get("_agent_method", "cascade") == "cascade":
                    row["_agent_method"] = "hybrid_overlay"
                if changes:
                    applied += 1
                print(
                    f"[sponsor-agency-codes] row {i+1}: agency {form_agency!r} "
                    "resolved from Manpower; event/home segments bypassed",
                    flush=True,
                )
                continue
            row["_sponsorship_agency_status"] = agency_status
            if agency_status.startswith("AGENCY_CODES_INCONSISTENT"):
                print(
                    f"[warn] row {i+1}: {agency_status}; falling back to existing "
                    "v30 sponsorship segment behavior",
                    flush=True,
                )

        manpower_home = _manpower_home_segments(row, manpower)

        changes = 0
        diff_parts = []
        for key, width in (
            ("cost_center", 6),
            ("div", 3),
            ("agency", 5),
            ("solution", 5),
        ):
            form_val = event.get(key, "")
            manpower_val = manpower_home.get(key, "")
            current_val = _clean_numeric_segment(row.get(key), width)
            if form_val:
                if current_val != form_val:
                    row[key] = form_val
                    changes += 1
                if manpower_val and form_val != manpower_val:
                    diff_parts.append(f"{key} form={form_val} manpower={manpower_val}")
            else:
                fallback = manpower_val or current_val
                if fallback and current_val != fallback:
                    row[key] = fallback
                    changes += 1
                diff_parts.append(f"{key} form_missing manpower={manpower_val or 'missing'}")

        # There is no reliable parsed OPEX location field today; keep existing
        # event/sponsorship location, falling back to manpower only if blank.
        if not _clean_numeric_segment(row.get("location"), 5):
            row["location"] = manpower_home.get("location", "") or "40100"
            changes += 1

        row["_form_division"] = event.get("div", "")
        row["_form_agency"] = event.get("agency", "")
        row["_form_solution"] = event.get("solution", "")
        row["_form_cost_center_ref"] = event.get("cost_center_ref", "") or event.get("cost_center", "")
        if folder:
            row["_evidence_folder"] = str(folder)

        if diff_parts:
            _append_agent_flag_detail(
                row,
                f"{FORM_VS_MANPOWER_SEGMENT_DIFF}({'; '.join(diff_parts)})",
            )

        if changes:
            if row.get("_agent_method", "cascade") == "cascade":
                row["_agent_method"] = "hybrid_overlay"
            row["_sponsorship_event_segments_applied"] = True
            applied += 1
            print(
                f"[sponsor-form-segments] row {i+1}: 60307021 event segments "
                f"from {event.get('source') or 'form'}",
                flush=True,
            )
    print(
        f"[sponsor-form-segments] {applied} sponsorship row(s) received event/form segments",
        flush=True,
    )
    return applied


def stamp_sponsorship_form_columns(out_xlsx: Path, hybrid_rows: list[dict], hdr_row: int) -> int:
    wb = openpyxl.load_workbook(out_xlsx)
    ws = wb.active
    cols = {
        str(ws.cell(hdr_row, ci).value or "").strip(): ci
        for ci in range(1, ws.max_column + 1)
        if str(ws.cell(hdr_row, ci).value or "").strip()
    }
    col_by_prefix = {}
    for wanted in (
        "Form Division",
        "Form Agency",
        "Form Solution",
        "Form Cost-Center-Ref",
    ):
        col_by_prefix[wanted] = next(
            (ci for hdr, ci in cols.items() if hdr.startswith(wanted)),
            None,
        )

    written = 0
    for row in hybrid_rows:
        if str(row.get("account", "") or "").strip() != "60307021":
            continue
        values = {
            "Form Division": row.get("_form_division", ""),
            "Form Agency": row.get("_form_agency", ""),
            "Form Solution": row.get("_form_solution", ""),
            "Form Cost-Center-Ref": row.get("_form_cost_center_ref", ""),
        }
        row_written = False
        for hdr, val in values.items():
            col = col_by_prefix.get(hdr)
            if col and val:
                ws.cell(row["_row_idx"], col).value = val
                row_written = True
        if row_written:
            written += 1
    if written:
        wb.save(str(out_xlsx))
    wb.close()
    print(f"[sponsor-form-segments] {written} sponsorship row(s) stamped Form * columns", flush=True)
    return written


def _emp_tokens(emp_no) -> list[str]:
    if emp_no is None:
        return []
    text = str(emp_no).strip()
    if not text or text in ("0", "-", "nan", "None"):
        return []
    tokens = []
    for part in re.split(r"[,\s]+", text):
        part = part.strip()
        if re.fullmatch(r"\d+\.0", part):
            part = part[:-2]
        if re.fullmatch(r"\d{7}", part):
            tokens.append(part)
    return tokens


def _emp_resolves_in_manpower(emp_no, manpower: dict) -> bool:
    return any(token in manpower for token in _emp_tokens(emp_no))


def _remove_pipe_flag_text(value, flag: str):
    if value is None:
        return value, False
    text = str(value).strip()
    sep = "|" if "|" in text else None
    parts = [p.strip() for p in (text.split("|") if sep else text.split())]
    kept = [p for p in parts if p and p != flag]
    changed = len(kept) != len([p for p in parts if p])
    if not changed:
        return value, False
    joiner = " | " if sep else " "
    return (joiner.join(kept) if kept else "CLEAN"), True


def _clear_stale_employee_not_in_master_dict(row: dict, manpower: dict) -> bool:
    if not _emp_resolves_in_manpower(row.get("emp_no"), manpower):
        return False
    changed = False
    for key in ("_flags", "Agent Flags"):
        new_value, did_change = _remove_pipe_flag_text(
            row.get(key, ""), "EMPLOYEE_NOT_IN_MASTER"
        )
        if did_change:
            if key == "_flags" and new_value == "CLEAN":
                new_value = ""
            row[key] = new_value
            changed = True
    return changed


def _apply_multi_salesman_from_opex(final, classify, row_idx, manpower=None):
    """Labadi RULE 1 (2026-06-09) multi-salesman: a sponsorship OPEX form can
    allocate the amount across SEVERAL salesmen. The shortcut / metadata paths
    only see the single requesting emp_no, so re-read the OPEX PDF's salesman
    table and stamp ALL employee numbers (comma-separated) on the row.
    Also backfills opex_serial from the OPEX PDF filename when still missing.
    """
    folder_str = str(classify.get("_folder", "") or "")
    if not folder_str:
        return
    opex_pdfs = _find_opex_pdfs(Path(folder_str))
    if not opex_pdfs:
        return
    salesmen = _extract_salesmen_from_opex_pdf(opex_pdfs[0])
    if len(salesmen) >= 2:
        final["emp_no"] = ",".join(salesmen)
        print(
            f"[v30-multi-salesman] row {row_idx}: {len(salesmen)} salesmen "
            f"in {opex_pdfs[0].name} → {final['emp_no']}",
            flush=True,
        )
    elif len(salesmen) == 1 and str(final.get("emp_no", "") or "").strip() in ("", "0", "-"):
        final["emp_no"] = salesmen[0]

    if manpower:
        _clear_stale_employee_not_in_master_dict(final, manpower)

    # OPEX serial is often right in the PDF filename (e.g.
    # "OPEX-CE-18-2026-J-2026-108 (1).pdf").
    if str(final.get("opex_serial", "") or "").strip() in ("", "MISSING", "N/A"):
        for opex_pdf in opex_pdfs:
            serial_from_name = _extract_serial_from_text(opex_pdf.name)
            if serial_from_name:
                final["opex_serial"] = serial_from_name
                break


def process_row_v25(
    row_idx: int,
    cascade_row: dict,
    route_reason: str,
    batch_id: str,
    raw_root: Path,
    all_folders: list[Path],
    manpower: dict,
    lookups: dict,
    reverse_index: dict[str, Path] | None = None,
    pc_index: dict[str, dict] | None = None,
    no_cache: bool = False,
    verified_emp_locked: bool = False,
) -> dict:
    """
    v25 process_row with folder-correction (Fix A+B).

    classify_row is called first (it may find the wrong folder for family bookings
    via surname matching).  We then check if find_folder_v25 returns a BETTER folder
    (one that is in the reverse_index via adjacent-ticket expansion).  If the better
    folder has a PC email, we override classify's cached _folder / _evidence before
    calling full_resolve_row, and we reuse route_reason="CHD_PC_EVIDENCE" so that
    the prompt hint fires for family members just as it does for CHD/INF passengers.
    """
    import time as _t
    # Local imports kept from v16 helper flow (origin: v16).
    from run_v16 import (
        classify_row, full_resolve_row,
        resolve_from_master, resolve_sponsorship_from_master,
        _apply_sponsorship_agency_codes,
        apply_overlays_v16, enforce_sponsorship_rules,
        _clean_passenger, _norm_master_code,
    )

    desc  = str(cascade_row.get("Description", "") or "")
    notes = str(cascade_row.get("Notes", "") or "")
    text  = desc + " " + notes
    m     = re.search(r"\b(\d{10,})\b", text)
    ticket = m.group(1) if m else ""
    if not ticket:
        m2 = re.search(r"\b(26-\d{3})\b", text)
        ticket = m2.group(1) if m2 else ""
    passenger = desc.split(" - ", 1)[0].strip() if " - " in desc else ""

    trace: dict = {
        "row_idx":      row_idx,
        "description":  desc[:80],
        "route_reason": route_reason,
        "call1": None, "call2": None, "shortcut": None, "final": None,
    }

    # ── CALL 1: classify ─────────────────────────────────────────────────
    t1 = _t.time()
    classify = classify_row(row_idx, cascade_row, batch_id, raw_root, all_folders,
                            reverse_index=reverse_index, no_cache=no_cache)

    # ── FIX A+B: correct folder if classify found wrong one ──────────────
    # find_folder_v25 prioritises reverse_index (adjacent-ticket entries) over
    # surname matching.  If it finds a DIFFERENT folder with a PC email,
    # override classify's evidence so Call 2 sees the right documents.
    correct_folder = find_folder_v25(ticket, passenger, notes, all_folders, reverse_index or {})
    classify_folder_str = classify.get("_folder", "")
    folder_corrected = False

    if correct_folder and str(correct_folder) != classify_folder_str:
        # v30 conservative: only correct if the better folder is an explicit family
        # folder (folder name contains 'family') AND has a PC email.  Pure PC-email
        # folders without 'family' in the name are individual employee tickets and
        # should not override a classify result that already found a valid folder.
        is_family_folder = "family" in correct_folder.name.lower()
        if is_family_folder and _folder_has_pc_email(correct_folder):
            correct_evidence = fea.collect_evidence(correct_folder)
            classify["_folder"]   = str(correct_folder)
            classify["_evidence"] = correct_evidence
            folder_corrected = True
            # Escalate route_reason so Call 2 gets the CHD_PC_EVIDENCE hint
            if route_reason not in ("CHD_PC_EVIDENCE", "FAMILY_PC_EVIDENCE"):
                route_reason = "FAMILY_PC_EVIDENCE"
            print(
                f"[v30-fix-ab] row {row_idx} ({passenger}): folder corrected "
                f"{Path(classify_folder_str).name if classify_folder_str else '(none)'} "
                f"→ {correct_folder.name}",
                flush=True,
            )

    # ── v30 FIX: shared-OPEX event-folder fallback (no per-ticket folder) ──
    # Some sponsored-attendee tickets have NO folder named by ticket number —
    # their approval evidence lives in a shared event folder (e.g.
    # "CRM-2026-27 Approvals") alongside an OPEX-*.pdf.  find_folder_v25 (ticket /
    # reverse-index / 26-NNN based) returns None for these, so classify_row
    # collects zero evidence and Call 2 defaults to 60301003 (travel) at low
    # confidence.  Reuse the _find_shared_opex_folder logic from
    # qc_catches_within_batch.py: scan sibling dirs in the same date-dir for a
    # non-ticket folder that holds an OPEX-*.pdf and a file referencing the
    # passenger name or ticket number.  If found, adopt it as the evidence folder
    # and prepend the OPEX requesting/sponsoring employee number to the evidence
    # text so Call 2 (and the sponsorship master shortcut) can see it.
    if (not folder_corrected) and not classify.get("_folder"):
        from qc_catches_within_batch import _find_shared_opex_folder_in_batch
        _shared_date_dir, shared_folder = _find_shared_opex_folder_in_batch(
            raw_root, ticket, passenger
        )
        if shared_folder:
            shared_evidence = fea.collect_evidence(shared_folder)
            opex_emp = _extract_opex_emp_no(shared_folder)
            if opex_emp:
                # Prepend an explicit hint as a synthetic PDF so both the raw
                # evidence text (Call 2) and downstream snapshot see the emp_no.
                hint = {
                    "filename": "[v30-shared-opex-hint]",
                    "text": (
                        f"SHARED OPEX SPONSORSHIP EVIDENCE — ticket {ticket} "
                        f"({passenger}) has no dedicated per-ticket folder; its "
                        f"approval evidence is the shared event folder "
                        f"'{shared_folder.name}'. The AlJeel OPEX requesting / "
                        f"sponsoring employee number is {opex_emp}. This is a "
                        f"sponsored external attendee (account 60307021), funded "
                        f"by employee {opex_emp}'s department."
                    ),
                }
                shared_evidence.setdefault("pdfs", []).insert(0, hint)
                shared_evidence["total_chars"] = (
                    shared_evidence.get("total_chars", 0) + len(hint["text"])
                )
                # Feed the sponsoring emp_no into classify so the sponsorship
                # master shortcut / Call 2 can resolve the event CC.
                classify["requesting_emp_no"] = opex_emp
                classify["row_type"] = "sponsorship"
            classify["_folder"]   = str(shared_folder)
            classify["_evidence"] = shared_evidence
            folder_corrected = True
            route_reason = "SHARED_OPEX_SPONSORSHIP"
            print(
                f"[v30-shared-opex] row {row_idx} ({passenger}): no per-ticket "
                f"folder; using shared OPEX folder '{shared_folder.name}'"
                + (f" (requesting emp {opex_emp})" if opex_emp else ""),
                flush=True,
            )

    if classify.get("row_type") == "sponsorship":
        _feed_sponsorship_agency_from_opex(classify, cascade_row)

    trace["call1"] = {
        "model":                classify.get("_llm_model", ""),
        "from_cache":           classify.get("_from_cache", False),
        "elapsed_sec":          round(_t.time() - t1, 2),
        "row_type":             classify.get("row_type", ""),
        "employee_no_in_doc":   classify.get("employee_no_in_doc", ""),
        "requesting_emp_no":    classify.get("requesting_emp_no", ""),
        "sponsorship_agency_from_form": classify.get("sponsorship_agency_from_form", ""),
        "opex_code":            classify.get("opex_code", ""),
        "classification_basis": str(classify.get("classification_basis", "") or "")[:200],
        "evidence_folder":      classify.get("_folder", ""),
        "evidence_files":       list((classify.get("_evidence") or {}).get("files", [])),
        "evidence_chars":       int((classify.get("_evidence") or {}).get("total_chars", 0)),
        "in_tokens":            classify.get("_llm_in_tokens", 0),
        "out_tokens":           classify.get("_llm_out_tokens", 0),
        "error":                classify.get("_llm_error", ""),
        "folder_corrected":     folder_corrected,
    }

    row_type       = classify.get("row_type", "unclear")
    emp_no_hint    = classify.get("employee_no_in_doc", "").strip()
    requesting_no  = classify.get("requesting_emp_no", "").strip()
    form_agency    = str(classify.get("sponsorship_agency_from_form", "") or "").strip()

    # v19 Fix 2b: downgrade "employee" with no evidence files + surname not in master
    if row_type == "employee" and not emp_no_hint:
        ev_files = list((classify.get("_evidence") or {}).get("files", []))
        if not ev_files:
            desc_for_chk = desc.upper()
            pax_part = desc_for_chk.split(" - ", 1)[0].strip().upper()
            surname = pax_part.split("/")[0].strip() if "/" in pax_part else ""
            surname_in_master = surname and any(
                surname in str(v.get("name", "") or "").upper()
                for v in manpower.values()
            )
            if not surname_in_master:
                row_type = "unclear"
                classify["row_type"] = "unclear"
                classify["classification_basis"] = (
                    str(classify.get("classification_basis", "") or "") +
                    " [v19: overridden unclear — no evidence files + surname not in master]"
                )
                trace["call1"]["row_type"] = "unclear"

    # ── Master shortcut: employee found in doc AND in master? Skip Call 2 ──
    if row_type == "employee" and emp_no_hint and emp_no_hint in manpower:
        rec = resolve_from_master(emp_no_hint, manpower)
        if rec:
            final = enforce_sponsorship_rules(rec, classify, cascade_row)
            final["_agent_method"]  = "v16_master_shortcut"
            final["_classify"]      = row_type
            final["_classify_emp"]  = emp_no_hint
            final["_route_reason"]  = route_reason
            final["_llm_in_tokens"] = classify.get("_llm_in_tokens", 0)
            final["_llm_out_tokens"]= classify.get("_llm_out_tokens", 0)
            final["_from_cache"]    = classify.get("_from_cache", False)
            trace["shortcut"] = {"type": "master_shortcut_employee", "emp_no": emp_no_hint}
            trace["final"] = {k: v for k, v in final.items() if not k.startswith("_")}
            final["_step_trace"] = trace
            return final

    # ── Master shortcut: sponsorship with requesting emp in master? ──────
    if (
        row_type == "sponsorship"
        and requesting_no
        and requesting_no in manpower
        and not verified_emp_locked
    ):
        rec = resolve_sponsorship_from_master(
            requesting_no, manpower, lookups, form_agency=form_agency
        )
        if rec:
            final = enforce_sponsorship_rules(rec, classify, cascade_row)
            if form_agency:
                final["_sponsorship_agency_from_form"] = form_agency
            final["_agent_method"]  = "v16_sponsorship_master"
            # Stamp requestor emp_no on shortcut rows (Labadi Rule 1 — always populated)
            if str(final.get("emp_no", "") or "").strip() in ("", "0", "0000000"):
                final["emp_no"] = str(requesting_no)
            final["_classify"]      = row_type
            final["_classify_req"]  = requesting_no
            final["_route_reason"]  = route_reason
            final["_llm_in_tokens"] = classify.get("_llm_in_tokens", 0)
            final["_llm_out_tokens"]= classify.get("_llm_out_tokens", 0)
            final["_from_cache"]    = classify.get("_from_cache", False)
            # Labadi RULE 4 follow-up: the shortcut bypasses Call 2, so
            # opex_serial was never LLM-extracted. Pull it from the evidence
            # folder name when possible (e.g. "OPEX ... CRM-2026-30").
            if str(final.get("opex_serial", "") or "").strip() in ("", "MISSING", "N/A"):
                _serial = _extract_serial_from_text(
                    Path(classify.get("_folder", "") or "").name
                )
                if _serial:
                    final["opex_serial"] = _serial
            # Labadi RULE 1: pick up ALL salesmen from the OPEX PDF's allocation
            # table (the shortcut only saw the single requesting emp_no), and
            # backfill opex_serial from the PDF filename if still missing.
            _apply_multi_salesman_from_opex(final, classify, row_idx, manpower)
            trace["shortcut"] = {"type": "master_shortcut_sponsorship", "requesting_emp_no": requesting_no}
            trace["final"] = {k: v for k, v in final.items() if not k.startswith("_")}
            final["_step_trace"] = trace
            return final

    # ── CALL 2: full evidence resolve ─────────────────────────────────────
    # For FAMILY_PC_EVIDENCE, reuse the CHD_PC_EVIDENCE route_reason so the
    # existing prompt-hint in full_resolve_row fires correctly.
    effective_reason = "CHD_PC_EVIDENCE" if route_reason == "FAMILY_PC_EVIDENCE" else route_reason


    # ── FIX: PDF OPEX Emp No Extraction Overlay ───────────────────
    extracted_opex_emp = ""
    folder_str = classify.get("folder") if classify and isinstance(classify, dict) else None
    if folder_str:
        import pathlib
        folder_to_check = pathlib.Path(folder_str)
        extracted_opex_emp = _extract_opex_emp_no(folder_to_check)
    
    if extracted_opex_emp:
        print(f"[v30-opex-override] Found explicit emp_no {extracted_opex_emp} in OPEX PDF for {ticket}. Forcing into classification hint.", flush=True)
        classify["requesting_emp_no"] = extracted_opex_emp
        classify["row_type"] = "sponsorship"
        _feed_sponsorship_agency_from_opex(classify, cascade_row)
        form_agency = str(classify.get("sponsorship_agency_from_form", "") or "").strip()
        requesting_no = str(classify.get("requesting_emp_no", "") or "").strip()
        row_type = classify.get("row_type", row_type)
        route_reason = "SPONSORING_EMPNO_REVIEW"

    t2 = _t.time()
    llm = full_resolve_row(
        row_idx, cascade_row, classify, batch_id, raw_root, all_folders,
        manpower, lookups, reverse_index=reverse_index,
        no_cache=no_cache, route_reason=effective_reason,
    )
    trace["call2"] = {
        "model":       llm.get("_llm_model", ""),
        "from_cache":  llm.get("_from_cache", False),
        "elapsed_sec": round(_t.time() - t2, 2),
        "emp_no":      llm.get("emp_no", ""),
        "account":     llm.get("account", ""),
        "cost_center": llm.get("cost_center", ""),
        "agency":      llm.get("agency", ""),
        "confidence":  llm.get("confidence", ""),
        "reasoning":   str(llm.get("reasoning", "") or "")[:400],
        "in_tokens":   llm.get("_llm_in_tokens", 0),
        "out_tokens":  llm.get("_llm_out_tokens", 0),
        "error":       llm.get("_llm_error", ""),
    }

    if llm.get("_llm_error"):
        trace["final"] = {"error": llm.get("_llm_error", "")}
        result = {
            "_agent_method":  "cascade_fallback",
            "_route_reason":  route_reason,
            "_llm_error":     llm.get("_llm_error", ""),
            "_classify":      row_type,
            "_llm_in_tokens": classify.get("_llm_in_tokens", 0) + llm.get("_llm_in_tokens", 0),
            "_llm_out_tokens":classify.get("_llm_out_tokens", 0) + llm.get("_llm_out_tokens", 0),
            "_step_trace":    trace,
        }
        return result

    final, method = apply_overlays_v16(llm, cascade_row, classify)
    final = enforce_sponsorship_rules(final, classify, cascade_row)

    # Labadi RULE 4 (2026-06-09): carry the LLM-extracted OPEX serial through the
    # result so the worker can stamp it on the row. apply_overlays_v16 only copies
    # the 6 GL segments, so read opex_serial straight off the raw LLM output.
    final["opex_serial"] = str(llm.get("opex_serial", "") or "").strip()

    # Labadi RULE 1 (2026-06-09): sponsorship rows carry the requestor / AlJeel
    # employee who submitted the OPEX form — never blank. If the LLM/overlay path
    # left emp_no blank but a requesting employee was identified, populate it.
    if (str(final.get("account", "") or "").strip() == "60307021"
            and str(final.get("emp_no", "") or "").strip() in ("", "0", "-")
            and requesting_no):
        final["emp_no"] = requesting_no

    # Labadi RULE 1 multi-salesman catch-all: sponsorship rows resolved via the
    # LLM also carry only one emp_no even when the OPEX PDF's salesman table
    # allocates across several. Re-read the OPEX PDF and stamp them all.
    if str(final.get("account", "") or "").strip() == "60307021":
        _apply_multi_salesman_from_opex(final, classify, row_idx, manpower)

    # v20 Fix B: PC / family-of-employee reasoning override
    llm_reasoning = str(llm.get("reasoning", "") or "").lower()
    PC_SIGNALS = (
        "personal contribution", "family of employee", "family member of employee",
        "family members of employee", "dependent of employee", "dependents of employee",
        "employee's family", "employee's dependent", "is a family", "are family of",
    )
    is_pc_signal   = False  # Disabled PC reasoning override to prevent overfitting and preserve dynamic LLM accounts
    is_26nnn_route = (route_reason == "26NNN_LIKELY_SPONSORSHIP")

    if is_26nnn_route and is_pc_signal:
        desc_for_nm = str(cascade_row.get("Description", "") or "").upper()
        nm_match = re.search(r"for ([A-Z][a-z]+(?:\s+[A-Z][a-z]+){1,3})\s*\(\d",
                             str(llm.get("reasoning", "") or ""))
        if nm_match:
            pc_name_upper = nm_match.group(1).upper()
            # Require BOTH first AND last name of the passenger to appear in the
            # PC email name. A single common name is never a sufficient match.
            pax_part = desc_for_nm.split(" - ", 1)[0].strip() if " - " in desc_for_nm else desc_for_nm
            TITLE_SKIP = {"MRS","MR","MS","CHD","INF","INFANT"}
            pax_tokens = [t for t in re.findall(r"[A-Z]{3,}", pax_part) if t not in TITLE_SKIP]
            pc_tokens   = set(re.findall(r"[A-Z]{3,}", pc_name_upper))
            if len(pax_tokens) >= 2:
                name_match_found = (pax_tokens[0] in pc_tokens) and (pax_tokens[-1] in pc_tokens)
            elif len(pax_tokens) == 1:
                name_match_found = pax_tokens[0] in pc_tokens
            else:
                name_match_found = False
            is_26nnn_route = not name_match_found

    if is_pc_signal and not is_26nnn_route and final.get("account") != "21070229":
        final["account"] = "21070229"
        pc_emp = final.get("emp_no") or llm.get("emp_no") or ""
        rec = None
        if pc_emp and pc_emp in manpower:
            rec = resolve_from_master(pc_emp, manpower)
        _stamp_21070229_home_segments(final, rec)
        method = "llm_agent_pc_override"

    final["_agent_method"]  = f"v16_{method}"

    # v21 Fix 2: 26-NNN sponsorship override
    # Guard: if Call 2 resolved a real AlJeel employee, keep 60301003/60301004.
    # Hotel/accommodation for an employee is still travel expense, not sponsoring.
    _final_emp = str(final.get("emp_no") or "").strip()
    if (route_reason == "26NNN_LIKELY_SPONSORSHIP"
            and final.get("account") in ("60301003", "60301004")
            and final.get("account") != "21070229"
            and _final_emp not in manpower):
        final["account"] = "60307021"
        final["_agent_method"] = "v16_26nnn_forced_sponsorship"
    elif (route_reason == "26NNN_LIKELY_SPONSORSHIP"
            and _final_emp in manpower):
        # Employee confirmed — preserve travel account, note the guard fired
        final["_agent_method"] = final.get("_agent_method", "") + "+26nnn_employee_guard"

    if (
        not form_agency
        and str(final.get("account", "") or "").strip() == "60307021"
    ):
        _feed_sponsorship_agency_from_opex(classify, cascade_row)
        form_agency = str(classify.get("sponsorship_agency_from_form", "") or "").strip()

    if form_agency and str(final.get("account", "") or "").strip() == "60307021":
        final["_sponsorship_agency_from_form"] = form_agency
        final, agency_status = _apply_sponsorship_agency_codes(final, classify, manpower)
        if agency_status:
            final["_sponsorship_agency_status"] = agency_status

    final["_classify"]      = row_type
    final["_route_reason"]  = route_reason
    final["_llm_in_tokens"] = classify.get("_llm_in_tokens", 0) + llm.get("_llm_in_tokens", 0)
    final["_llm_out_tokens"]= classify.get("_llm_out_tokens", 0) + llm.get("_llm_out_tokens", 0)
    final["_from_cache"]    = classify.get("_from_cache", False) and llm.get("_from_cache", False)
    trace["final"] = {k: v for k, v in final.items() if not k.startswith("_")}
    final["_step_trace"]    = trace
    return final


# ─── FIX C: PC-family dependent emp_no blanking ──────────────────────────────

def apply_pc_family_emp_no_rule(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    manpower: dict,
    pc_index: dict[str, dict],
    all_folders: list[Path],
    reverse_index: dict[str, Path],
) -> int:
    """
    For rows where account=21070229 (personal contribution), blank emp_no when
    the passenger is a family dependent rather than the responsible employee.

    Detection rule:
      1. Look up the responsible employee from the PC index for that ticket's folder.
      2. Extract the passenger's first name from "LASTNAME/FIRSTNAME" format.
      3. If the passenger's first name does NOT appear in the responsible employee's
         full name → the passenger is a family member → emp_no = "".

    This safely preserves emp_no for the actual employee's own PC ticket while
    clearing it for CHD/INF and spouse passengers.

    Returns count of rows where emp_no was blanked.

    Labadi RULE 1 (2026-06-09): emp_no is now ALWAYS populated — dependents/CHD
    rows carry the responsible employee's emp_no (the one already on the row),
    never blank. This blanking pass is therefore DISABLED end-to-end; it is kept
    as a no-op so the pipeline's stage call sites and return-count plumbing stay
    intact.
    """
    return 0
    blanked = 0
    for i, hr in enumerate(hybrid_rows):
        account = str(hr.get("account", "") or "").strip()
        if account != "21070229":
            continue
        emp_no = str(hr.get("emp_no", "") or "").strip()
        if not emp_no:
            continue  # already blank — nothing to do

        # Find the evidence folder for this row
        cr    = cascade_rows[i]
        desc  = str(cr.get("Description", "") or "")
        notes = str(cr.get("Notes", "") or "")
        text  = desc + " " + notes
        m     = re.search(r"\b(\d{10,})\b", text)
        ticket = m.group(1) if m else ""
        if not ticket:
            m2 = re.search(r"\b(26-\d{3})\b", text)
            ticket = m2.group(1) if m2 else ""

        passenger = desc.split(" - ", 1)[0].strip() if " - " in desc else ""
        # Use find_folder_v25 (adj-ticket aware) instead of fea.find_ticket_folder
        folder    = find_folder_v25(ticket, passenger, notes, all_folders, reverse_index)

        # Get PC record
        pc_rec = pc_index.get(str(folder)) if folder else None

        if pc_rec:
            # Use the employee name from the PC email filename
            pc_emp_name = (pc_rec.get("name", "") or "").upper()
        else:
            # Fall back: use the employee's name from master data
            rec = manpower.get(emp_no, {})
            pc_emp_name = (rec.get("emp_name", "") or "").upper()

        if not pc_emp_name:
            continue   # can't determine — leave as-is

        # Extract passenger's first name: "HUSSEIN/TALIA MS(CHD)" → "TALIA"
        pax_first = ""
        m_slash = re.search(r"[/\\]([A-Z]+)", passenger.upper())
        if m_slash:
            pax_first = m_slash.group(1).strip()
        if not pax_first:
            continue   # can't parse — leave as-is

        # If passenger first name is NOT a token in the responsible employee's name
        # → this is a family dependent → blank emp_no
        emp_name_tokens = set(pc_emp_name.split())
        if pax_first not in emp_name_tokens:
            hybrid_rows[i]["emp_no"] = ""
            blanked += 1
            print(
                f"[v25-fix-c] row {i} ({passenger}): emp_no blanked "
                f"('{pax_first}' not in PC employee '{pc_emp_name}')",
                flush=True,
            )

    return blanked


# ─── family-folder emp_no rule (2026-06-09) ──────────────────────────────────
# Evidence folders named "<ticket> family" / "<ticket>_family" are an
# authoritative, deterministic family signal: the owner ticket belongs to the
# family of the employee who owns that ticket. The owner's emp_no comes straight
# from the owner row's Employee No column (the invoice Ref. No., emp_no_direct)
# — no LLM needed.
# Note: a family booking does NOT require CHD rows; spouse-only bookings are
# covered the same way.

_FAMILY_FOLDER_OWNER_RE = re.compile(r"^(\d{10})[ _]+family\b", re.IGNORECASE)

# process_batch stamps the trusted invoice Ref. No. into the Resolution Trace
# ("EMP_FROM_REF_NO: invoice Ref. No. emp_no=NNNNNNN trusted"). The Employee No
# CELL is mutable — later overlays (shared-OPEX, fuzzy manpower) may overwrite
# it with an unrelated requesting emp — so the trace is the authoritative source.
_REF_NO_TRACE_RE = re.compile(
    r"EMP_FROM_REF_NO:\s*invoice Ref\. No\. emp_no=(\d+)\s+trusted"
)

FAMILY_FOLDER_ADJ_RADIUS = 0


def _row_ref_no_emp(cascade_row: dict) -> str:
    m = _REF_NO_TRACE_RE.search(str(cascade_row.get("Resolution Trace", "") or ""))
    return m.group(1) if m else ""


VERIFIED_EMP_LOCK_FLAG = "VERIFIED_EMP_LOCK"
MISSING_EVIDENCE_FLAG = "MISSING_EVIDENCE"
ANCILLARY_EVENT_INHERITED_FLAG = "ANCILLARY_EVENT_ALLOCATION_INHERITED"
OPEX_EMAIL_ONLY_FLAG = "OPEX_EMAIL_ONLY"
BUNDLED_TICKET_SHARED_PDF_FLAG = "BUNDLED_TICKET_SHARED_PDF"
TICKET_SCAN_RE = re.compile(r"\b(\d{10})\b")
SHORT_REF_SCAN_RE = re.compile(r"\b(\d{2}-\d{3,})\b")
PNR_SCAN_RE = re.compile(r"(?<![A-Z0-9])([A-Z0-9]{6})(?![A-Z0-9])", re.IGNORECASE)
TRAILING_REF_RE = re.compile(r"\(([^)]+)\)\s*$")
INVOICE_BASENAME_RE = re.compile(r"INV(?:OICE)?", re.IGNORECASE)
_OPEX_PREFIX_RE = re.compile(r"^[A-Z]+-\d{4}-\d+-")
_TITLE_TOKENS = {"MR", "MRS", "MS", "DR", "ENG", "CHD", "INF", "INFANT"}
TRIP_PURPOSE_INHERIT_CONFIDENCE = 0.85
_BUNDLED_SHARED_HOST_RE = re.compile(
    rf"\b{re.escape(BUNDLED_TICKET_SHARED_PDF_FLAG)}:(\d{{10}})\b"
)


def _normalize_reference_token(token: str) -> str:
    token = str(token or "").strip()
    if re.fullmatch(r"\d{10}", token):
        return token
    if re.fullmatch(r"\d{2}-\d{3,}", token):
        return token
    if (
        re.fullmatch(r"[A-Z0-9]{6}", token, re.IGNORECASE)
        and re.search(r"[A-Z]", token, re.IGNORECASE)
        and re.search(r"\d", token)
    ):
        return token.upper()
    return ""


def _row_reference_token(cascade_row: dict) -> str:
    """Return the supported ref from the Description's trailing parenthetical."""
    desc = str(cascade_row.get("Description", "") or "")
    m = TRAILING_REF_RE.search(desc)
    return _normalize_reference_token(m.group(1)) if m else ""


def _reference_tokens_in_text(text: str) -> set[str]:
    refs = {m.group(1) for m in TICKET_SCAN_RE.finditer(text)}
    refs.update(m.group(1) for m in SHORT_REF_SCAN_RE.finditer(text))
    for m in PNR_SCAN_RE.finditer(text):
        token = _normalize_reference_token(m.group(1))
        if token:
            refs.add(token)
    return refs


def _master_emp_name(rec: dict) -> str:
    return str(
        rec.get("name_en", "") or rec.get("name", "") or rec.get("emp_name", "") or ""
    )


def _verify_emp_name_match(emp_no: str, passenger_desc: str, manpower: dict) -> bool:
    """Strongly verify invoice Ref.No. emp_no against the passenger name.

    Requires the Ref.No. employee to exist in Manpower, the passenger surname to
    appear in that employee's master name, and at least one given-name token
    (length >= 4) to appear too. Single-token matches are deliberately rejected.
    """
    emp_no = str(emp_no or "").strip()
    if not re.fullmatch(r"\d{7}", emp_no):
        return False
    rec = manpower.get(emp_no)
    if not rec:
        return False

    passenger = str(passenger_desc or "").strip()
    if " - " in passenger:
        passenger = passenger.split(" - ", 1)[0].strip()
    passenger = _OPEX_PREFIX_RE.sub("", passenger.upper()).strip()
    if not passenger:
        return False

    if "/" in passenger:
        surname_raw, given_raw = passenger.split("/", 1)
        surname = surname_raw.strip().split()[0] if surname_raw.strip() else ""
        given_tokens = [
            t for t in re.findall(r"[A-Z]+", given_raw)
            if len(t) >= 4 and t not in _TITLE_TOKENS
        ]
    else:
        tokens = [
            t for t in re.findall(r"[A-Z]+", passenger)
            if t not in _TITLE_TOKENS
        ]
        surname = tokens[0] if tokens else ""
        given_tokens = [t for t in tokens[1:] if len(t) >= 4]

    if not surname or not given_tokens:
        return False

    master_name = _master_emp_name(rec).upper()
    if not master_name:
        return False
    if not re.search(r"\b" + re.escape(surname) + r"\b", master_name):
        return False
    return any(
        re.search(r"\b" + re.escape(tok) + r"\b", master_name)
        for tok in given_tokens
    )


def row_verified_emp_locked(row: dict) -> bool:
    """True when a Ref.No. emp_no was name-verified and must not be overwritten."""
    if row.get("_verified_emp_lock"):
        return True
    return any(
        VERIFIED_EMP_LOCK_FLAG in str(row.get(k, "") or "")
        for k in ("_flags", "Agent Flags")
    )


def _append_hybrid_flag(row: dict, flag: str) -> None:
    if flag not in str(row.get("_flags", "") or ""):
        row["_flags"] = (str(row.get("_flags", "") or "") + " " + flag).strip()


def _append_row_flag(row: dict, key: str, flag: str) -> None:
    existing = str(row.get(key, "") or "").strip()
    if flag not in existing.split():
        row[key] = (existing + " " + flag).strip()


def apply_cc_account_override(hybrid_rows: list[dict]) -> int:
    applied = 0
    for i, row in enumerate(hybrid_rows):
        cc = str(row.get("cost_center", "") or "").strip()
        if cc not in CC_ACCOUNT_OVERRIDE:
            continue

        old = str(row.get("account", "") or "").strip()
        if old not in TRAVEL_TICKET_ACCOUNTS:
            continue
        if old in CC_ACCOUNT_OVERRIDE_SKIP_ACCOUNTS:
            continue
        if row.get("_missing_evidence") is True:
            continue

        new_account = CC_ACCOUNT_OVERRIDE[cc]
        if old == new_account:
            continue

        row["account"] = new_account
        row["_cc_account_override"] = True
        _append_hybrid_flag(row, "CC_ACCOUNT_OVERRIDE")
        _append_row_flag(row, "agent_flags", "CC_ACCOUNT_OVERRIDE")
        if row.get("_agent_method", "cascade") == "cascade":
            row["_agent_method"] = "hybrid_overlay"
        applied += 1
        print(
            f"  [cc-override] row {i+1}: CC={cc} → account {old} → {new_account}",
            flush=True,
        )

    print(f"[cc-override] {applied} rows → cost-center account override applied", flush=True)
    return applied


def build_ticket_folder_index(evidence_root: Path) -> set[str]:
    """Return supported Jawal refs found in evidence folder/file names."""
    index = set()
    if not evidence_root or not evidence_root.exists():
        return index
    invoice_skip_paths, invoice_skip_stems = _invoice_pdf_skip_set(evidence_root)
    for root, dirs, files in os.walk(evidence_root):
        for d in dirs:
            index.update(_reference_tokens_in_text(d))
        root_path = Path(root)
        for fname in files:
            file_path = root_path / fname
            if (
                file_path.resolve(strict=False) in invoice_skip_paths
                or file_path.stem.lower() in invoice_skip_stems
                or INVOICE_BASENAME_RE.search(file_path.stem)
            ):
                continue
            index.update(_reference_tokens_in_text(file_path.stem))
    return index


def _batch_id_from_path(path: Path) -> str:
    for part in path.parts:
        m = re.search(r"J26-\d+", part, re.IGNORECASE)
        if m:
            return m.group(0).upper()
    return ""


def _invoice_pdf_skip_set(evidence_root: Path) -> tuple[set[Path], set[str]]:
    """Known source invoice PDFs/stems that must never seed ticket evidence."""
    skip_paths: set[Path] = set()
    skip_stems: set[str] = set()
    if not evidence_root:
        return skip_paths, skip_stems

    batch_id = _batch_id_from_path(evidence_root)
    candidate_dirs: list[Path] = []
    for directory in [evidence_root, *evidence_root.parents]:
        candidate_dirs.append(directory)
        if batch_id and directory.name.upper() == batch_id:
            break
    if batch_id:
        candidate_dirs.extend([
            ROOT / "batches" / f"jawal-{batch_id}",
            VOLUME_BASE / batch_id,
        ])
    invoice_sources: list[Path] = []
    seen_dirs: set[Path] = set()
    for directory in candidate_dirs:
        directory = directory.resolve(strict=False)
        if directory in seen_dirs:
            continue
        seen_dirs.add(directory)
        if not directory.is_dir():
            continue
        invoice_sources.extend(
            p for p in directory.iterdir()
            if p.is_file()
            and p.suffix.lower() in {".xlsx", ".xls", ".pdf"}
            and (
                p.name == "invoice-source.xlsx"
                or INVOICE_BASENAME_RE.search(p.stem)
            )
        )

    for source in invoice_sources:
        source_resolved = source.resolve(strict=False)
        skip_stems.add(source.stem.lower())
        if source.suffix.lower() == ".pdf":
            skip_paths.add(source_resolved)
            continue
        for directory in candidate_dirs:
            if directory.is_dir():
                skip_paths.add((directory / f"{source.stem}.pdf").resolve(strict=False))
    return skip_paths, skip_stems


def _nested_below_root(path: Path, evidence_root: Path) -> bool:
    try:
        rel = path.relative_to(evidence_root)
    except ValueError:
        return False
    return len(rel.parts) > 1


def _should_scan_ticket_body_pdf(
    pdf_path: Path,
    evidence_root: Path,
    invoice_skip_paths: set[Path],
    invoice_skip_stems: set[str],
) -> bool:
    if not _nested_below_root(pdf_path, evidence_root):
        return False
    if pdf_path.resolve(strict=False) in invoice_skip_paths:
        return False
    if pdf_path.stem.lower() in invoice_skip_stems:
        return False
    if INVOICE_BASENAME_RE.search(pdf_path.stem):
        return False
    return True


def _pdf_ticket_body_numbers(pdf_path: Path, pdf_text_cache: dict[Path, set[str]]) -> set[str]:
    if pdf_path in pdf_text_cache:
        return pdf_text_cache[pdf_path]
    numbers: set[str] = set()
    try:
        import fitz  # pymupdf — primary in this pipeline (see full_evidence_agent)
        doc = fitz.open(str(pdf_path))
        try:
            text = "\n".join(page.get_text() for page in doc)
        finally:
            doc.close()
        numbers = _reference_tokens_in_text(text)
    except Exception as exc:
        print(f"[ticket-pdf-scan] WARNING: PDF read failed for {pdf_path}: {exc}", flush=True)
    pdf_text_cache[pdf_path] = numbers
    return numbers


def build_bundled_ticket_pdf_map(
    evidence_root: Path,
    pdf_text_cache: dict[Path, set[str]] | None = None,
) -> dict[str, str]:
    """Return {embedded_reference_token: host_pdf_path} from nested non-invoice PDFs."""
    bundled: dict[str, str] = {}
    if not evidence_root or not evidence_root.exists():
        return bundled
    cache = pdf_text_cache if pdf_text_cache is not None else {}
    invoice_skip_paths, invoice_skip_stems = _invoice_pdf_skip_set(evidence_root)
    for root, _dirs, files in os.walk(evidence_root):
        root_path = Path(root)
        for fname in files:
            if not fname.lower().endswith(".pdf"):
                continue
            pdf_path = root_path / fname
            if not _should_scan_ticket_body_pdf(
                pdf_path, evidence_root, invoice_skip_paths, invoice_skip_stems
            ):
                continue
            for ticket_no in sorted(_pdf_ticket_body_numbers(pdf_path, cache)):
                bundled.setdefault(ticket_no, str(pdf_path))
    return bundled


def _bundled_host_ticket_no(host_pdf_path: str) -> str:
    path = Path(host_pdf_path)
    m = TICKET_SCAN_RE.search(path.stem)
    if m:
        return m.group(1)
    for parent in [path.parent, *path.parents]:
        m = re.match(r"^(\d{10})", parent.name)
        if m:
            return m.group(1)
    return ""


def cascade_row_no_folder(cascade_row: dict, ticket_folder_index: set[str]) -> bool:
    """True when the row lacks evidence for its trailing Description reference."""
    desc = str(cascade_row.get("Description", "") or "")
    if re.search(r"\b(CHD|INF)\b", desc, re.IGNORECASE):
        return False
    ref_token = _row_reference_token(cascade_row)
    if not ref_token:
        return True
    return ref_token not in ticket_folder_index


def row_missing_evidence(row: dict) -> bool:
    if row.get("_missing_evidence_resolved"):
        return False
    flags = " ".join(str(row.get(k, "") or "") for k in ("_flags", "Agent Flags"))
    if ANCILLARY_EVENT_INHERITED_FLAG in flags:
        return False
    if row.get("_missing_evidence"):
        return True
    return any(
        MISSING_EVIDENCE_FLAG in str(row.get(k, "") or "")
        for k in ("_flags", "Agent Flags")
    )


def stamp_missing_evidence_gate(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    ticket_folder_index: set[str],
    bundled_ticket_pdf_map: dict[str, str] | None = None,
    direct_ticket_index: set[str] | None = None,
) -> int:
    gated = 0
    bundled_ticket_pdf_map = bundled_ticket_pdf_map or {}
    direct_ticket_index = direct_ticket_index or set()
    for i, c in enumerate(cascade_rows):
        if not cascade_row_no_folder(c, ticket_folder_index):
            ref_token = _row_reference_token(c)
            ticket_no = _row_ticket_no(c)
            if (
                re.fullmatch(r"\d{10}", ref_token or "")
                and ticket_no
                and ref_token in bundled_ticket_pdf_map
                and ref_token not in direct_ticket_index
            ):
                host_ticket = _bundled_host_ticket_no(bundled_ticket_pdf_map[ref_token])
                flag = (
                    f"{BUNDLED_TICKET_SHARED_PDF_FLAG}:{host_ticket}"
                    if host_ticket
                    else BUNDLED_TICKET_SHARED_PDF_FLAG
                )
                _append_hybrid_flag(hybrid_rows[i], flag)
                print(
                    f"[ticket-pdf-scan] row {i}: ticket {ticket_no} bundled in "
                    f"{bundled_ticket_pdf_map[ref_token]}",
                    flush=True,
                )
            continue
        h = hybrid_rows[i]
        h["_missing_evidence"] = True
        _append_hybrid_flag(h, MISSING_EVIDENCE_FLAG)
        for key in ("account", "cost_center", "div", "solution", "agency"):
            h[key] = ""
        if not row_verified_emp_locked(h):
            h["emp_no"] = ""
        if h.get("_agent_method", "cascade") == "cascade":
            h["_agent_method"] = "missing_evidence_gate"
        gated += 1
        print(f"[missing-evidence] row {i}: no folder - allocation blanked", flush=True)
    return gated


def stamp_verified_emp_locks(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    manpower: dict,
) -> int:
    locked = 0
    for i, c in enumerate(cascade_rows):
        desc = str(c.get("Description", "") or "")
        if re.search(r"\b(CHD|INF)\b", desc, re.IGNORECASE):
            continue
        emp_no = _row_ref_no_emp(c)
        if not emp_no or emp_no not in manpower:
            continue
        if not _verify_emp_name_match(emp_no, desc, manpower):
            continue
        h = hybrid_rows[i]
        h["_verified_emp_lock"] = True
        _append_hybrid_flag(h, VERIFIED_EMP_LOCK_FLAG)
        if str(h.get("account", "") or "").strip() == "60307021":
            old_emp_no = str(h.get("emp_no", "") or "").strip()
            h["account"] = "60301003"
            h["emp_no"] = emp_no
            _append_hybrid_flag(h, "VERIFIED_EMP_ACCOUNT_CORRECTED")
            rec = manpower.get(emp_no, {})
            if rec:
                h["cost_center"] = _norm_master_code(rec.get("cost_center", ""), "cc")
                h["div"]         = _norm_master_code(rec.get("div_code", ""), "div")
                h["solution"]    = _norm_master_code(rec.get("solution", ""), "solution") or "00000"
                h["agency"]      = _norm_master_code(rec.get("agency_code", ""), "agency")
                _append_hybrid_flag(h, "VERIFIED_EMP_SEGMENTS_CORRECTED")
                print(
                    f"[verified-lock] row {i}: emp_no {emp_no} segments corrected "
                    f"from master (was requestor {old_emp_no})",
                    flush=True,
                )
            print(
                f"[verified-lock] row {i}: emp_no {emp_no} account corrected "
                "60307021 -> 60301003 (employee cannot be sponsorship)",
                flush=True,
            )
        locked += 1
        print(f"[verified-lock] row {i}: emp_no {emp_no} name-matched -> locked", flush=True)
    return locked


def apply_family_cluster_unification_verified_safe(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
) -> int:
    """Run imported cluster unification without exposing locked row dicts."""
    work_rows = [
        h.copy() if (row_verified_emp_locked(h) or row_missing_evidence(h)) else h
        for h in hybrid_rows
    ]
    before = [
        str(hybrid_rows[i].get("emp_no", "") or "").strip()
        for i, h in enumerate(hybrid_rows)
        if not row_verified_emp_locked(h) and not row_missing_evidence(h)
    ]
    apply_family_cluster_unification(work_rows, cascade_rows)
    after = [
        str(hybrid_rows[i].get("emp_no", "") or "").strip()
        for i, h in enumerate(hybrid_rows)
        if not row_verified_emp_locked(h) and not row_missing_evidence(h)
    ]
    return sum(1 for old, new in zip(before, after) if old != new)


def _row_ticket_no(cascade_row: dict) -> str:
    ref_token = _row_reference_token(cascade_row)
    if re.fullmatch(r"\d{10}", ref_token or ""):
        return ref_token
    text = str(cascade_row.get("Notes", "") or "")
    m = re.search(r"\b(\d{10})\b", text)
    return m.group(1) if m else ""


def _bundled_shared_host_from_flags(row: dict, cascade_row: dict | None = None) -> str:
    """Return host ticket from BUNDLED_TICKET_SHARED_PDF:<ticket>, if present."""
    flag_text = " ".join(
        str(v or "")
        for v in (
            row.get("_flags", ""),
            row.get("Agent Flags", ""),
            cascade_row.get("Agent Flags", "") if cascade_row else "",
        )
    )
    m = _BUNDLED_SHARED_HOST_RE.search(flag_text)
    return m.group(1) if m else ""


def _trip_confidence(cascade_row: dict) -> float:
    try:
        return float(cascade_row.get("Trip Purpose Confidence", 0) or 0)
    except (TypeError, ValueError):
        return 0.0


def _row_has_own_confident_trip_purpose(cascade_row: dict) -> bool:
    purpose = str(cascade_row.get("Trip Purpose", "") or "").strip().upper()
    if purpose in ("", "UNKNOWN"):
        return False
    return _trip_confidence(cascade_row) >= TRIP_PURPOSE_INHERIT_CONFIDENCE


def _row_is_default_trip_purpose(cascade_row: dict, hybrid_row: dict) -> bool:
    """True when the row has no account-driving trip-purpose signal of its own."""
    purpose = str(cascade_row.get("Trip Purpose", "") or "").strip().upper()
    override = str(cascade_row.get("Trip Account Override", "") or "").strip()
    account = str(hybrid_row.get("account", "") or "").strip()
    if purpose in ("", "UNKNOWN"):
        return True
    if override.isdigit():
        return False
    return account in ("", *TRAVEL_TICKET_ACCOUNTS) and not _row_has_own_confident_trip_purpose(cascade_row)


def _host_has_confident_account_driving_trip_purpose(
    cascade_row: dict,
    hybrid_row: dict,
) -> bool:
    purpose = str(cascade_row.get("Trip Purpose", "") or "").strip().upper()
    if purpose in ("", "UNKNOWN"):
        return False
    if _trip_confidence(cascade_row) < TRIP_PURPOSE_INHERIT_CONFIDENCE:
        return False
    account = str(hybrid_row.get("account", "") or "").strip()
    override = str(cascade_row.get("Trip Account Override", "") or "").strip()
    if override.isdigit() and account == override:
        return True
    return account not in ("", *TRAVEL_TICKET_ACCOUNTS)


def apply_bundled_shared_pdf_trip_purpose_inheritance(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
) -> int:
    """Propagate final host trip purpose/account to bundled child ticket rows.

    The bundled rescue proves the child ticket came from the host ticket's PDF,
    but the child may have no OPEX form of its own. In that case it should share
    the host's purpose-derived account while keeping employee/master segments.
    """
    host_by_ticket = {
        ticket: i
        for i, c in enumerate(cascade_rows)
        if (ticket := _row_ticket_no(c))
    }
    inherited = 0
    for i, c in enumerate(cascade_rows):
        child = hybrid_rows[i]
        host_ticket = _bundled_shared_host_from_flags(child, c)
        if not host_ticket:
            continue
        if row_missing_evidence(child):
            continue
        verified_emp_locked = row_verified_emp_locked(child)
        if row_family_annual_locked(child):
            continue
        if _row_has_own_confident_trip_purpose(c) or not _row_is_default_trip_purpose(c, child):
            continue
        host_i = host_by_ticket.get(host_ticket)
        if host_i is None or host_i == i:
            continue
        host_c = cascade_rows[host_i]
        host_h = hybrid_rows[host_i]
        if not _host_has_confident_account_driving_trip_purpose(host_c, host_h):
            continue
        host_account = str(host_h.get("account", "") or "").strip()
        if not host_account:
            continue

        old_account = str(child.get("account", "") or "").strip()
        child["account"] = host_account
        if child.get("_agent_method", "cascade") == "cascade":
            child["_agent_method"] = "hybrid_overlay"
        _append_hybrid_flag(child, f"INHERITED_TRIP_PURPOSE_FROM_HOST:{host_ticket}")
        _append_hybrid_flag(child, "INHERITED_ACCOUNT_FROM_HOST")
        if verified_emp_locked:
            _append_hybrid_flag(child, "INHERITED_ACCOUNT_OVERRIDES_VERIFIED_CORRECTION")

        inherited_purpose = str(host_c.get("Trip Purpose", "") or "").strip()
        inherited_conf = _trip_confidence(host_c)
        inherited_trace = (
            f"inherited from bundled shared PDF host {host_ticket}: "
            f"{host_c.get('Trip Purpose Trace', '')}"
        ).strip()
        c["Trip Purpose"] = inherited_purpose
        c["Trip Purpose Confidence"] = inherited_conf
        c["Trip Account Override"] = host_account
        c["Trip Purpose Trace"] = inherited_trace
        child["_inherited_trip_purpose"] = {
            "Trip Purpose": inherited_purpose,
            "Trip Purpose Confidence": inherited_conf,
            "Trip Account Override": host_account,
            "Trip Purpose Trace": inherited_trace,
        }
        inherited += 1
        print(
            f"  [bundled-trip-inherit] row {i+1}: ticket {_row_ticket_no(c) or '?'} "
            f"inherited {inherited_purpose}/{host_account} from host {host_ticket} "
            f"(account {old_account or '?'} -> {host_account})",
            flush=True,
        )
    return inherited


def _row_passenger_tokens(cascade_row: dict) -> set[str]:
    desc = str(cascade_row.get("Description", "") or "")
    head = desc.split(" - ", 1)[0].upper()
    head = _OPEX_PREFIX_RE.sub("", head).strip()
    head = re.sub(r"\((?:CHD|INF)\)", " ", head, flags=re.IGNORECASE)
    return {
        tok
        for tok in re.findall(r"[A-Z]{3,}", head)
        if tok not in _TITLE_TOKENS
    }


def _passenger_tokens_match(a: set[str], b: set[str]) -> bool:
    if not a or not b:
        return False
    shared = a.intersection(b)
    if len(shared) >= 2:
        return True
    # Airline descriptions normally provide SURNAME/GIVEN. A single shared
    # surname is not enough to merge colleagues, so require all tokens on the
    # shorter side when one side is sparse.
    return len(shared) == min(len(a), len(b)) and min(len(a), len(b)) >= 2


def _pdf_text(path: Path) -> str:
    try:
        import fitz
        with fitz.open(str(path)) as doc:
            return "\n".join(page.get_text() for page in doc)
    except Exception:
        return ""


def _itinerary_pdf_evidence(folder: Path | None, host_ticket: str) -> list[dict]:
    if not folder or not folder.exists() or not host_ticket:
        return []
    evidence = []
    for pdf in sorted(folder.glob("*.pdf")):
        text = _pdf_text(pdf)
        if host_ticket not in text:
            continue
        tickets = {m.group(1) for m in TICKET_SCAN_RE.finditer(text)}
        if len(tickets) < 2:
            continue
        booking_refs = _reference_tokens_in_text(text) - tickets
        if not booking_refs:
            continue
        evidence.append({
            "pdf": str(pdf),
            "tickets": tickets,
            "booking_refs": booking_refs,
        })
    return evidence


def apply_sibling_leg_trip_purpose_inheritance(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
) -> int:
    """Propagate an own-form trip classification to sibling legs in one itinerary.

    The source leg must own an approved form and its itinerary PDF must list the
    sibling ticket(s) plus at least one booking/PNR reference. The target leg must
    share passenger tokens and be otherwise default/unclassified.
    """
    host_by_ticket = {
        ticket: i
        for i, c in enumerate(cascade_rows)
        if (ticket := _row_ticket_no(c))
    }
    inherited = 0
    for host_i, host_h in enumerate(hybrid_rows):
        trip = host_h.get("_own_form_trip_purpose") or {}
        host_ticket = _row_ticket_no(cascade_rows[host_i])
        host_account = str(trip.get("account_override") or host_h.get("account", "") or "").strip()
        folder_text = str(trip.get("folder", "") or host_h.get("_evidence_folder", "") or "").strip()
        folder = Path(folder_text) if folder_text else None
        if not host_ticket or not host_account:
            continue
        if not _host_has_confident_account_driving_trip_purpose(cascade_rows[host_i], host_h):
            continue
        host_tokens = _row_passenger_tokens(cascade_rows[host_i])
        for ev in _itinerary_pdf_evidence(folder, host_ticket):
            for sibling_ticket in sorted(ev["tickets"] - {host_ticket}):
                sib_i = host_by_ticket.get(sibling_ticket)
                if sib_i is None or sib_i == host_i:
                    continue
                sib_h = hybrid_rows[sib_i]
                sib_c = cascade_rows[sib_i]
                if row_missing_evidence(sib_h) or row_family_annual_locked(sib_h):
                    continue
                if _row_has_own_confident_trip_purpose(sib_c):
                    continue
                if not _row_is_default_trip_purpose(sib_c, sib_h):
                    continue
                if not _passenger_tokens_match(host_tokens, _row_passenger_tokens(sib_c)):
                    continue

                old_account = str(sib_h.get("account", "") or "").strip()
                sib_h["account"] = host_account
                for key in ("emp_no", "cost_center", "div", "solution", "agency"):
                    value = str(host_h.get(key, "") or "").strip()
                    if value:
                        sib_h[key] = value
                if sib_h.get("_agent_method", "cascade") == "cascade":
                    sib_h["_agent_method"] = "hybrid_overlay"
                _append_hybrid_flag(sib_h, f"INHERITED_TRIP_PURPOSE_FROM_SIBLING:{host_ticket}")
                _append_hybrid_flag(sib_h, "INHERITED_ACCOUNT_FROM_SIBLING")
                purpose = str(cascade_rows[host_i].get("Trip Purpose", "") or trip.get("purpose", "")).strip()
                conf = _trip_confidence(cascade_rows[host_i]) or float(trip.get("confidence") or 0)
                trace = (
                    f"inherited from sibling itinerary host {host_ticket}; "
                    f"booking_refs={','.join(sorted(ev['booking_refs']))}; "
                    f"pdf={Path(ev['pdf']).name}"
                )
                sib_c["Trip Purpose"] = purpose
                sib_c["Trip Purpose Confidence"] = conf
                sib_c["Trip Account Override"] = host_account
                sib_c["Trip Purpose Trace"] = trace
                sib_h["_inherited_trip_purpose"] = {
                    "Trip Purpose": purpose,
                    "Trip Purpose Confidence": conf,
                    "Trip Account Override": host_account,
                    "Trip Purpose Trace": trace,
                }
                inherited += 1
                print(
                    f"  [sibling-trip-inherit] row {sib_i+1}: ticket {sibling_ticket} "
                    f"inherited {purpose}/{host_account} from sibling {host_ticket} "
                    f"(account {old_account or '?'} -> {host_account})",
                    flush=True,
                )
    return inherited


def build_family_folder_emp_map(
    all_folders: list[Path],
    cascade_rows: list[dict],
    manpower: dict,
) -> dict[str, str]:
    """
    Scan folder NAMES (no content scanning) for the "<ticket> family" pattern
    and resolve each owner ticket to its employee via the owner row's
    Employee No column, validated against master.

    Returns {owner_ticket: emp_no}.
    """
    owners: dict[str, str] = {}
    for folder in all_folders:
        m = _FAMILY_FOLDER_OWNER_RE.match(folder.name.strip())
        if not m:
            continue
        owner_ticket = m.group(1)
        for c in cascade_rows:
            if _row_ticket_no(c) != owner_ticket:
                continue
            # Prefer the invoice Ref. No. preserved in the Resolution Trace —
            # the Employee No cell may have been overwritten by a later overlay
            # (e.g. shared-OPEX stamping a nearby event's requesting emp).
            ref_emp = _row_ref_no_emp(c)
            cell_emp = str(c.get("Employee No", "") or "").strip()
            emp, source = (ref_emp, "invoice Ref. No. via Resolution Trace") \
                if ref_emp and ref_emp in manpower else (cell_emp, "emp_no_direct from invoice")
            if ref_emp and cell_emp and ref_emp != cell_emp:
                print(f"[family-folder] WARNING owner ticket {owner_ticket}: "
                      f"Employee No cell={cell_emp} disagrees with Ref. No. "
                      f"trace={ref_emp} — trusting Ref. No.", flush=True)
            if emp and emp not in ("0", "-") and emp in manpower:
                owners[owner_ticket] = emp
                print(f"[family-folder] '{folder.name}' → owner ticket {owner_ticket} "
                      f"→ emp_no {emp} ({source})", flush=True)
            break
    return owners


def apply_family_folder_emp_rule(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    family_owner_map: dict[str, str],
    adj_radius: int = FAMILY_FOLDER_ADJ_RADIUS,
) -> int:
    """
    Stamp the family-folder owner's emp_no on rows whose ticket number exactly
    matches the family-folder owner ticket. Deterministic — runs after
    the LLM / cluster stages and has final authority on emp_no for these rows.
    Flags each row EMP_FROM_FAMILY_FOLDER. Returns count of rows changed.
    """
    if not family_owner_map:
        return 0
    stamped = 0
    for i, c in enumerate(cascade_rows):
        if row_missing_evidence(hybrid_rows[i]):
            continue
        if row_verified_emp_locked(hybrid_rows[i]):
            continue
        ticket = _row_ticket_no(c)
        if not ticket:
            continue
        owner = ticket if ticket in family_owner_map else None
        if owner is None:
            continue
        emp = family_owner_map[owner]
        if "EMP_FROM_FAMILY_FOLDER" not in str(hybrid_rows[i].get("_flags", "")):
            hybrid_rows[i]["_flags"] = str(
                hybrid_rows[i].get("_flags", "") + " EMP_FROM_FAMILY_FOLDER"
            ).strip()
        if str(hybrid_rows[i].get("emp_no", "") or "").strip() != emp:
            desc = str(c.get("Description", "") or "")[:60]
            print(f"[family-folder] row {i} ({desc}): emp_no "
                  f"{hybrid_rows[i].get('emp_no', '')!r} → {emp} "
                  f"(family folder of ticket {owner})", flush=True)
            hybrid_rows[i]["emp_no"] = emp
            # v25_-prefixed so the stage-4 rename maps it to llm_agent and the
            # writer persists the emp_no override to the output xlsx.
            hybrid_rows[i]["_agent_method"] = "v25_family_folder"
            hybrid_rows[i]["_route_reason"] = "FAMILY_FOLDER_EMP"
            stamped += 1
    return stamped


# ─── family annual-ticket GL rule (Labadi, 2026-06-10) ───────────────────────
# Personal/family annual-leave travel routes to 21070229 (Accrued Employee
# Annual Tickets). Stage 3h already pins family rows to the sponsor employee's
# emp_no; this stage routes their ACCOUNT. Triggers (generic):
#   (a) the row's ticket is the owner ticket of a "<ticket> family" folder, OR
#   (b) the row's description carries a CHD/INF marker AND its settled emp_no
#       matches a non-CHD (parent) row on the same invoice — the whole emp_no
#       group then forms the family annual group (mirrors the process_batch
#       CHD-confirmed cluster flip).
# Only plain travel-ticket rows flip (account empty / 60301003); sponsorship
# (60307021), training and every other GL are never touched.

_CHD_INF_RE = re.compile(r"\((CHD|INF)\)", re.IGNORECASE)
FAMILY_FLIPPABLE_ACCOUNTS = {"", "60301003"}

FAMILY_ANNUAL_LOCK_FLAG = "FAMILY_ANNUAL_LOCKED"


def row_family_annual_locked(row: dict) -> bool:
    """True when stage 3i finalised this row's account + segments.

    Checks the in-memory lock key and the persisted flag (hybrid `_flags` /
    xlsx "Agent Flags") so the lock survives the write-then-reread passes
    (booking-group propagation reads the output xlsx, not hybrid_rows).
    """
    if row.get("_family_annual_locked"):
        return True
    return any(
        FAMILY_ANNUAL_LOCK_FLAG in str(row.get(k, "") or "")
        for k in ("_flags", "Agent Flags")
    )


def _family_folder_paths(all_folders: list[Path]) -> dict[str, Path]:
    """{owner_ticket: folder} for every '<ticket> family' evidence folder."""
    paths = {}
    for folder in all_folders:
        m = _FAMILY_FOLDER_OWNER_RE.match(folder.name.strip())
        if m:
            paths[m.group(1)] = folder
    return paths


def _effective_account(hyb: dict, c: dict) -> str:
    acct = str(hyb.get("account", "") or "").strip()
    return acct or str(c.get("Account", "") or "").strip()


def _effective_emp(hyb: dict, c: dict) -> str:
    emp = str(hyb.get("emp_no", "") or "").strip()
    return emp or str(c.get("Employee No", "") or "").strip()


def _row_passenger_family_tokens(cascade_row: dict) -> set[str]:
    desc = str(cascade_row.get("Description", "") or "")
    passenger = desc.split(" - ", 1)[0].upper()
    passenger = re.sub(r"\((?:CHD|INF)\)", " ", passenger, flags=re.IGNORECASE)
    if "/" in passenger:
        surname_part = passenger.split("/", 1)[0]
    else:
        surname_part = passenger
    return {
        tok
        for tok in re.findall(r"[A-Z]{3,}", surname_part)
        if tok not in _TITLE_TOKENS
    }


def _row_family_folder_owner(row: dict) -> str:
    folder_text = str(row.get("_evidence_folder", "") or "")
    if not folder_text:
        return ""
    m = _FAMILY_FOLDER_OWNER_RE.match(Path(folder_text).name.strip())
    return m.group(1) if m else ""


def _row_booking_pnr(row: dict, cascade_row: dict) -> str:
    for source in (
        row.get("_booking_pnr", ""),
        row.get("Booking PNR", ""),
        cascade_row.get("Booking PNR", ""),
        cascade_row.get("PNR", ""),
        cascade_row.get("Resolution Trace", ""),
    ):
        m = re.search(r"\b[A-Z0-9]{6}\b", str(source or "").upper())
        if m and not m.group(0).isdigit():
            return m.group(0)
    return ""


def _chd_family_related(
    chd_idx: int,
    parent_idx: int,
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
) -> bool:
    chd_pnr = _row_booking_pnr(hybrid_rows[chd_idx], cascade_rows[chd_idx])
    parent_pnr = _row_booking_pnr(hybrid_rows[parent_idx], cascade_rows[parent_idx])
    if chd_pnr and parent_pnr and chd_pnr == parent_pnr:
        return True

    chd_family = _row_family_folder_owner(hybrid_rows[chd_idx])
    parent_family = _row_family_folder_owner(hybrid_rows[parent_idx])
    if not chd_family or chd_family != parent_family:
        return False

    chd_tokens = _row_passenger_family_tokens(cascade_rows[chd_idx])
    parent_tokens = _row_passenger_family_tokens(cascade_rows[parent_idx])
    return bool(chd_tokens and parent_tokens and chd_tokens.intersection(parent_tokens))


def collect_family_annual_rows(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    family_owner_map: dict[str, str],
    adj_radius: int = FAMILY_FOLDER_ADJ_RADIUS,
) -> dict[int, tuple[str, str]]:
    """Return {row_index: (owner_emp_no, trigger)} for all family annual rows."""
    fam: dict[int, tuple[str, str]] = {}

    # (a) explicit family-folder rows. The folder owner emp is deterministic
    # evidence for rows whose evidence folder is that same family folder.
    if family_owner_map:
        for i, c in enumerate(cascade_rows):
            if row_missing_evidence(hybrid_rows[i]):
                continue
            ticket = _row_ticket_no(c)
            owner = ticket if ticket in family_owner_map else _row_family_folder_owner(hybrid_rows[i])
            if owner and owner in family_owner_map:
                fam[i] = (family_owner_map[owner], f"family_folder:{owner}")

    # (b) CHD/INF rows sharing the settled emp_no with a non-CHD parent row.
    # The emp_no alone is not evidence; earlier overlays can contaminate it.
    # Require a same PNR or same family folder plus surname-compatible tokens.
    emp_rows: dict[str, list[int]] = {}
    for i, c in enumerate(cascade_rows):
        if row_missing_evidence(hybrid_rows[i]):
            continue
        if row_verified_emp_locked(hybrid_rows[i]):
            continue
        emp = _effective_emp(hybrid_rows[i], c)
        if emp and emp not in ("0", "-"):
            emp_rows.setdefault(emp, []).append(i)
    for emp, idxs in emp_rows.items():
        if len(idxs) < 2:
            continue
        chd = [i for i in idxs
               if _CHD_INF_RE.search(str(cascade_rows[i].get("Description", "") or ""))]
        if not chd or len(chd) == len(idxs):
            continue  # need a CHD/INF dependent AND a non-CHD parent row
        parents = [i for i in idxs if i not in chd]
        related: set[int] = set()
        for child_idx in chd:
            child_parents = [
                parent_idx for parent_idx in parents
                if _chd_family_related(child_idx, parent_idx, hybrid_rows, cascade_rows)
            ]
            if child_parents:
                related.add(child_idx)
                related.update(child_parents)
        for i in sorted(related):
            fam.setdefault(i, (emp, f"chd_empno_group:{emp}"))

    return fam


def apply_family_annual_account_rule(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    fam_rows: dict[int, tuple[str, str]],
    manpower: dict,
) -> int:
    """Route family annual rows to account 21070229 and stamp annual segments.

    Already-21070229 rows get the segment stamp too (they previously skipped
    it, leaving General/propagated segments on correctly-routed rows). Every
    processed row is marked _family_annual_locked so no downstream stage
    (booking-group propagation, cluster unification, PC overlays) may rewrite
    its account or segments. Returns count of rows whose account flipped.
    """
    flipped = 0
    for i, (owner_emp, trigger) in sorted(fam_rows.items()):
        c = cascade_rows[i]
        hyb = hybrid_rows[i]
        hyb["_family_annual"] = trigger
        if row_missing_evidence(hyb):
            continue
        if row_family_annual_locked(hyb):
            continue  # already processed (rerun safety)
        acct = _effective_account(hyb, c)
        if acct == "21070229":
            account_flipped = False  # already routed — segments still need stamping
        elif acct in FAMILY_FLIPPABLE_ACCOUNTS:
            account_flipped = True
        else:
            continue  # never touch sponsorship/training/other GLs

        hyb["account"] = "21070229"

        # CC/DIV/Agency come from the sponsor's Manpower home record. Solution
        # stays general for annual-ticket rows.
        rec = manpower.get(owner_emp, {})
        _stamp_21070229_home_segments(hyb, rec)
        if not rec and not str(hyb.get("cost_center", "") or "").strip():
            hyb["cost_center"] = str(c.get("Cost Center", "") or "").strip()

        if not row_verified_emp_locked(hyb) and not str(hyb.get("emp_no", "") or "").strip():
            hyb["emp_no"] = owner_emp

        # Lock — downstream segment-mutating stages must skip this row.
        hyb["_family_annual_locked"] = True
        for flag in ("FAMILY_ANNUAL_TICKET_GL", FAMILY_ANNUAL_LOCK_FLAG):
            if flag not in str(hyb.get("_flags", "")):
                hyb["_flags"] = (str(hyb.get("_flags", "")) + " " + flag).strip()
        # v25_-prefixed so the stage-4 rename maps it to llm_agent and the
        # writer persists account/segments + rebuilt combo to the output xlsx.
        hyb["_agent_method"] = "v25_family_annual"

        desc = str(c.get("Description", "") or "")[:60]
        if account_flipped:
            print(f"[family-annual] row {i} ({desc}): account {acct or '(blank)'} → "
                  f"21070229 ({trigger})", flush=True)
            flipped += 1
        else:
            print(f"[family-annual] row {i} ({desc}): already 21070229 — "
                  f"segments stamped + locked ({trigger})", flush=True)
    return flipped


def stamp_verified_annual_home_segments(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
    manpower: dict,
) -> int:
    """Stamp home segments on settled 21070229 rows with a verified owner emp."""
    stamped = 0
    for i, hyb in enumerate(hybrid_rows):
        acct = _effective_account(hyb, cascade_rows[i])
        if acct != "21070229":
            continue
        emp = _effective_emp(hyb, cascade_rows[i]) or _row_ref_no_emp(cascade_rows[i])
        rec = manpower.get(emp) if emp else None
        if not rec:
            continue
        before = (
            str(hyb.get("cost_center", "") or ""),
            str(hyb.get("div", "") or ""),
            str(hyb.get("solution", "") or ""),
            str(hyb.get("agency", "") or ""),
        )
        hyb["account"] = "21070229"
        _stamp_21070229_home_segments(hyb, rec)
        if not str(hyb.get("emp_no", "") or "").strip():
            hyb["emp_no"] = emp
        after = (
            str(hyb.get("cost_center", "") or ""),
            str(hyb.get("div", "") or ""),
            str(hyb.get("solution", "") or ""),
            str(hyb.get("agency", "") or ""),
        )
        if before != after:
            _append_hybrid_flag(hyb, "ANNUAL_HOME_SEGMENTS_STAMPED")
            if hyb.get("_agent_method", "cascade") == "cascade":
                hyb["_agent_method"] = "hybrid_overlay"
            stamped += 1
    return stamped


_ANCILLARY_EVENT_RE = re.compile(
    r"\b(HOTEL|TRANSFER|PICK\s*UP|DROP\s*OFF|AIRPORT|GROUND\s*TRANSPORT|TRANSPORT)\b",
    re.IGNORECASE,
)


def _normalised_attendee(desc: str) -> str:
    head = str(desc or "").split(" - ", 1)[0]
    head = re.sub(r"^\s*[A-Z]+-\d{4}-\d+\s+", "", head, flags=re.IGNORECASE)
    head = re.sub(r"\((?:CHD|INF)\)", " ", head, flags=re.IGNORECASE)
    tokens = [
        t for t in re.findall(r"[A-Z]{3,}", head.upper())
        if t not in _TITLE_TOKENS
    ]
    return " ".join(sorted(set(tokens)))


def inherit_ancillary_event_allocations(
    hybrid_rows: list[dict],
    cascade_rows: list[dict],
) -> int:
    """Let missing ancillary rows inherit resolved OPEX event allocation by attendee."""
    event_by_attendee: dict[str, dict] = {}
    for i, row in enumerate(hybrid_rows):
        if str(row.get("account", "") or "").strip() != "60307021":
            continue
        serial = str(row.get("_opex_serial", "") or cascade_rows[i].get("OPEX Serial", "") or "").strip()
        if serial.upper() in {"", "MISSING", "N/A", "NONE"}:
            serial = _extract_serial_from_text(str(row.get("_evidence_folder", "") or ""))
        if serial.upper() in {"", "MISSING", "N/A", "NONE"}:
            continue
        attendee = _normalised_attendee(str(cascade_rows[i].get("Description", "") or ""))
        if not attendee:
            continue
        event_by_attendee.setdefault(attendee, {
            "account": "60307021",
            "emp_no": str(row.get("emp_no", "") or "").strip(),
            "cost_center": str(row.get("cost_center", "") or "").strip(),
            "div": str(row.get("div", "") or "").strip(),
            "solution": str(row.get("solution", "") or "").strip(),
            "agency": str(row.get("agency", "") or "").strip(),
            "_opex_serial": serial,
            "_evidence_folder": str(row.get("_evidence_folder", "") or "").strip(),
        })

    inherited = 0
    for i, row in enumerate(hybrid_rows):
        if not row_missing_evidence(row):
            continue
        desc = str(cascade_rows[i].get("Description", "") or "")
        if not _ANCILLARY_EVENT_RE.search(desc):
            continue
        event = event_by_attendee.get(_normalised_attendee(desc))
        if not event:
            continue
        for key, value in event.items():
            if value:
                row[key] = value
        row["_missing_evidence"] = False
        row["_flags"] = " ".join(
            flag for flag in str(row.get("_flags", "") or "").split()
            if flag != MISSING_EVIDENCE_FLAG
        ).strip()
        row["_agent_method"] = "v25_ancillary_event_inheritance"
        row["_route_reason"] = "ANCILLARY_EVENT_ATTENDEE_MATCH"
        _append_hybrid_flag(row, "ANCILLARY_EVENT_ALLOCATION_INHERITED")
        inherited += 1
        print(
            f"[ancillary-event] row {i+1}: inherited {event.get('_opex_serial')} "
            f"allocation for attendee {_normalised_attendee(desc)}",
            flush=True,
        )
    return inherited


_MAI_RE_EN = re.compile(r"\bmai\b", re.IGNORECASE)
_MAI_RE_AR = re.compile(r"(?<![؀-ۿ])مي(?![؀-ۿ])")


def evaluate_family_dual_approval(folder: Path | None) -> tuple[str, str]:
    """RULE 5 — Mai (HR) + Sanad approval presence from a family folder's emails.

    process_batch evaluates Mai/Sanad from the parsed OPEX form, but family
    annual rows have no OPEX form — their approvals live in the .msg files of
    the family evidence folder. Same detectors as process_batch: word-bounded
    'Mai' (EN/AR) for HR; 'sanad'/'abdullah'/'سند' for Sanad.
    """
    mai_ok = sanad_ok = False
    if folder and Path(folder).is_dir():
        try:
            from msg_parser import parse_msg
        except ImportError:
            parse_msg = None
        if parse_msg:
            for msg in sorted(Path(folder).glob("*.msg")):
                try:
                    p = parse_msg(str(msg))
                except Exception:
                    continue
                if not isinstance(p, dict):
                    continue
                parts = [str(p.get(k, "") or "")
                         for k in ("subject", "body_text", "sender", "to", "cc")]
                parts.extend(str(a) for a in (p.get("attachment_names") or []))
                blob = " ".join(parts)
                low = blob.lower()
                if _MAI_RE_EN.search(blob) or _MAI_RE_AR.search(blob):
                    mai_ok = True
                if ("sanad" in low) or ("abdullah" in low) or ("سند" in blob):
                    sanad_ok = True
    return ("OK" if mai_ok else "MISSING", "OK" if sanad_ok else "MISSING")


# ─── booking-group inline (origin: v24) ──────────────────────────────────────

def apply_booking_groups_inline_v25(out_xlsx: Path) -> tuple[int, int]:
    """
    Thin wrapper around v24's apply_booking_groups_inline with VERSION=v30.
    (We can't call v24's function directly because it uses v24's VERSION constant.)
    """
    import copy
    print(f"\n[booking-groups] scanning for family groups...", flush=True)
    headers, rows, hdr_row = read_xlsx_rows(out_xlsx)

    combo_hdr = next((h for h in headers if h and "distribution combination" in str(h).lower()), None)
    acct_hdr  = next((h for h in headers if h and str(h).strip().lower() == "account"), None)
    cc_hdr    = next((h for h in headers if h and "cost center" in str(h).lower()), None)
    div_hdr   = next((h for h in headers if h and str(h).strip().lower() == "div"), None)
    sol_hdr   = next((h for h in headers if h and str(h).strip().lower() == "solution"), None)
    ag_hdr    = next((h for h in headers if h and str(h).strip().lower() == "agency"), None)
    loc_hdr   = next((h for h in headers if h and str(h).strip().lower() == "location"), None)
    co_hdr    = next((h for h in headers if h and str(h).strip().lower() == "company"), None)

    def _pad(v, w):
        s = str(v or "").strip()
        return s.zfill(w) if s.isdigit() else (s or "0"*w)

    combos_fixed = 0
    if combo_hdr and acct_hdr:
        for row in rows:
            if row_missing_evidence(row):
                continue
            if row_verified_emp_locked(row):
                continue
            existing_combo = str(row.get(combo_hdr, "") or "")
            acct = str(row.get(acct_hdr, "") or "").strip()
            if not acct or not existing_combo:
                continue
            parts = existing_combo.split("-")
            combo_acct = (parts[2].strip() if len(parts) > 2 else "").lstrip("0") or "0"
            clean_acct = acct.lstrip("0") or "0"
            if combo_acct != clean_acct:
                co  = str(row.get(co_hdr, "03") or "03").strip() or "03"
                loc = str(row.get(loc_hdr, "") or "").strip() or (parts[1] if len(parts) > 1 else "20100")
                cc  = str(row.get(cc_hdr, "") or "").strip() or (parts[3] if len(parts) > 3 else "000000")
                div = str(row.get(div_hdr, "") or "").strip() or (parts[4] if len(parts) > 4 else "000")
                sol = str(row.get(sol_hdr, "") or "").strip() or (parts[5] if len(parts) > 5 else "00000")
                ag  = str(row.get(ag_hdr, "") or "").strip() or (parts[6] if len(parts) > 6 else "00000")
                proj = parts[7] if len(parts) > 7 else "00000"
                ic   = parts[8] if len(parts) > 8 else "00"
                f1   = parts[9] if len(parts) > 9 else "000000"
                row[combo_hdr] = (
                    f"{_pad(co,2)}-{_pad(loc,5)}-{_pad(acct,8)}-{_pad(cc,6)}-{_pad(div,3)}"
                    f"-{_pad(sol,5)}-{_pad(ag,5)}-{_pad(proj,5)}-{_pad(ic,2)}-{_pad(f1,6)}"
                )
                # Flag as high-confidence PC anchor when account=21070229
                if acct.lstrip("0") == "21070229".lstrip("0") or acct == "21070229":
                    row["_pc_resynced"] = True
                combos_fixed += 1
    if combos_fixed:
        print(f"[booking-groups] {combos_fixed} combo(s) synced from Account column (PC override fix)", flush=True)

    orig_rows = copy.deepcopy(rows)
    groups = build_booking_groups(rows)
    family_groups = [g for g in groups if _is_family_group(g, rows)]
    skipped       = len(groups) - len(family_groups)
    print(f"[booking-groups] {len(groups)} groups detected  ({len(family_groups)} family, {skipped} colleague-skip)", flush=True)

    propagated, conflicts, conflict_descs = apply_booking_group_propagation(rows, verbose=True)
    for idx, orig in enumerate(orig_rows):
        if row_verified_emp_locked(orig) or row_missing_evidence(orig):
            rows[idx] = orig
    patches = collect_patches(rows, orig_rows)
    if patches:
        tmp = out_xlsx.with_name(out_xlsx.stem + ".__patch__.xlsx")
        write_xlsx_patches(out_xlsx, tmp, patches)
        tmp.replace(out_xlsx)
        print(f"[booking-groups] {len(patches)} rows patched in {out_xlsx.name}", flush=True)
    else:
        print(f"[booking-groups] no changes needed", flush=True)

    if conflicts:
        print(f"[booking-groups] ⚠️  {conflicts} FAMILY_CONFLICT groups — review catches JSON", flush=True)

    catches_out = out_xlsx.parent / f"catches-booking-groups-{VERSION}.json"
    catches_out.write_text(json.dumps({
        "batch_id":    out_xlsx.parent.parent.name,
        "version":     VERSION,
        "propagated":  propagated,
        "conflicts":   conflicts,
        "conflict_details": conflict_descs,
        "groups_found": len(groups),
        "family_groups": len(family_groups),
    }, indent=2))

    return propagated, conflicts


def sync_final_gl_descriptions(out_xlsx: Path, cascade_xlsx: Path, header_row: int) -> int:
    """Refresh GL Description AND all Block-2 name columns from the final combo.

    process_batch writes the Block-2 name columns (GL, Cost Name, Contribution,
    Solution Name, Agency Name, GL Description) before run_v30 rewrites combos
    (PC-override fix + booking-group propagation). Any row whose combo changed
    afterwards keeps stale / #N/A name labels. This pass re-expands every row's
    final combo and re-derives the human-readable name columns so they always
    agree with the combo actually shipped. Combo values are never modified.
    """
    lookup = get_lookup()
    out_wb = openpyxl.load_workbook(out_xlsx)
    out_ws = out_wb.active
    in_wb = openpyxl.load_workbook(cascade_xlsx, data_only=True)
    in_ws = in_wb.active

    out_headers = {
        str(c.value).strip(): i + 1
        for i, c in enumerate(out_ws[header_row])
        if c.value
    }
    in_headers = {
        str(c.value).strip(): i + 1
        for i, c in enumerate(in_ws[header_row])
        if c.value
    }

    out_combo_col = next((v for k, v in out_headers.items() if "distribution combination" in k.lower()), None)
    in_combo_col = next((v for k, v in in_headers.items() if "distribution combination" in k.lower()), None)
    gl_desc_col = out_headers.get("GL Description")
    if not out_combo_col or not in_combo_col or not gl_desc_col:
        print("[v30-gl-sync] WARNING: required columns missing; skipping GL Description sync", flush=True)
        in_wb.close()
        out_wb.close()
        return 0

    # Block-2 name columns to re-derive from expand_combo(). Map each output
    # header (if present in the sheet) to the expansion key that feeds it:
    #   GL (col 20) - Cost Name (22) - Contribution (24) - Solution Name (26)
    #   - Agency Name (28). GL Description (col 32) is handled separately below.
    NAME_COL_KEYS = {
        "GL": "GL",
        "Cost Name": "Cost Name",
        "Contribution": "Contribution",
        "Solution Name": "Solution Name",
        "Agency Name": "Agency Name",
    }
    name_cols = {
        out_headers[hdr]: key
        for hdr, key in NAME_COL_KEYS.items()
        if hdr in out_headers
    }

    updated = 0       # rows whose name columns were refreshed
    desc_updated = 0  # GL Description cells re-derived
    for row_idx in range(header_row + 1, out_ws.max_row + 1):
        final_combo = str(out_ws.cell(row=row_idx, column=out_combo_col).value or "").strip()
        # Only touch rows with a non-empty, structurally valid (10-segment) combo.
        if not final_combo or len(final_combo.split("-")) < 10:
            continue

        cascade_combo = str(in_ws.cell(row=row_idx, column=in_combo_col).value or "").strip()
        if final_combo != cascade_combo:
            out_ws.cell(row=row_idx, column=gl_desc_col, value=build_gl_description(final_combo, lookup))
            desc_updated += 1

        # Re-expand the final combo and refresh the human-readable name columns
        # so they can never disagree with the shipped combo (fixes #N/A Cost
        # Name on rows whose combo was rewritten after process_batch).
        expansion = lookup.expand_combo(final_combo)
        if not expansion.get("Account"):
            continue  # combo did not expand cleanly; leave existing labels alone
        for col, key in name_cols.items():
            out_ws.cell(row=row_idx, column=col, value=expansion.get(key, ""))
        updated += 1

    out_wb.save(str(out_xlsx))
    in_wb.close()
    out_wb.close()
    print(
        f"[v30-gl-sync] refreshed Block-2 name columns on {updated} row(s); "
        f"{desc_updated} GL Description cell(s) re-derived from final combo",
        flush=True,
    )
    return updated


def stamp_missing_evidence_output(
    out_xlsx: Path,
    hybrid_rows: list[dict],
    hdr_row: int,
) -> int:
    missing = [h for h in hybrid_rows if row_missing_evidence(h)]
    if not missing:
        return 0

    wb = openpyxl.load_workbook(out_xlsx)
    ws = wb.active
    cols = {
        str(ws.cell(hdr_row, ci).value or "").strip(): ci
        for ci in range(1, ws.max_column + 1)
        if str(ws.cell(hdr_row, ci).value or "").strip()
    }
    combo_col = next(
        (ci for hdr, ci in cols.items() if "distribution combination" in hdr.lower()),
        None,
    )
    clear_headers = ("Account", "Cost Center", "DIV", "Solution", "Agency")
    cleared = 0

    for h in missing:
        row_idx = h["_row_idx"]
        account = str(h.get("account", "") or "").strip()
        agent_flags = (
            str(ws.cell(row_idx, cols["Agent Flags"]).value or "")
            if "Agent Flags" in cols
            else ""
        )
        verified_emp_locked = (
            row_verified_emp_locked(h)
            or VERIFIED_EMP_LOCK_FLAG in agent_flags
        )
        verified_annual = (
            account == "21070229"
            and verified_emp_locked
            and str(h.get("emp_no", "") or "").strip()
            and str(h.get("cost_center", "") or "").strip()
            and str(h.get("div", "") or "").strip()
            and str(h.get("agency", "") or "").strip()
        )
        if verified_annual:
            for key, hdr in (
                ("account", "Account"),
                ("cost_center", "Cost Center"),
                ("div", "DIV"),
                ("solution", "Solution"),
                ("agency", "Agency"),
            ):
                if hdr in cols:
                    ws.cell(row_idx, cols[hdr]).value = str(h.get(key, "") or "").strip()
            if combo_col:
                parts = str(ws.cell(row_idx, combo_col).value or "").strip().split("-")
                company = str(ws.cell(row_idx, cols.get("Company", 0)).value or "").strip() if "Company" in cols else ""
                location = str(ws.cell(row_idx, cols.get("Location", 0)).value or "").strip() if "Location" in cols else ""
                project = str(ws.cell(row_idx, cols.get("Project", 0)).value or "").strip() if "Project" in cols else ""
                intercompany = str(ws.cell(row_idx, cols.get("Intercompany", 0)).value or "").strip() if "Intercompany" in cols else ""
                future = str(ws.cell(row_idx, cols.get("Future 1", 0)).value or "").strip() if "Future 1" in cols else ""
                combo_parts = [
                    (company or (parts[0] if len(parts) > 0 else "")).zfill(2),
                    (location or str(h.get("location", "") or "") or (parts[1] if len(parts) > 1 else "")).zfill(5),
                    account.zfill(8),
                    str(h.get("cost_center", "") or "").zfill(6),
                    str(h.get("div", "") or "").zfill(3),
                    str(h.get("solution", "") or "").zfill(5),
                    str(h.get("agency", "") or "").zfill(5),
                    (project or (parts[7] if len(parts) > 7 else "")).zfill(5),
                    (intercompany or (parts[8] if len(parts) > 8 else "")).zfill(2),
                    (future or (parts[9] if len(parts) > 9 else "")).zfill(6),
                ]
                ws.cell(row_idx, combo_col).value = "-".join(combo_parts)
        else:
            for hdr in clear_headers:
                if hdr in cols:
                    ws.cell(row_idx, cols[hdr]).value = ""
            if combo_col:
                ws.cell(row_idx, combo_col).value = ""
        if "Employee No" in cols:
            if verified_emp_locked:
                ws.cell(row_idx, cols["Employee No"]).value = str(
                    h.get("emp_no", "") or ""
                ).strip()
            else:
                ws.cell(row_idx, cols["Employee No"]).value = ""
        if "Row Status" in cols:
            ws.cell(row_idx, cols["Row Status"]).value = "RED"
        if "Evidence Folder Status" in cols:
            ws.cell(row_idx, cols["Evidence Folder Status"]).value = "MISSING"
        if "Agent Flags" in cols:
            cell = ws.cell(row_idx, cols["Agent Flags"])
            existing = str(cell.value or "").strip()
            if MISSING_EVIDENCE_FLAG not in existing:
                cell.value = (
                    f"{existing} | {MISSING_EVIDENCE_FLAG}"
                    if existing and existing.upper() != "CLEAN"
                    else MISSING_EVIDENCE_FLAG
                )
        if "QC Catches" in cols:
            cell = ws.cell(row_idx, cols["QC Catches"])
            existing = str(cell.value or "").strip()
            catch = "MISSING_EVIDENCE(HARD)"
            if catch not in existing:
                cell.value = f"{existing} | {catch}" if existing else catch
        if "Agent Method" in cols:
            ws.cell(row_idx, cols["Agent Method"]).value = "missing_evidence_gate"
        cleared += 1

    wb.save(str(out_xlsx))
    print(f"[missing-evidence] {cleared} output row(s) hard-stamped RED/blank allocation", flush=True)
    return cleared


def _append_cell_token(cell, token: str, separator: str = " | ") -> bool:
    existing = str(cell.value or "").strip()
    if token in existing:
        return False
    cell.value = f"{existing}{separator}{token}" if existing and existing.upper() != "CLEAN" else token
    return True


def stamp_opex_email_only_output(
    out_xlsx: Path,
    hybrid_rows: list[dict],
    hdr_row: int,
) -> int:
    email_only = [h for h in hybrid_rows if h.get("_opex_email_only")]
    if not email_only:
        return 0

    wb = openpyxl.load_workbook(out_xlsx)
    ws = wb.active
    cols = {
        str(ws.cell(hdr_row, ci).value or "").strip(): ci
        for ci in range(1, ws.max_column + 1)
        if str(ws.cell(hdr_row, ci).value or "").strip()
    }
    combo_col = next(
        (ci for hdr, ci in cols.items() if "distribution combination" in hdr.lower()),
        None,
    )
    stamped = 0
    for h in email_only:
        row_idx = h["_row_idx"]
        if "Account" in cols:
            ws.cell(row_idx, cols["Account"]).value = "60307021"
        for hdr in ("Cost Center", "DIV", "Solution", "Agency"):
            if hdr in cols:
                ws.cell(row_idx, cols[hdr]).value = ""
        if combo_col:
            ws.cell(row_idx, combo_col).value = ""
        if "Row Status" in cols:
            ws.cell(row_idx, cols["Row Status"]).value = "YELLOW"
        if "Evidence Folder Status" in cols:
            ws.cell(row_idx, cols["Evidence Folder Status"]).value = OPEX_EMAIL_ONLY_FLAG
        if "Human Review Note" in cols:
            ws.cell(row_idx, cols["Human Review Note"]).value = (
                "OPEX/event approval is present only as email evidence; the OPEX PDF is absent, "
                "so exact sponsorship segments require human review."
            )
        if "Agent Flags" in cols:
            _append_cell_token(ws.cell(row_idx, cols["Agent Flags"]), OPEX_EMAIL_ONLY_FLAG)
        if "QC Catches" in cols:
            _append_cell_token(
                ws.cell(row_idx, cols["QC Catches"]),
                "OPEX_EMAIL_ONLY_REVIEW(MEDIUM)",
            )
        if "Agent Action" in cols:
            _append_cell_token(
                ws.cell(row_idx, cols["Agent Action"]),
                OPEX_EMAIL_ONLY_FLAG,
            )
        if "OPEX Serial" in cols and h.get("_opex_serial"):
            ws.cell(row_idx, cols["OPEX Serial"]).value = str(h.get("_opex_serial") or "")
        if "Agent Method" in cols:
            ws.cell(row_idx, cols["Agent Method"]).value = "opex_email_only_review"
        stamped += 1

    wb.save(str(out_xlsx))
    wb.close()
    print(f"[opex-email-only] {stamped} output row(s) stamped for human review", flush=True)
    return stamped


def clear_stale_employee_not_in_master_output(
    out_xlsx: Path,
    hybrid_rows: list[dict],
    manpower: dict,
    hdr_row: int,
) -> int:
    candidates = [h for h in hybrid_rows if _emp_resolves_in_manpower(h.get("emp_no"), manpower)]
    if not candidates:
        return 0

    wb = openpyxl.load_workbook(out_xlsx)
    ws = wb.active
    cols = {
        str(ws.cell(hdr_row, ci).value or "").strip(): ci
        for ci in range(1, ws.max_column + 1)
        if str(ws.cell(hdr_row, ci).value or "").strip()
    }
    flags_col = cols.get("Agent Flags")
    action_col = cols.get("Agent Action")
    status_col = cols.get("Row Status")
    catches_col = cols.get("QC Catches")
    if not flags_col:
        wb.close()
        return 0

    cleared = 0
    for h in candidates:
        row_idx = h["_row_idx"]
        flag_cell = ws.cell(row_idx, flags_col)
        new_flags, flag_changed = _remove_pipe_flag_text(
            flag_cell.value, "EMPLOYEE_NOT_IN_MASTER"
        )
        if not flag_changed:
            continue
        flag_cell.value = new_flags
        cleared += 1

        if action_col:
            action_cell = ws.cell(row_idx, action_col)
            action = str(action_cell.value or "").strip()
            if "EMPLOYEE_NOT_IN_MASTER" in action:
                if action.startswith("HOLD - "):
                    codes = [
                        p.strip() for p in action[len("HOLD - "):].split("|")
                        if p.strip() and p.strip() != "EMPLOYEE_NOT_IN_MASTER"
                    ]
                    action_cell.value = "HOLD - " + " | ".join(codes) if codes else "Post to GL"
                elif action == "EMPLOYEE_NOT_IN_MASTER":
                    action_cell.value = "Post to GL"

        if status_col:
            remaining_flags = str(flag_cell.value or "").strip().upper()
            remaining_catches = (
                str(ws.cell(row_idx, catches_col).value or "").strip().upper()
                if catches_col else ""
            )
            if (
                str(ws.cell(row_idx, status_col).value or "").strip() == "YELLOW"
                and remaining_flags in ("", "CLEAN")
                and remaining_catches in ("", "CLEAN", "NONE")
            ):
                ws.cell(row_idx, status_col).value = "GREEN"

    if cleared:
        wb.save(str(out_xlsx))
    wb.close()
    print(f"[v30-stale-emp-flag] cleared {cleared} stale EMPLOYEE_NOT_IN_MASTER flag(s)", flush=True)
    return cleared


# ─── main ─────────────────────────────────────────────────────────────────────

def _collect_evidence_folders(batch_id: str, batch_dir: Path) -> list[Path]:
    """Collect evidence folders across live batch roots and archive fallback.

    Historical batches use raw/day/ticket folders. J26-788 and portal-driven
    batches may have direct folders under gdrive-evidence, while the complete
    J26-788 evidence currently lives under archive/raw-J26-788.
    """
    candidate_roots = [
        batch_dir / "raw",
        batch_dir / "gdrive-evidence",
        batch_dir / "gdrive-evidence2",
        ROOT / "archive" / f"raw-{batch_id}",
    ]

    folders: list[Path] = []
    for root in candidate_roots:
        if not root.exists():
            continue

        try:
            folders.extend(fea.collect_all_folders(root))
        except Exception as exc:
            print(f"[scan] warning: legacy folder scan failed for {root}: {exc}", flush=True)

        for child in sorted(root.rglob("*")):
            if not child.is_dir():
                continue
            try:
                has_evidence = any(
                    p.is_file() and p.suffix.lower() in {".msg", ".pdf", ".eml"}
                    for p in child.iterdir()
                )
            except OSError:
                continue
            if has_evidence:
                folders.append(child)

    # Volume root (DigitalOcean volume — covers portal-uploaded batches J26-815+)
    volume_batch_dir = VOLUME_BASE / batch_id
    if volume_batch_dir.is_dir():
        # Walk up to 3 levels deep to find the dir that directly contains date/ticket subfolders
        import re as _re
        ticket_pat = _re.compile(r"^\d{6,}$")
        date_pat = _re.compile(r"^\d{2}[a-z]{3}$", _re.IGNORECASE)
        from collections import deque as _deque
        _queue = _deque([(volume_batch_dir, 0)])
        while _queue:
            _cur, _depth = _queue.popleft()
            try:
                _subdirs = [p for p in _cur.iterdir() if p.is_dir()]
            except PermissionError:
                continue
            if any(ticket_pat.match(p.name) or date_pat.match(p.name.lower()) for p in _subdirs):
                try:
                    folders.extend(fea.collect_all_folders(_cur))
                except Exception as exc:
                    print(f"[scan] WARNING: failed to scan volume root {_cur}: {exc}", flush=True)
                break
            if _depth < 3:
                for _sub in _subdirs:
                    _queue.append((_sub, _depth + 1))

    seen_paths = set()
    unique_folders: list[Path] = []
    for folder in folders:
        resolved = folder.resolve(strict=False)
        if resolved in seen_paths:
            continue
        seen_paths.add(resolved)
        unique_folders.append(folder)
    return unique_folders


def main():
    ap = argparse.ArgumentParser(description=f"AlJeel AP Pipeline {VERSION}")
    ap.add_argument("batch_id")
    ap.add_argument("--invoice-id", default=None)
    ap.add_argument("--workers", type=int, default=4)
    ap.add_argument("--limit", type=int, default=0)
    ap.add_argument("--cost-ceiling", type=float, default=COST_CEILING)
    ap.add_argument("--input-suffix", default="v15.11",
                    help="Cascade input version (default: v15.11)")
    ap.add_argument("--skip-fraud", action="store_true")
    ap.add_argument("--use-cache", action="store_true")
    ap.add_argument("--no-cache", action="store_true")
    args = ap.parse_args()

    batch_id   = args.batch_id
    batch_dir  = ROOT / "batches" / f"jawal-{batch_id}"
    raw_root   = batch_dir / "raw"
    # Fallback to volume evidence root for portal-uploaded batches (J26-815+)
    if not raw_root.exists():
        _vol_batch = VOLUME_BASE / batch_id
        if _vol_batch.is_dir():
            import re as _re2
            _tp = _re2.compile(r"^\d{6,}$")
            _dp = _re2.compile(r"^\d{2}[a-z]{3}$", _re2.IGNORECASE)
            from collections import deque as _dq2
            _q2 = _dq2([(_vol_batch, 0)])
            while _q2:
                _c2, _d2 = _q2.popleft()
                try:
                    _s2 = [p for p in _c2.iterdir() if p.is_dir()]
                except PermissionError:
                    continue
                if any(_tp.match(p.name) or _dp.match(p.name.lower()) for p in _s2):
                    raw_root = _c2
                    print(f"[info] raw_root resolved from volume: {raw_root}", flush=True)
                    break
                if _d2 < 3:
                    for _sb2 in _s2:
                        _q2.append((_sb2, _d2 + 1))
    gdrive_root = batch_dir / "gdrive-evidence"
    direct_ticket_index: set[str] = set()
    bundled_ticket_pdf_map: dict[str, str] = {}
    _ticket_pdf_text_cache: dict[Path, set[str]] = {}
    for _ticket_root in (
        raw_root,
        gdrive_root,
        batch_dir / "gdrive-evidence2",
        ROOT / "archive" / f"raw-{batch_id}",
    ):
        direct_ticket_index.update(build_ticket_folder_index(_ticket_root))
        bundled_ticket_pdf_map.update(
            build_bundled_ticket_pdf_map(_ticket_root, _ticket_pdf_text_cache)
        )
    ticket_folder_index = set(direct_ticket_index)
    ticket_folder_index.update(bundled_ticket_pdf_map)
    print(
        f"[scan] {len(direct_ticket_index)} ticket-number evidence folder/file name(s) indexed; "
        f"{len(bundled_ticket_pdf_map)} bundled PDF ticket(s) indexed",
        flush=True,
    )
    invoice_id = args.invoice_id or batch_id

    if not batch_dir.exists():
        print(f"[fatal] batch dir not found: {batch_dir}", file=sys.stderr)
        sys.exit(2)

    # ── find cascade input ─────────────────────────────────────────────────
    out_dir = batch_dir / "output"
    out_dir.mkdir(parents=True, exist_ok=True)

    exact_cascade = out_dir / f"Spreadsheet-{invoice_id}-FILLED-{args.input_suffix}.xlsx"
    if exact_cascade.exists():
        cascade_xlsx = exact_cascade
    else:
        pattern    = f"Spreadsheet-{invoice_id}-FILLED-{args.input_suffix}*.xlsx"
        candidates = sorted(out_dir.glob(pattern),
                            key=lambda p: p.stat().st_mtime, reverse=True)
        candidates = [c for c in candidates if not re.search(r"v1[78]", c.name)]
        if not candidates:
            print(f"[fatal] cascade input not found: {out_dir}/{pattern}", file=sys.stderr)
            sys.exit(3)
        cascade_xlsx = candidates[0]
    print(f"[load] cascade: {cascade_xlsx.name}", flush=True)

    # ── output path ────────────────────────────────────────────────────────
    out_xlsx = out_dir / f"Spreadsheet-{invoice_id}-FILLED-{VERSION}.xlsx"
    if out_xlsx.exists():
        bak = out_xlsx.with_suffix(out_xlsx.suffix + f".bak-pre-{VERSION}-{utc_ts()}")
        shutil.copy2(out_xlsx, bak)
        print(f"[backup] {bak.name}", flush=True)

    # ── load inputs ────────────────────────────────────────────────────────
    cascade_rows, headers, hdr_row = v15.read_cascade_xlsx(cascade_xlsx)
    print(f"[load] {len(cascade_rows)} cascade rows", flush=True)
    if args.limit > 0:
        cascade_rows = cascade_rows[:args.limit]

    print("[load] master data...", flush=True)
    manpower    = fea.load_manpower()
    lookups     = fea.load_lookups()
    
    all_folders = _collect_evidence_folders(batch_id, batch_dir)

    print(f"[scan] {len(all_folders)} evidence folders scanned across roots", flush=True)

    # ── FIX A: build expanded reverse index with adjacent-ticket entries ───
    print("[scan] building reverse folder + PC index (v30 — adj-ticket expansion)...", flush=True)
    reverse_index = build_reverse_folder_index_v25(all_folders)
    pc_index      = build_personal_contribution_index(all_folders)
    print(f"[scan] reverse={len(reverse_index)} mappings  pc={len(pc_index)} PC folders", flush=True)

    # ── stage 1: routing ───────────────────────────────────────────────────
    # ── v30 Fix D: routing override for sponsoring rows with non-empty emp_no ─
    def _needs_classification_v26(
        row: dict, all_folders_: list[Path], rev_idx: dict | None
    ) -> tuple[bool, str]:
        """v26 adds SPONSORING_EMPNO_REVIEW before falling back to v16 logic.

        Catches rows where account=60307021 already set (via v4_preserved or
        L1_sponsor_override) but emp_no is non-empty in cascade output.
        This indicates the CC/account may be wrong (requestor CC used instead
        of event CC, or employee misclassified as sponsored external party).
        """
        # General sponsoring-row emp_no review now covers rows that previously
        # needed row-specific route forcing.
        account = str(row.get("Account", "") or "").strip()
        emp_no  = str(row.get("Employee No", "") or "").strip()
        if account == "60307021":
            return True, "SPONSORING_EMPNO_REVIEW"
        return _needs_classification(row, all_folders_, rev_idx)

    routed: list[tuple[int, str]] = []
    for i, row in enumerate(cascade_rows):
        should, reason = _needs_classification_v26(row, all_folders, reverse_index)
        if should:
            routed.append((i, reason))

    # ── stage 2: init hybrid_rows from cascade ────────────────────────────
    hybrid_rows: list[dict] = []
    for c in cascade_rows:
        hybrid_rows.append({
            "_row_idx":      c["_row_idx"],
            "_agent_method": "cascade",
            "emp_no":        c.get("Employee No", "") or "",
            "account":       c.get("Account", "") or "",
            "cost_center":   c.get("Cost Center", "") or "",
            "div":           c.get("DIV", "") or "",
            "solution":      c.get("Solution", "") or "",
            "agency":        c.get("Agency", "") or "",
            "location":      c.get("Location", "") or "",
        })

    # v30 NOTE: L0 validation was trialled but reverted — the Jawwal source system's
    # direct emp_no assignment (L0) must be trusted. Applying a both-token name
    # check on L0 inadvertently cleared correct assignments (e.g. YOUSEF AL DIGHRIR
    # whose tribal name differs between Jawwal and Oracle). The both-token rule
    # is applied inside the RESOLVERS (full_evidence_agent_v30 PRIORITY 2, and
    # v30 employee registration Pass-2 removal below) which is where false-positive
    # name-based matches should be blocked.

    # Labadi RULE 1 (2026-06-09): sponsorship rows KEEP an emp_no — the requestor /
    # AlJeel employee who submitted the OPEX form — and must NEVER be blanked. The
    # cascade [blank] pass that cleared emp_no on account=60307021 rows is REMOVED.
    # The requestor emp_no is resolved downstream (stage 3 LLM resolution / OPEX
    # folder extraction).

    # ── stage 2.5: verified Ref.No. employee lock ────────────────────────
    # If the invoice Ref.No. carries a 7-digit emp_no and that employee's
    # Manpower name strongly matches the passenger, the identity is final.
    # Later LLM routes, overlays, cluster propagation, and sponsorship rewrites
    # must not alter account/emp_no/segments for that row.
    verified_locks = stamp_verified_emp_locks(hybrid_rows, cascade_rows, manpower)
    print(f"[verified-lock] {verified_locks} Ref.No. employee row(s) locked", flush=True)

    # ── stage 2.6: missing-evidence hard gate ────────────────────────────
    # Ticket-number evidence folders are authoritative. These rows keep invoice
    # facts and verified Ref.No. identity only; allocation is blank.
    missing_evidence_rows = stamp_missing_evidence_gate(
        hybrid_rows,
        cascade_rows,
        ticket_folder_index,
        bundled_ticket_pdf_map=bundled_ticket_pdf_map,
        direct_ticket_index=direct_ticket_index,
    )
    if missing_evidence_rows:
        routed_before_gate = len(routed)
        routed = [(i, reason) for i, reason in routed if not row_missing_evidence(hybrid_rows[i])]
        skipped_llm = routed_before_gate - len(routed)
        print(
            f"[missing-evidence] {missing_evidence_rows} NO_FOLDER row(s) gated; "
            f"{skipped_llm} routed row(s) removed before LLM",
            flush=True,
        )

    reason_counts: dict[str, int] = Counter(r for _, r in routed)
    print(f"[route] {len(routed)} rows → LLM  /  {len(cascade_rows) - len(routed)} stay cascade",
          flush=True)

    # ── stage 3: LLM two-call resolution (v30 wrapper — Fix B) ───────────
    no_cache = True
    print("[llm] cache FORCED DISABLED — all LLM calls will be fresh", flush=True)

    total_in = total_out = llm_errors = 0
    pricing_pro = fea.GEMINI_PRICING["gemini-2.5-pro"]
    step_traces: list[dict] = []

    def worker(idx_reason):
        idx, reason = idx_reason
        if row_missing_evidence(hybrid_rows[idx]):
            return idx, reason, {
                "_agent_method": "missing_evidence_gate",
                "_classify": "MISSING_EVIDENCE",
                "_route_reason": reason,
            }
        try:
            return idx, reason, process_row_v25(
                idx, cascade_rows[idx], reason,
                batch_id, raw_root, all_folders, manpower, lookups,
                reverse_index=reverse_index,
                pc_index=pc_index,
                no_cache=no_cache,
                verified_emp_locked=row_verified_emp_locked(hybrid_rows[idx]),
            )
        except Exception as e:
            return idx, reason, {
                "_agent_method": "cascade_fallback",
                "_llm_error":    f"{type(e).__name__}: {e}",
                "_tb":           traceback.format_exc()[-500:],
            }

    t_start = time.time()
    done = 0
    with concurrent.futures.ThreadPoolExecutor(max_workers=args.workers) as ex:
        futs = [ex.submit(worker, ir) for ir in routed]
        try:
            for fut in concurrent.futures.as_completed(futs):
                idx, reason, res = fut.result()
                done += 1
                tok_in  = res.get("_llm_in_tokens", 0) or 0
                tok_out = res.get("_llm_out_tokens", 0) or 0
                total_in  += tok_in
                total_out += tok_out
                cost_est = (total_in * pricing_pro["in"]) + (total_out * pricing_pro["out"])
                elapsed  = time.time() - t_start
                print(
                    f"[{done:3d}/{len(routed)}] row {idx:3d} "
                    f"({reason} → {res.get('_classify','?')})  "
                    f"method={res.get('_agent_method','?')}"
                    f"  t={elapsed:5.1f}s  cost~=${cost_est:.3f}"
                    f"{' [C]' if res.get('_from_cache') else ''}"
                    f"{' ERR=' + res.get('_llm_error','')[:60] if res.get('_llm_error') else ''}",
                    flush=True,
                )
                if res.get("_llm_error"):
                    llm_errors += 1
                method = res.get("_agent_method", "cascade_fallback")
                hybrid_rows[idx]["_agent_method"] = method
                if (
                    "cascade_fallback" not in method
                    and not (
                        row_verified_emp_locked(hybrid_rows[idx])
                        and ((res.get("_step_trace") or {}).get("shortcut") or {}).get("type")
                        == "master_shortcut_sponsorship"
                    )
                ):
                    if row_verified_emp_locked(hybrid_rows[idx]):
                        protected = ("emp_no", "account", "cost_center", "div", "solution", "agency")
                    else:
                        protected = ()
                    for key in ("emp_no", "account", "cost_center", "div", "solution", "agency"):
                        if key in protected:
                            continue
                        v = res.get(key)
                        if v is not None:
                            hybrid_rows[idx][key] = v
                    # Labadi RULE 4 (2026-06-09): stamp the LLM-extracted OPEX serial
                    # on the row. process_batch prefers this over its regex fallback.
                    # Do NOT override if process_batch already set a non-MISSING value
                    # via regex (handled downstream — we only set when LLM found one).
                    opex_serial = res.get("opex_serial", "")
                    if opex_serial:
                        hybrid_rows[idx]["_opex_serial"] = opex_serial
                hybrid_rows[idx]["_route_reason"] = reason
                hybrid_rows[idx]["_classify"]      = res.get("_classify", "?")
                # Remember the evidence folder so the pre-write serial
                # catch-all can try folder-name extraction for rows that
                # still have no opex_serial.
                _ev_folder = ((res.get("_step_trace") or {}).get("call1") or {}).get("evidence_folder", "")
                if _ev_folder:
                    hybrid_rows[idx]["_evidence_folder"] = _ev_folder

                if res.get("_step_trace"):
                    step_traces.append(res["_step_trace"])

                if cost_est > args.cost_ceiling:
                    print(f"[fatal] cost ceiling ${args.cost_ceiling:.2f} hit — saving partial.",
                          file=sys.stderr)
                    for f in futs:
                        f.cancel()
                    break
        except KeyboardInterrupt:
            print("\n[interrupt] saving partial...", flush=True)

    # ── stage 3b: family cluster unification ──────────────────────────────
    unified = apply_family_cluster_unification_verified_safe(hybrid_rows, cascade_rows)
    print(f"[cluster] {unified} rows emp_no-unified within family clusters", flush=True)

    # ── stage 3c: personal contribution overlay (v30 — uses find_folder_v25) ──
    # Two v30 changes carried forward:
    #   1. Use find_folder_v25 for folder lookup (correct adjacent-ticket routing)
    #   2. Skip rows where the LLM already resolved to account=21070229 with a
    #      valid CC — avoids overwriting a correct LLM result with a wrong PC folder.
    pc_applied = 0
    for i, c in enumerate(cascade_rows):
        if row_missing_evidence(hybrid_rows[i]):
            continue
        if row_verified_emp_locked(hybrid_rows[i]):
            continue
        if row_family_annual_locked(hybrid_rows[i]):
            continue  # stage 3i family-annual lock — account/segments are final
        desc  = str(c.get("Description", "") or "")
        notes = str(c.get("Notes", "") or "")
        text  = desc + " " + notes
        tm    = re.search(r"\b(\d{10,})\b", text)
        ticket = tm.group(1) if tm else ""
        if not ticket:
            tm2 = re.search(r"\b(26-\d{3})\b", text)
            ticket = tm2.group(1) if tm2 else ""
        passenger = desc.split(" - ", 1)[0].strip() if " - " in desc else ""

        # v30: skip rows already correctly resolved by LLM to PC with valid CC
        # Also skip rows resolved to sponsorship (60307021) — PC overlay must not
        # overwrite a correctly-resolved sponsorship account even when the evidence
        # folder contains a contaminating PC email.
        hybrid_acct = str(hybrid_rows[i].get("account", "") or "").strip()
        hybrid_cc   = str(hybrid_rows[i].get("cost_center", "") or "").strip()
        if hybrid_acct == "21070229" and hybrid_cc not in ("", "000000", "999999"):
            continue   # LLM already nailed it — don't overwrite
        if hybrid_acct == "60307021":
            continue   # already resolved to sponsorship — PC overlay must not overwrite

        # v30: use find_folder_v25 (not fea.find_ticket_folder) to avoid surname mismatch
        folder = find_folder_v25(ticket, passenger, notes, all_folders, reverse_index)
        if not folder:
            continue
        pc_rec = pc_index.get(str(folder))
        if not pc_rec:
            continue
        cascade_account = str(c.get("Account", "") or "").strip()
        if cascade_account in ("21070229", "60307021"):
            continue
        res_layer = str(c.get("Resolution Layer", "") or "").strip().lower()
        if "not_resolved" not in res_layer and "not resolved" not in res_layer:
            continue
        flags     = str(c.get("Agent Flags", "") or "")
        cascade_cc = str(c.get("Cost Center", "") or "").strip()
        if "EMPLOYEE_NOT_IN_MASTER" not in flags and cascade_cc not in ("", "000000", "999999"):
            continue
        emp_no = pc_rec.get("emp_no", "")
        rec    = manpower.get(emp_no, {})
        hybrid_rows[i]["account"]  = "21070229"
        hybrid_rows[i]["emp_no"]   = emp_no
        _stamp_21070229_home_segments(hybrid_rows[i], rec)
        hybrid_rows[i]["_agent_method"] = "v25_personal_contribution"
        pc_applied += 1
    if pc_applied:
        print(f"[pc] {pc_applied} rows → account=21070229 (personal contribution)", flush=True)

    # ── stage 3d: FIX C — PC-family dependent emp_no blanking ─────────────
    pc_family_blanked = apply_pc_family_emp_no_rule(
        hybrid_rows, cascade_rows, manpower, pc_index, all_folders, reverse_index,
    )
    print(f"[v30-fix-c] {pc_family_blanked} PC-family dependent rows → emp_no blanked", flush=True)

    # ── stage 3e: v30 — NTS hotel rows with PC email (folder-by-empno lookup) ─────
    # Problem: hotel rows like "26-731 / MOSTAFA AMER - Kimpton Vividora Barcelona - 1 NTS"
    # use "26-NNN" ticket keys. The evidence folder is named "hotel amer + sultan" (not a
    # ticket-number folder) so find_folder_v25 misses it. Stage 3c PC overlay also misses
    # it. Fix: build a secondary index emp_no→folder from pc_index, then match by passenger
    # name via manpower. If a PC email exists for the passenger → apply 21070229 + master CC.
    pc_by_empno: dict[str, Path] = {}
    for _fp, _prec in pc_index.items():
        _eno = _prec.get("emp_no", "").strip()
        if _eno:
            pc_by_empno[_eno] = Path(_fp)

    nts_pc_count = 0
    for i, c in []:  # Disabled v26_nts_pc_overlay to prevent overfitting and let the clean LLM classification decide
        if row_verified_emp_locked(hybrid_rows[i]):
            continue
        if row_family_annual_locked(hybrid_rows[i]):
            continue  # stage 3i family-annual lock — account/segments are final
        acct = str(hybrid_rows[i].get("account") or "").strip()
        if acct not in ("60301003", "60301004", "60307021"):
            continue
        desc = str(c.get("Description", "") or "")
        # Target: 26-NNN rows with NTS (hotel nights) in description
        if not re.search(r"26-[0-9]{3}", desc) or "NTS" not in desc.upper():
            continue
        passenger = desc.split(" - ", 1)[0].strip() if " - " in desc else ""
        if not passenger:
            continue

        # Resolve passenger to emp_no via manpower name lookup.
        # Passenger may be "LASTNAME/FIRSTNAME" (IATA) or "FIRSTNAME LASTNAME" (non-IATA).
        tokens = [t for t in re.split(r"[/\s]+", passenger.upper()) if len(t) >= 4]
        matched_eno = None
        # Pass 1: two-token match (preferred)
        for eno, mrec in manpower.items():
            name_en = (mrec.get("name") or "").upper()
            if sum(1 for tok in tokens if re.search(r"\b" + re.escape(tok) + r"\b", name_en)) >= 2:
                matched_eno = eno
                break
        # Pass 2: single long-token match (fallback)
        if not matched_eno:
            for eno, mrec in manpower.items():
                name_en = (mrec.get("name") or "").upper()
                if any(re.search(r"\b" + re.escape(tok) + r"\b", name_en) for tok in tokens if len(tok) >= 5):
                    matched_eno = eno
                    break

        if not matched_eno:
            continue

        # Find PC folder — check pc_by_empno first, then scan all PC folder files.
        pc_folder_nts: "Path | None" = pc_by_empno.get(matched_eno)
        if not pc_folder_nts:
            last_token = tokens[-1] if tokens else ""
            for _fp, _prec in pc_index.items():
                try:
                    _fdir = Path(_fp)
                    for _msg_f in _fdir.glob("*.msg"):
                        if "personal contribution" in _msg_f.name.lower() and last_token in _msg_f.name.upper():
                            pc_folder_nts = _fdir
                            break
                    if pc_folder_nts:
                        break
                except Exception:
                    pass

        if not pc_folder_nts or not pc_folder_nts.exists():
            continue
        has_pc = any(
            "personal contribution" in f.name.lower()
            for f in pc_folder_nts.iterdir()
            if f.suffix.lower() == ".msg"
        )
        if not has_pc:
            continue
        # Apply PC account + master CC
        mrec_nts = manpower.get(matched_eno, {})
        hybrid_rows[i]["account"]  = "21070229"
        hybrid_rows[i]["emp_no"]   = matched_eno
        _stamp_21070229_home_segments(hybrid_rows[i], mrec_nts)
        hybrid_rows[i]["_agent_method"] = "v26_nts_pc_overlay"
        hybrid_rows[i]["_route_reason"] = "NTS_PC_FOLDER"
        nts_pc_count += 1
        print(f"  [v30-nts-pc] row {i+1}: {passenger} -> 21070229 via {pc_folder_nts.name}", flush=True)
    print(f"[v30-nts-pc] {nts_pc_count} hotel/NTS rows -> account=21070229", flush=True)

    # ── stage 3f: v30 — employee conference registration rows (26-NNN) ────────────
    # Problem: rows like "AMMAR CHAUDHARY - Heart Failure 2026, Barcelona Registrati (26-743)"
    # trigger L1_sponsor_override (HF keyword) setting account=60307021. But the passenger
    # IS an AlJeel employee (in manpower). Conference registrations by employees = 60308009
    # (Training Expenses), not 60307021 (Sponsoring).
    # Rule: 26-NNN row with "Registration" in description, account=60307021, passenger in
    # manpower → account=60308009, emp_no=employee, CC from master.
    emp_reg_count = 0
    for i, c in enumerate(cascade_rows):
        if row_missing_evidence(hybrid_rows[i]):
            continue
        if row_verified_emp_locked(hybrid_rows[i]):
            continue
        if str(hybrid_rows[i].get("account") or "").strip() != "60307021":
            continue
        desc = str(c.get("Description", "") or "")
        if not re.search(r"26-\d{3}", desc) or "REGISTRAT" not in desc.upper():
            continue
        passenger = desc.split(" - ", 1)[0].strip() if " - " in desc else ""
        if not passenger:
            continue
        # Resolve passenger → emp_no via manpower (non-IATA format: "FIRSTNAME LASTNAME")
        # Note: passenger name on Jawal ticket may not match Oracle master exactly.
        # Strategy: require 2 token matches (preferred) or 1 long-token match (fallback).
        name_parts = [t for t in passenger.upper().split() if len(t) >= 4]
        if not name_parts:
            continue
        matched_eno = None
        # v30: two-token match ONLY — both first AND last name required.
        # Pass 2 (single-token fallback) removed: accepting a match on just
        # one name token (e.g. "AMMAR" matching "Jawdat Ammar Shorab") produces
        # wrong employee assignments. Better to leave unresolved than guess wrong.
        for eno, mrec in manpower.items():
            name_en = (mrec.get("name") or "").upper()
            if sum(1 for p in name_parts if re.search(r"\b" + re.escape(p) + r"\b", name_en)) >= 2:
                matched_eno = eno
                break
        if not matched_eno:
            continue
        # Apply Training account + master CC
        mrec = manpower.get(matched_eno, {})
        hybrid_rows[i]["account"]  = "60308009"
        hybrid_rows[i]["emp_no"]   = matched_eno
        if mrec:
            hybrid_rows[i]["cost_center"] = _norm_master_code(mrec.get("cost_center", ""), "cc")
            hybrid_rows[i]["div"]         = _norm_master_code(mrec.get("div_code", ""), "div")
            hybrid_rows[i]["solution"]    = _norm_master_code(mrec.get("solution", ""), "solution")
            hybrid_rows[i]["agency"]      = _norm_master_code(mrec.get("agency_code", ""), "agency")
        hybrid_rows[i]["_agent_method"] = "v26_emp_registration"
        hybrid_rows[i]["_route_reason"] = "EMP_REGISTRATION_TRAINING"
        emp_reg_count += 1
        print(f"  [v30-emp-reg] row {i+1}: {passenger} → 60308009 (Training) via master", flush=True)
    print(f"[v30-emp-reg] {emp_reg_count} employee registration rows → account=60308009", flush=True)

        # ── stage 3d: OPEX event-folder sponsorship overlay (v30) ──────────────
    # POST-PROCESSING — no LLM call. Deterministic overlay.
    # For tickets with account 60301003/60301004, no individual folder, whose
    # passenger surname appears in a conference/event folder .msg that also
    # contains an OPEX-*.pdf AND sponsorship language near the name.
    # => account=60307021, emp_no=blank, all other segments unchanged.
    opex_event_overlay_count = 0
    try:
        import extract_msg as _emsg_v26
        SPONSOR_SIGNALS = (
            "NON-MEMBER", "NON MEMBER", "HCP", "SPONSORSHIP", "SPONSORED",
            "EXTERNAL", "PHYSICIAN", "DOCTOR", "SPECIALIST", "PROFESSOR",
            "NOMINATION", "ATTENDEE", "\u0637\u0628\u064a\u0628", "\u0645\u062e\u062a\u0635",
        )

        def _is_aljeel_employee(surname: str, passenger: str, manpower: dict) -> bool:
            """
            Return True only if the passenger is clearly an AlJeel employee.
            Requires either:
            1. surname is >= 6 chars AND is a whole-word match in the employee name
            2. OR the full passenger name has 2+ tokens that all appear in one employee name

            A short surname (< 6 chars) like AHMED, OMAR, or ALI is never sufficient alone.
            """
            surname = surname.strip().upper()
            passenger_tokens = set(
                t.strip().upper() for t in re.split(r"[/\s]+", passenger)
                if len(t.strip()) >= 4 and t.strip().upper() not in ("MR", "MRS", "MS", "DR", "ENG", "CHD")
            )
            for emp in manpower.values():
                emp_name = ((emp.get("name_en", "") or emp.get("name", "") or "")).strip().upper()
                if not emp_name:
                    continue
                emp_tokens = set(emp_name.split())
                if len(surname) >= 6 and surname in emp_tokens:
                    return True
                if len(passenger_tokens) >= 2 and passenger_tokens.issubset(emp_tokens):
                    return True
            return False

        for idx, h in enumerate(hybrid_rows):
            if row_missing_evidence(h):
                continue
            if row_verified_emp_locked(h):
                continue
            acct = str(h.get("account", h.get("Account", "")) or "").strip()
            if acct not in ("60301003", "60301004"):
                continue
            desc  = str(cascade_rows[idx].get("Description", "") or "")
            notes = str(cascade_rows[idx].get("Notes", "") or "")
            tm    = re.search(r"\b(\d{10,})\b", desc + " " + notes)
            ticket_no = tm.group(1) if tm else ""
            if not ticket_no:
                continue
            passenger = desc.split(" - ", 1)[0].strip() if " - " in desc else ""
            surname = passenger.split("/")[0].strip().upper() if "/" in passenger else passenger.strip().upper()
            if len(surname) < 3:
                continue
            # Skip only if passenger is likely an AlJeel employee; sponsored parties are external.
            if _is_aljeel_employee(surname, passenger, manpower):
                continue
            import os as _os26
            import pathlib

            # Pre-check: does this ticket already have its own per-ticket folder anywhere in raw_root?
            ticket_has_own_folder = any(
                ticket_no in dir_name
                for _root26, _dirs26, _files26 in _os26.walk(raw_root)
                for dir_name in _dirs26
            )
            if ticket_has_own_folder:
                continue
            # Full walk: find any non-ticket dir containing OPEX-*.pdf
            found_folder = None
            for _dirpath26, _subdirs26, _filenames26 in _os26.walk(raw_root):
                _dirpath26 = pathlib.Path(_dirpath26)
                # Skip if this directory IS a ticket folder
                if re.match(r"^\d{10}", _dirpath26.name):
                    _subdirs26.clear()
                    continue
                opex_pdfs = [f for f in _filenames26 if re.match(r"OPEX-.*\.pdf", f, re.IGNORECASE)]
                if not opex_pdfs:
                    continue
                # Search .msg files in this dir for surname + SPONSOR_SIGNALS
                for fname in _filenames26:
                    if not fname.lower().endswith(".msg"):
                        continue
                    msg_path = _dirpath26 / fname
                    try:
                        msg_obj = _emsg_v26.Message(str(msg_path))
                        body = (msg_obj.body or "").upper()
                        subj = (msg_obj.subject or "").upper()
                        if surname not in body and surname not in subj:
                            continue
                        if any(sig in body or sig in subj for sig in SPONSOR_SIGNALS):
                            found_folder = _dirpath26
                            break
                    except Exception:
                        continue
                if found_folder:
                    break
            if found_folder:
                # Look up requesting employee from OPEX folder name for agency/cc
                opex_emp_no = None
                opex_emp_rec = None
                for opex_f in (found_folder.glob("OPEX-*.pdf") or []):
                    # OPEX filename encodes the J-code; requesting emp is in the .msg body
                    pass
                # Try to find requesting emp from the .msg body (look for emp_no in "Emp No: XXXXXXX")
                for msg_p in found_folder.glob("*.msg"):
                    try:
                        _msg2 = _emsg_v26.Message(str(msg_p))
                        import re as _re26
                        _m = _re26.search(r"(?:emp(?:loyee)?[\s#:]*no[.\s:]*|employee\s+id\s*:?\s*)(\d{7})", (_msg2.body or "").lower())
                        if _m:
                            opex_emp_no = _m.group(1)
                            opex_emp_rec = manpower.get(opex_emp_no)
                            break
                    except Exception:
                        pass
                h["account"]        = "60307021"
                # Labadi RULE 1 (2026-06-09): sponsorship rows carry the requestor
                # emp_no (AlJeel employee who submitted the OPEX form), never blank.
                # Use the emp_no extracted from the OPEX folder .msg body when found;
                # otherwise keep the existing emp_no on the row rather than clearing.
                if opex_emp_no:
                    h["emp_no"]     = opex_emp_no
                h["gl_name"]        = "Sponsoring Expenses"
                # If requesting emp found in master, use their agency/cc/div/solution
                if opex_emp_rec:
                    try:
                        h["cost_center"] = str(opex_emp_rec.cost_center or h.get("cost_center", "")).zfill(6)
                        h["div"]         = str(opex_emp_rec.div_code or h.get("div", "")).zfill(3)
                        h["agency"]      = str(opex_emp_rec.agency_code or h.get("agency", "")).zfill(5)
                        h["solution"]    = str(opex_emp_rec.solution or h.get("solution", "00000")).zfill(5)
                    except Exception:
                        pass
                h["_agent_method"]  = "v26_opex_event_overlay"
                h["_route_reason"]  = "OPEX_EVENT_FOLDER_MATCH"
                h["_v2_trace"]      = f"v26 overlay: {surname} found in {found_folder.name} (OPEX sponsorship confirmed)"
                h["_evidence_folder"] = str(found_folder)
                opex_event_overlay_count += 1
                try:
                    _rel = found_folder.relative_to(raw_root)
                except Exception:
                    _rel = found_folder.name
                print(f"  [v30-overlay] row {idx+1}: {passenger} -> 60307021 via {_rel}", flush=True)
    except Exception as _v26_err:
        print(f"[v30-overlay] error: {_v26_err}", flush=True)
    print(f"[v30-overlay] {opex_event_overlay_count} rows -> 60307021 via OPEX event folder match", flush=True)


    # ── stage 3g: OPEX serial catch-all from folder name ──────────────────
    # Any row that still has no opex_serial (shortcut rows, overlay rows,
    # LLM rows where extraction failed) gets one more chance: the evidence
    # folder name itself often carries the serial (e.g. "CRM-2026-27 Approvals").
    serial_from_folder = 0
    for h in hybrid_rows:
        if row_missing_evidence(h):
            continue
        cur = str(h.get("_opex_serial", "") or "").strip()
        if cur and cur not in ("MISSING", "N/A"):
            continue
        folder_text = str(h.get("_evidence_folder", "") or "")
        if not folder_text:
            continue
        extracted = _extract_serial_from_text(Path(folder_text).name)
        if not extracted:
            # Folder name has no serial — but the OPEX PDF filename inside it
            # often does (e.g. "OPEX-CE-18-2026-J-2026-108 (1).pdf").
            for opex_pdf in _find_opex_pdfs(Path(folder_text)):
                extracted = _extract_serial_from_text(opex_pdf.name)
                if extracted:
                    break
        if extracted:
            h["_opex_serial"] = extracted
            serial_from_folder += 1
    if serial_from_folder:
        print(f"[v30-serial] {serial_from_folder} rows → OPEX serial from folder name", flush=True)

    # ── stage 3h: deterministic family-folder emp_no rule (2026-06-09) ─────
    # Runs LAST among emp_no-mutating stages so the folder-name signal is
    # authoritative — "<ticket> family" folders pin the responsible employee's
    # emp_no (from the owner row's invoice Ref. No.) onto every family row.
    family_owner_map = build_family_folder_emp_map(all_folders, cascade_rows, manpower)
    family_stamped = apply_family_folder_emp_rule(hybrid_rows, cascade_rows, family_owner_map)
    print(f"[family-folder] {len(family_owner_map)} family folder(s) → "
          f"{family_stamped} rows emp_no stamped (EMP_FROM_FAMILY_FOLDER)", flush=True)

    # ── stage 3i: family annual-ticket GL + RULE 5 dual approval (2026-06-10) ──
    # Runs after 3h so emp_nos are settled. Family annual rows (family folder /
    # CHD-group) route to 21070229 and get a Mai+Sanad dual-approval evaluation
    # (process_batch left them N/A because the account flipped after its
    # RULE 5 finalisation pass).
    fam_rows = collect_family_annual_rows(hybrid_rows, cascade_rows, family_owner_map)
    fam_flipped = apply_family_annual_account_rule(hybrid_rows, cascade_rows, fam_rows, manpower)
    fam_folder_paths = _family_folder_paths(all_folders)
    _appr_cache: dict[str, tuple[str, str]] = {}
    for i, (owner_emp, trigger) in fam_rows.items():
        if row_missing_evidence(hybrid_rows[i]):
            continue
        if trigger.startswith("family_folder:"):
            folder = fam_folder_paths.get(trigger.split(":", 1)[1])
        else:
            ev = str(hybrid_rows[i].get("_evidence_folder", "") or "")
            folder = Path(ev) if ev and "family" in Path(ev).name.lower() else None
        key = str(folder) if folder else ""
        if key not in _appr_cache:
            _appr_cache[key] = evaluate_family_dual_approval(folder)
        mai_status, sanad_status = _appr_cache[key]
        hybrid_rows[i]["_mai_status"] = mai_status
        hybrid_rows[i]["_sanad_status"] = sanad_status
        for status, flag in ((mai_status, "ANNUAL_HR_APPROVAL_MISSING"),
                             (sanad_status, "ANNUAL_SANAD_APPROVAL_MISSING")):
            if status != "OK" and flag not in str(hybrid_rows[i].get("_flags", "")):
                hybrid_rows[i]["_flags"] = (
                    str(hybrid_rows[i].get("_flags", "")) + " " + flag
                ).strip()
    print(f"[family-annual] {fam_flipped} rows → account=21070229; "
          f"RULE 5 evaluated for {len(fam_rows)} family rows", flush=True)

    annual_home_stamped = stamp_verified_annual_home_segments(
        hybrid_rows,
        cascade_rows,
        manpower,
    )
    print(f"[family-annual] {annual_home_stamped} settled 21070229 row(s) "
          "received verified owner home segments", flush=True)

    # ── stage 3i.5: own approved form trip-purpose precedence ───────────────
    # A dedicated ticket folder with a parseable approved PC/OPEX form is row-owned
    # evidence. Its form->classifier->account result beats shared-OPEX, bundled PDF,
    # and master-shortcut fallbacks, while those fallbacks still apply to rows that
    # do not own a form.
    own_form_trip_applied = apply_own_form_trip_purpose_precedence(
        hybrid_rows,
        cascade_rows,
        manpower,
        all_folders,
    )
    sibling_trip_inherited = apply_sibling_leg_trip_purpose_inheritance(
        hybrid_rows,
        cascade_rows,
    )
    print(
        f"[sibling-trip-inherit] {sibling_trip_inherited} sibling ticket row(s) "
        "inherited trip purpose/account",
        flush=True,
    )

    # ── stage 3j: Trip Account Override enforcement (Labadi L4, 2026-06-10) ──
    # process_batch computes "Trip Account Override" from the trip-purpose
    # classifier (e.g. TRAINING → 60308009) and applies it at conf ≥ 0.7, but
    # later passes (shared-OPEX sponsorship in process_batch, LLM resolution
    # here) can flip the account again, leaving the override column and the
    # final Account disagreeing (J26-870 BUKHARI: override said 60308009, final
    # combo shipped 21070229 — Labadi corrected it back per his L4 rule).
    # Re-assert the override here, after every account-mutating stage and
    # before the combo is built. Family-annual locked rows keep their account.
    trip_ovr_applied = 0
    for i, c in enumerate(cascade_rows):
        if row_missing_evidence(hybrid_rows[i]):
            continue
        if row_verified_emp_locked(hybrid_rows[i]):
            continue
        if row_family_annual_locked(hybrid_rows[i]):
            continue
        ovr = str(c.get("Trip Account Override", "") or "").strip()
        if not ovr.isdigit():
            continue
        try:
            conf = float(c.get("Trip Purpose Confidence", 0) or 0)
        except (TypeError, ValueError):
            conf = 0.0
        if conf < 0.7:
            continue
        old_acct = str(hybrid_rows[i].get("account", "") or "").strip()
        if old_acct == ovr:
            continue
        hybrid_rows[i]["account"] = ovr
        # Cascade-method rows are skipped by write_v15_12_xlsx — promote so
        # the new account (and a rebuilt combo) actually reach the sheet.
        if hybrid_rows[i].get("_agent_method", "cascade") == "cascade":
            hybrid_rows[i]["_agent_method"] = "hybrid_overlay"
        hybrid_rows[i]["_flags"] = (
            str(hybrid_rows[i].get("_flags", "")) + " TRIP_ACCOUNT_OVERRIDE_APPLIED"
        ).strip()
        trip_ovr_applied += 1
        print(f"  [v30-trip-ovr] row {i+1}: account {old_acct or '?'} → {ovr} "
              f"(Trip Purpose={c.get('Trip Purpose')}, conf={conf})", flush=True)
    print(f"[v30-trip-ovr] {trip_ovr_applied} rows → Trip Account Override re-applied",
          flush=True)

    # ── stage 3k: bundled/shared PDF trip-purpose inheritance ─────────────
    # Late final account pass: LLM resolution, shared-OPEX sponsorship routing,
    # deterministic overlays, family annual, and Trip Account Override have all
    # settled by here. Keep this before cost-center override and the XLSX write
    # so inherited purpose/account participates in combo/stamp generation.
    # Child ticket rows rescued by BUNDLED_TICKET_SHARED_PDF:<host_ticket>
    # share evidence with the host PDF. If the child has only UNKNOWN/default
    # trip purpose, inherit the host's final purpose-derived account so both
    # legs of one trip stay on the same GL.
    bundled_trip_inherited = apply_bundled_shared_pdf_trip_purpose_inheritance(
        hybrid_rows,
        cascade_rows,
    )
    print(
        f"[bundled-trip-inherit] {bundled_trip_inherited} bundled ticket row(s) "
        "inherited host trip purpose/account",
        flush=True,
    )

    apply_cc_account_override(hybrid_rows)
    opex_email_only = apply_opex_email_only_review_state(
        hybrid_rows,
        cascade_rows,
        raw_root,
        all_folders,
        reverse_index,
    )
    print(
        f"[opex-email-only] {opex_email_only} row(s) routed to review without exact OPEX PDF segments",
        flush=True,
    )

    # ── stage 4: write XLSX ────────────────────────────────────────────────
    apply_sponsorship_event_segments(
        hybrid_rows,
        cascade_rows,
        manpower,
        raw_root,
        all_folders,
        reverse_index,
    )
    ancillary_inherited = inherit_ancillary_event_allocations(hybrid_rows, cascade_rows)
    print(f"[ancillary-event] {ancillary_inherited} missing ancillary row(s) inherited event allocation", flush=True)

    for h in hybrid_rows:
        m = h.get("_agent_method", "")
        if m.startswith("v26_") or m.startswith("v25_") or m.startswith("v18_") or m.startswith("v16_") or m in (
            "v16_master_shortcut", "v16_sponsorship_master", "own_form_trip_purpose"
        ):
            h["_agent_method_orig"] = m
            h["_agent_method"] = "cluster_unified" if "cluster" in m else "llm_agent"

    v15.write_v15_12_xlsx(cascade_xlsx, out_xlsx, hybrid_rows, cascade_rows, hdr_row)
    stamp_own_form_trip_columns(out_xlsx, hybrid_rows, hdr_row)

    # cascade_fallback rows are copied from the cascade workbook by the v15 writer.
    # VERIFIED_EMP_LOCK rows must still persist the stage-2.5 corrected identity.
    try:
        _wb_lock = openpyxl.load_workbook(out_xlsx)
        _ws_lock = _wb_lock.active
        _cols_lock = {}
        for _ci in range(1, _ws_lock.max_column + 1):
            _hdr = str(_ws_lock.cell(hdr_row, _ci).value or "").strip()
            if _hdr:
                _cols_lock[_hdr] = _ci
        _locked_fallback_written = 0
        _locked_combo_written = 0
        if "Account" in _cols_lock and "Employee No" in _cols_lock:
            _combo_col_lock = next(
                (_ci for _hdr, _ci in _cols_lock.items() if "distribution combination" in _hdr.lower()),
                None,
            )

            def _pad_lock(_v, _w):
                _s = str(_v or "").strip()
                return _s.zfill(_w) if _s.isdigit() else (_s or "0" * _w)

            for _i, _h in enumerate(hybrid_rows):
                _method = str(_h.get("_agent_method", "") or "")
                _acct = str(_h.get("account", "") or "").strip()
                if (
                    "cascade_fallback" not in _method
                    or row_missing_evidence(_h)
                    or not row_verified_emp_locked(_h)
                    or not _acct
                ):
                    continue
                _row = _h["_row_idx"]
                _ws_lock.cell(_row, _cols_lock["Account"]).value = _acct
                _emp = str(_h.get("emp_no", "") or "").strip()
                if _emp:
                    _ws_lock.cell(_row, _cols_lock["Employee No"]).value = _emp
                for _key, _hdr in (
                    ("cost_center", "Cost Center"),
                    ("div", "DIV"),
                    ("solution", "Solution"),
                    ("agency", "Agency"),
                ):
                    _val = str(_h.get(_key, "") or "").strip()
                    if _val and _hdr in _cols_lock:
                        _ws_lock.cell(_row, _cols_lock[_hdr]).value = _val
                if _combo_col_lock:
                    _existing_combo = str(_ws_lock.cell(_row, _combo_col_lock).value or "").strip()
                    _parts = _existing_combo.split("-") if _existing_combo else []
                    _co = (
                        str(_ws_lock.cell(_row, _cols_lock["Company"]).value or "").strip()
                        if "Company" in _cols_lock
                        else ""
                    ) or (_parts[0] if len(_parts) > 0 else "03")
                    _loc = (
                        str(_ws_lock.cell(_row, _cols_lock["Location"]).value or "").strip()
                        if "Location" in _cols_lock
                        else ""
                    ) or (_parts[1] if len(_parts) > 1 else "40100")
                    _cc = (
                        str(_ws_lock.cell(_row, _cols_lock["Cost Center"]).value or "").strip()
                        if "Cost Center" in _cols_lock
                        else ""
                    ) or (_parts[3] if len(_parts) > 3 else "000000")
                    _div = (
                        str(_ws_lock.cell(_row, _cols_lock["DIV"]).value or "").strip()
                        if "DIV" in _cols_lock
                        else ""
                    ) or (_parts[4] if len(_parts) > 4 else "000")
                    _sol = (
                        str(_ws_lock.cell(_row, _cols_lock["Solution"]).value or "").strip()
                        if "Solution" in _cols_lock
                        else ""
                    ) or (_parts[5] if len(_parts) > 5 else "00000")
                    _ag = (
                        str(_ws_lock.cell(_row, _cols_lock["Agency"]).value or "").strip()
                        if "Agency" in _cols_lock
                        else ""
                    ) or (_parts[6] if len(_parts) > 6 else "00000")
                    _proj = _parts[7] if len(_parts) > 7 else "00000"
                    _ic = _parts[8] if len(_parts) > 8 else "00"
                    _f1 = _parts[9] if len(_parts) > 9 else "000000"
                    _ws_lock.cell(_row, _combo_col_lock).value = (
                        f"{_pad_lock(_co,2)}-{_pad_lock(_loc,5)}-{_pad_lock(_acct,8)}-"
                        f"{_pad_lock(_cc,6)}-{_pad_lock(_div,3)}-{_pad_lock(_sol,5)}-"
                        f"{_pad_lock(_ag,5)}-{_pad_lock(_proj,5)}-{_pad_lock(_ic,2)}-{_pad_lock(_f1,6)}"
                    )
                    _locked_combo_written += 1
                _locked_fallback_written += 1
            if _locked_fallback_written:
                _wb_lock.save(str(out_xlsx))
        else:
            print("[verified-lock] Account/Employee No column missing — skipping fallback write guard", flush=True)
        print(
            f"[verified-lock] {_locked_fallback_written} cascade_fallback row(s) "
            "wrote locked account/emp_no/segments from hybrid_rows "
            f"({_locked_combo_written} combo(s) rebuilt)",
            flush=True,
        )
    except Exception as _lock_write_err:
        print(f"[verified-lock] error writing cascade_fallback locked values: {_lock_write_err}", flush=True)

    stamp_missing_evidence_output(out_xlsx, hybrid_rows, hdr_row)
    stamp_opex_email_only_output(out_xlsx, hybrid_rows, hdr_row)
    stamp_sponsorship_form_columns(out_xlsx, hybrid_rows, hdr_row)

    for h in hybrid_rows:
        if "_agent_method_orig" in h:
            h["_agent_method"] = h.pop("_agent_method_orig")

    # write_v15_12_xlsx copies the cascade workbook before applying hybrid
    # account updates, so inherited trip-purpose cells need a small explicit
    # stamp just like later flag/serial post-write stamps.
    try:
        _wb_tp = openpyxl.load_workbook(out_xlsx)
        _ws_tp = _wb_tp.active
        _cols_tp = {}
        for _ci in range(1, _ws_tp.max_column + 1):
            _hdr = str(_ws_tp.cell(hdr_row, _ci).value or "").strip()
            if _hdr in (
                "Trip Purpose",
                "Trip Purpose Confidence",
                "Trip Account Override",
                "Trip Purpose Trace",
            ):
                _cols_tp[_hdr] = _ci
        _tp_written = 0
        for _h in hybrid_rows:
            _inherit = _h.get("_inherited_trip_purpose")
            if not _inherit:
                continue
            _row = _h["_row_idx"]
            for _hdr, _val in _inherit.items():
                if _hdr in _cols_tp:
                    _ws_tp.cell(_row, _cols_tp[_hdr]).value = _val
            _tp_written += 1
        if _tp_written:
            _wb_tp.save(str(out_xlsx))
        print(
            f"[bundled-trip-inherit] {_tp_written} inherited trip-purpose row(s) "
            "stamped into output",
            flush=True,
        )
    except Exception as _tp_err:
        print(f"[bundled-trip-inherit] error stamping inherited trip purpose: {_tp_err}", flush=True)

    print(f"[out] {out_xlsx.name} (v30 pass complete)", flush=True)

    # ── stage 4.2: write OPEX Serial column (Labadi RULE 4) ────────────────
    # write_v15_12_xlsx copies the cascade xlsx, whose "OPEX Serial" column was
    # filled by process_batch in an earlier run — before run_v30's serial
    # extraction (LLM pass, multi-salesman backfill, stage 3g folder catch-all)
    # existed. The serials collected on hybrid_rows["_opex_serial"] were never
    # written to any column, so they must be stamped here, after all extraction
    # passes complete and the output workbook exists.
    try:
        from copy import copy as _copy_style
        _wb_ser = openpyxl.load_workbook(out_xlsx)
        _ws_ser = _wb_ser.active
        _col_serial = None
        for _ci in range(1, _ws_ser.max_column + 1):
            if str(_ws_ser.cell(hdr_row, _ci).value or "").strip() == "OPEX Serial":
                _col_serial = _ci
                break
        if _col_serial is None:
            print("[v30-serial] 'OPEX Serial' column not found — skipping write", flush=True)
        else:
            # Same event keywords as process_batch._labadi_is_opex_context —
            # used only when the cell is blank and context must be re-derived.
            _event_kw = (
                "sponsor", "opex", "forum", "registration", "conference",
                "congress", "exhibition", "summit", "symposium", "iepc",
            )
            _serials_written = 0
            for _i, _h in enumerate(hybrid_rows):
                _cell = _ws_ser.cell(_h["_row_idx"], _col_serial)
                _serial = str(_h.get("_opex_serial", "") or "").strip()
                _existing = str(_cell.value or "").strip()
                if _serial and _serial not in ("MISSING", "N/A"):
                    if _existing != _serial:
                        if _existing.upper() == "MISSING" and _col_serial > 1:
                            # Cell carried the red MISSING fill — inherit the
                            # plain row fill from the neighbouring cell.
                            _cell.fill = _copy_style(
                                _ws_ser.cell(_h["_row_idx"], _col_serial - 1).fill
                            )
                        _cell.value = _serial
                        _serials_written += 1
                elif _existing in ("", "None"):
                    # No serial from any pass and no value from process_batch:
                    # MISSING for OPEX-context rows, N/A for pure employee travel.
                    _acct = str(_h.get("account", "") or "").strip()
                    _blob = " ".join(
                        str(x or "") for x in (
                            _h.get("_evidence_folder", ""),
                            cascade_rows[_i].get("Description", ""),
                            cascade_rows[_i].get("Notes", ""),
                        )
                    ).lower()
                    _cell.value = (
                        "MISSING"
                        if _acct == "60307021" or any(k in _blob for k in _event_kw)
                        else "N/A"
                    )
            _wb_ser.save(str(out_xlsx))
            print(f"[v30-serial] {_serials_written} serials written to OPEX Serial column", flush=True)
    except Exception as _ser_err:
        print(f"[v30-serial] error writing OPEX Serial column: {_ser_err}", flush=True)

    # ── stage 4.3: stamp hybrid-row flags into the Agent Flags column ──────
    # Flags accumulated on hybrid_rows["_flags"] (EMP_FROM_FAMILY_FOLDER,
    # FAMILY_CLUSTER_CHD_USES_SPONSOR_EMP) are appended to the existing
    # Agent Flags cell so the emp_no provenance is traceable in the output.
    try:
        _wb_fl = openpyxl.load_workbook(out_xlsx)
        _ws_fl = _wb_fl.active
        _col_flags = None
        for _ci in range(1, _ws_fl.max_column + 1):
            if str(_ws_fl.cell(hdr_row, _ci).value or "").strip() == "Agent Flags":
                _col_flags = _ci
                break
        if _col_flags is None:
            print("[v30-flags] 'Agent Flags' column not found — skipping flag stamp", flush=True)
        else:
            _flags_written = 0
            for _h in hybrid_rows:
                _new_flags = [f for f in str(_h.get("_flags", "") or "").split() if f]
                _new_flags.extend(
                    f for f in _h.get("_agent_flag_details", [])
                    if str(f or "").strip()
                )
                if not _new_flags:
                    continue
                _cell = _ws_fl.cell(_h["_row_idx"], _col_flags)
                _existing = str(_cell.value or "").strip()
                _missing = [f for f in _new_flags if f not in _existing]
                if not _missing:
                    continue
                if _existing and _existing.upper() != "CLEAN":
                    _cell.value = _existing + " | " + " | ".join(_missing)
                else:
                    _cell.value = " | ".join(_missing)
                _flags_written += 1
            _wb_fl.save(str(out_xlsx))
            print(f"[v30-flags] {_flags_written} rows → flags stamped into Agent Flags", flush=True)
    except Exception as _fl_err:
        print(f"[v30-flags] error stamping flags: {_fl_err}", flush=True)

    clear_stale_employee_not_in_master_output(out_xlsx, hybrid_rows, manpower, hdr_row)

    # ── stage 4.35: stamp RULE 5 dual-approval statuses (family annual rows) ──
    # process_batch fills "HR Approval (Mai)" / "Sanad Approval" only for rows
    # that were 21070229 during ITS pass; rows flipped by stage 3i still carry
    # N/A in the copied cascade sheet. Stamp the statuses evaluated in 3i, and
    # append the family-annual trigger to the Agent Account Rule trace.
    try:
        _wb_ap = openpyxl.load_workbook(out_xlsx)
        _ws_ap = _wb_ap.active
        _col_mai = _col_sanad = _col_acct = _col_rule = None
        for _ci in range(1, _ws_ap.max_column + 1):
            _v = str(_ws_ap.cell(hdr_row, _ci).value or "").strip()
            if _v == "HR Approval (Mai)":
                _col_mai = _ci
            elif _v == "Sanad Approval":
                _col_sanad = _ci
            elif _v == "Account":
                _col_acct = _ci
            elif _v == "Agent Account Rule":
                _col_rule = _ci
        if not (_col_mai and _col_sanad and _col_acct):
            print("[family-annual] approval columns not found — skipping RULE 5 stamp", flush=True)
        else:
            _ap_written = 0
            for _h in hybrid_rows:
                if not _h.get("_mai_status"):
                    continue
                _row = _h["_row_idx"]
                _final_acct = str(_ws_ap.cell(_row, _col_acct).value or "").strip()
                if _final_acct != "21070229":
                    continue  # account did not flip — leave process_batch's N/A
                _ws_ap.cell(_row, _col_mai).value = _h["_mai_status"]
                _ws_ap.cell(_row, _col_sanad).value = _h["_sanad_status"]
                if _col_rule and _h.get("_family_annual"):
                    _rule_cell = _ws_ap.cell(_row, _col_rule)
                    _detail = f"family_annual_ticket: {_h['_family_annual']}"
                    _existing_rule = str(_rule_cell.value or "").strip()
                    if _detail not in _existing_rule:
                        _rule_cell.value = (
                            f"{_existing_rule} | {_detail}" if _existing_rule else _detail
                        )
                _ap_written += 1
            _wb_ap.save(str(out_xlsx))
            print(f"[family-annual] RULE 5 statuses stamped on {_ap_written} rows", flush=True)
    except Exception as _ap_err:
        print(f"[family-annual] error stamping RULE 5 statuses: {_ap_err}", flush=True)

    # ── stage 4.4: v30 — Force rewrite cascade locations from Manpower ───────────
    try:
        _wb_loc = openpyxl.load_workbook(out_xlsx)
        _ws_loc = _wb_loc.active
        
        # Load manpower quickly
        import pandas as pd
        _df_m = pd.read_excel('/home/clawdbot/.openclaw/workspace/aljeel/qc/master-data/Aljeel_Lookups-v2.xlsx', sheet_name='Manpower')
        _loc_map = {}
        for _, _row in _df_m.iterrows():
            _emp_raw = _row.iloc[0]
            _loc_raw = _row.iloc[4]
            if pd.notna(_emp_raw):
                try:
                    _loc_map[str(int(_emp_raw))] = str(int(_loc_raw)) if pd.notna(_loc_raw) else ""
                except:
                    pass
                    
        for _r in range(4, _ws_loc.max_row+1):
            _combo = str(_ws_loc.cell(_r, 14).value)
            _emp_no = str(_ws_loc.cell(_r, 16).value) if _ws_loc.cell(_r, 16).value else ""
            if _combo and len(_combo.split('-')) == 10:
                _parts = _combo.split('-')
                _new_loc = _parts[1]
                if _emp_no in _loc_map:
                    _l = _loc_map[_emp_no]
                    if _l:
                        _new_loc = _l
                    else:
                        _new_loc = _parts[1]
                else:
                    _new_loc = _parts[1]
                _parts[1] = _new_loc
                _ws_loc.cell(_r, 14).value = "-".join(_parts)
        _wb_loc.save(str(out_xlsx))
        print("[v30-loc] Cascade locations explicitly rewritten from Manpower", flush=True)
    except Exception as e:
        print(f"[v30-loc] Error rewriting locations: {e}", flush=True)

    # ── stage 5: booking-group detection ──────────────────────────────────
    bg_propagated, bg_conflicts = apply_booking_groups_inline_v25(out_xlsx)

    # ── stage 5.5: sync final derived descriptions after all combo mutations ──
    gl_synced = sync_final_gl_descriptions(out_xlsx, cascade_xlsx, hdr_row)

    # ── stage 5.6: prefix OPEX serial onto sponsorship Descriptions (Labadi) ──
    # Labadi prepends the OPEX serial to the line description on every
    # sponsorship row ("{SERIAL}-{description}") so the serial lands in the
    # Oracle journal line. Only rows with a real serial (not MISSING/N/A) AND
    # sponsorship character (account=60307021, or blank/multi emp_no) qualify.
    # Runs after stage 5 because booking-group detection parses Description —
    # the prefix must be the LAST Description mutation in the pipeline.
    try:
        _wb_dp = openpyxl.load_workbook(out_xlsx)
        _ws_dp = _wb_dp.active
        _cols_dp = {}
        for _ci in range(1, _ws_dp.max_column + 1):
            _v = str(_ws_dp.cell(hdr_row, _ci).value or "").strip()
            if _v in ("Description", "OPEX Serial", "Account", "Employee No"):
                _cols_dp[_v] = _ci
        if len(_cols_dp) < 4:
            print(f"[v30-desc-serial] columns missing (found {sorted(_cols_dp)}) — "
                  f"skipping Description prefix", flush=True)
        else:
            _prefixed = 0
            for _h in hybrid_rows:
                if row_missing_evidence(_h):
                    continue
                _r = _h["_row_idx"]
                _serial = str(_ws_dp.cell(_r, _cols_dp["OPEX Serial"]).value or "").strip()
                if not _serial or _serial.upper() in ("MISSING", "N/A", "NONE"):
                    continue
                _acct = str(_ws_dp.cell(_r, _cols_dp["Account"]).value or "").strip()
                _emp  = str(_ws_dp.cell(_r, _cols_dp["Employee No"]).value or "").strip()
                if not (_acct == "60307021" or _emp == "" or "," in _emp):
                    continue  # not a sponsorship row — Description stays untouched
                _desc_cell = _ws_dp.cell(_r, _cols_dp["Description"])
                _desc = str(_desc_cell.value or "")
                if not _desc or _desc.startswith(_serial):
                    continue  # empty or already prefixed
                _desc_cell.value = f"{_serial}-{_desc}"
                _prefixed += 1
            _wb_dp.save(str(out_xlsx))
            print(f"[v30-desc-serial] {_prefixed} sponsorship Description(s) prefixed "
                  f"with OPEX serial", flush=True)
    except Exception as _dp_err:
        print(f"[v30-desc-serial] error prefixing Descriptions: {_dp_err}", flush=True)

    # ── stage 6: fraud detection ───────────────────────────────────────────
    fraud_catches: list[dict] = []
    if not args.skip_fraud:
        fraud_catches = run_fraud_detection(batch_id, cascade_rows, hybrid_rows, out_dir)
        # Override fraud output filename to v30
        fraud_out_v24 = out_dir / "fraud-watch-v24.json"
        fraud_out_v25 = out_dir / f"fraud-watch-{VERSION}.json"
        if fraud_out_v24.exists() and not fraud_out_v25.exists():
            import shutil as _shutil
            _shutil.copy2(fraud_out_v24, fraud_out_v25)
    else:
        print("[consistency-check] skipped (--skip-fraud)", flush=True)

    # ── stage 7: step trace ────────────────────────────────────────────────
    trace_path = out_dir / f"step-trace-{VERSION}.jsonl"
    if step_traces:
        with open(trace_path, "w") as tf:
            for t in step_traces:
                tf.write(json.dumps(t, default=str) + "\n")
        print(f"[trace] {len(step_traces)} routed rows → {trace_path.name}", flush=True)

    # ── stage 8: auto-score ────────────────────────────────────────────────
    auto_score: str = "N/A"
    truth_candidates = list(batch_dir.glob(f"{batch_id}.xlsx"))
    if truth_candidates:
        try:
            import subprocess
            qc_script = ROOT / "qc" / "score_against_truth.py"
            score_out = out_dir / f"score-{VERSION}.md"
            result = subprocess.run(
                ["python3", str(qc_script), str(out_xlsx), str(truth_candidates[0])],
                capture_output=True, text=True, timeout=120,
            )
            score_out.write_text(result.stdout)
            for line in reversed(result.stdout.splitlines()):
                m = re.search(r"All-5-segments exact.*?(\d+\.\d+)%", line)
                if m:
                    auto_score = f"{m.group(1)}%"
                    break
            print(f"[score] {auto_score}  → {score_out.name}", flush=True)
        except Exception as e:
            print(f"[score] auto-score failed: {e}", flush=True)
    else:
        print(f"[score] no truth file found (blind run)", flush=True)

    # ── summary ───────────────────────────────────────────────────────────
    cost_usd = (total_in * pricing_pro["in"]) + (total_out * pricing_pro["out"])
    method_counts: dict[str, int] = Counter(h["_agent_method"] for h in hybrid_rows)
    fraud_cats = Counter(c["category"] for c in fraud_catches)

    summary = {
        "batch_id":                   batch_id,
        "version":                    VERSION,
        "timestamp_utc":              utc_ts(),
        "total_rows":                 len(cascade_rows),
        "routed_to_llm":              len(routed),
        "routing_reasons":            dict(reason_counts),
        "method_counts":              dict(method_counts),
        "cluster_unified":            unified,
        "pc_applied":                 pc_applied,
        "pc_family_blanked":          pc_family_blanked,
        "booking_group_propagated":   bg_propagated,
        "booking_group_conflicts":    bg_conflicts,
        "gl_descriptions_synced":     gl_synced,
        "llm_errors":                 llm_errors,
        "no_cache":                   no_cache,
        "auto_score_all5":            auto_score,
        "fraud_catches":              len(fraud_catches),
        "fraud_categories":           dict(fraud_cats),
        "llm_in_tokens":              total_in,
        "llm_out_tokens":             total_out,
        "cost_usd_est":               round(cost_usd, 4),
        "cost_ceiling":               args.cost_ceiling,
        "runtime_sec":                round(time.time() - t_start, 1),
        "cascade_input":              str(cascade_xlsx),
        "output":                     str(out_xlsx),
    }
    (out_dir / f"summary-{VERSION}.json").write_text(
        json.dumps(summary, indent=2, default=str)
    )

    print()
    print("=" * 65)
    print(f"  {VERSION} done — {batch_id}")
    print(f"  Rows:              {summary['total_rows']}  ({len(routed)} routed to LLM)")
    print(f"  Methods:           {dict(method_counts)}")
    print(f"  Cluster unif.:     {unified}")
    print(f"  PC applied:        {pc_applied}")
    print(f"  PC-family blanked: {pc_family_blanked}")
    print(f"  Booking groups:    {bg_propagated} propagated  "
          f"{bg_conflicts} conflicts {'⚠️' if bg_conflicts else '✅'}")
    print(f"  GL synced:         {gl_synced}")
    print(f"  Fraud catches:     {len(fraud_catches)}"
          f"  {dict(fraud_cats) if fraud_cats else '(none)'}")
    print(f"  LLM cost (est):    ${cost_usd:.4f}  ({total_in:,} in / {total_out:,} out)")
    print(f"  Runtime:           {summary['runtime_sec']:.1f}s")
    print(f"  Score (auto):      {auto_score}")
    print(f"  Step trace:        {len(step_traces)} rows → step-trace-{VERSION}.jsonl")
    print(f"  Output:            {out_xlsx.name}")
    print("=" * 65)


if __name__ == "__main__":
    main()
